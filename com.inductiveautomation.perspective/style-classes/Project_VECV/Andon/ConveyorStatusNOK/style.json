{
  "base": {
    "animation": {
      "duration": "1s",
      "direction": "alternate-reverse",
      "fillMode": "none",
      "keyframes": {
        "0%": {
          "backgroundColor": "#FF4747",
          "borderTopLeftRadius": "80px",
          "borderTopRightRadius": "80px",
          "borderBottomLeftRadius": "80px",
          "borderBottomRightRadius": "80px"
        },
        "100%": {
          "backgroundColor": "#D90000",
          "borderTopLeftRadius": "80px",
          "borderTopRightRadius": "80px",
          "borderBottomLeftRadius": "80px",
          "borderBottomRightRadius": "80px"
        }
      }
    }
  }
}