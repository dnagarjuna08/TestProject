                      "config": {
                        "script": "\t\"\"\"\n\tWritten By: Amit Ravat\n\tWritten Date: 24/05/2024\n\tPurpose:\n\t\t\tThe purpose of the script to update rework data.\n\t\"\"\"\t\n\ttry:\n\t\tarea \u003d self.session.custom.CurrentAreaId\n\t\tline \u003d self.session.custom.CurrentLineId\n\t\tworkStationId \u003d self.session.custom.CurrentWorkStationId\n#\t\tarea \u003d23\n#\t\tline \u003d38\n#\t\tworkStationId \u003d 366\n\t\tserialNumber\u003dself.view.params.serialNumber\n\t\tcreatedBy\u003d self.session.custom.loggedInUserId\n\t\tbomId \u003dself.view.params.bomId\n\t\teventId \u003dself.view.params.eventId\n\t\tparams \u003d {\u0027SerialNumber\u0027:serialNumber,\u0027AreaId\u0027:int(area),\u0027LineId\u0027:int(line),\u0027WorkStationId\u0027:int(workStationId),\u0027CreatedBy\u0027:int(createdBy),\u0027BomId\u0027:int(bomId),\u0027EventId\u0027:int(eventId)}\n\t\tresult \u003d system.db.runNamedQuery(\"Project_VECV/OperatorDashboard/Rework/UpdateReworkData\",params)\n\t\tif eventId \u003d\u003d 10:\n\t\t\tmessage \u003d \u0027Rework Started\u0027\n\t\telif eventId \u003d\u003d 11:\n\t\t\tmessage \u003d \u0027Rework Completed\u0027\n\t\telif eventId \u003d\u003d 14:\n\t\t\tmessage \u003d \u0027Repair Started\u0027\n\t\telif eventId \u003d\u003d 15:\n\t\t\tmessage \u003d \u0027Repair Completed\u0027\n\t\tstate \u003d \"Sucess\"\n\t\tProject_VECV.PopUp.Alerts.showAlert(str(state), str(state.capitalize()), str(message), \"true\", \"Okay\", \"\", \"\", \"\", \"\", \"closePopup\", \"closePopup\", \"closePopup\", \"\", \"\", \"\", \"\")\n \t\tsystem.perspective.print(\u0027 from startstop popup \u0027+str(params))\n\t\tsystem.perspective.closePopup(\"Rework\")\n\t\tif int(eventId) \u003d\u003d 11 or int(eventId) \u003d\u003d 15:\n\t\t\tsystem.perspective.sendMessage(\"RefreshParams\")\n\t\t\tsystem.perspective.print(\u0027RefreshParams message sent \u0027)\n\t\tsystem.perspective.sendMessage(\"refreshQGData\")\n\t\t\n\texcept:\t\n\t\t#start of except block\t\t\n\t\tscreenName \u003d\u0027Rework StartStop\u0027 \n\t\tfilePath\u003dstr(\u0027Project_VECV/PopUp/OperatorDashBoard/Rework/StartStop\u0027)\n\t\terrorFunction \u003d str(\u0027Event:onClick- btnYes\u0027)\n\t\terrorType\u003dstr(\u0027Application\u0027)\n\t\terrorCode \u003d str(Project_VECV.Common.GenerateUUID.getUniqueUUID()) \n\t\tdescription\u003dstr(sys.exc_info()[1]) #error description\n\t\tlineNumber\u003dstr(sys.exc_info()[2].tb_lineno) #lineno on which error occur\t\t\t\n\t\tProject_VECV.Configuration.Common.AddLogDetails.AddErrorLogs(screenName,filePath,errorFunction,errorType,errorCode,description,lineNumber)\n\t\tsystem.perspective.print(\u0027lineNumber \u0027+str(lineNumber)+\u0027 description \u0027+str(description))\n\t"
                      },
