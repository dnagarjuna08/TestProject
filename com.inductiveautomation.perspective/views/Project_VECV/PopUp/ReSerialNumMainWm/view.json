              "script": "\tSerialNumber \u003d self.props.text\n\tif SerialNumber\u003d\u003d\u0027\u0027:\n\t\treturn \n\t#get GearRation and Fill the next Field\n\tsystem.perspective.print(\"serial num --\u003e %s\"%SerialNumber)\n\twsId\u003dself.getSibling(\"drpStation\").props.value\n\twsName\u003dself.getSibling(\"drpStation\").props.options\n\tsystem.perspective.print(wsId)\n\tdata \u003d system.db.runNamedQuery(\"Project_VECV/ITSupport/rePrint/validateSerialNumber\",{\"SerialNumber\":SerialNumber, \"WorkStationId\":wsId})\n\tif str(data) \u003d\u003d \u00270\u0027:\n\t\tmessage \u003d \"Print NA, Recheck Serial Number , Or else Serial Number not started at selected station\"\n\t\tstate \u003d \"warning\"\n\t\tProject_VECV.PopUp.Alerts.showAlert(str(state), str(state.capitalize()), str(message), \"true\", \"Okay\", \"\", \"\", \"\", \"\", \"closePopup\", \"closePopup\", \"closePopup\",\"\",\"\",\"\",\"\")\n\t\tself.getSibling(\"txtGearRatio\").props.text \u003d \u0027\u0027\n\t\tself.getSibling(\"txtGearRatio\").props.enabled \u003d False\n\t\tself.getSibling(\"drpStation\").props.value\u003d-1\n\t\tself.props.text\u003d\u0027\u0027\n\t\t\n\telse:\n\t\tself.getSibling(\"txtGearRatio\").props.text \u003d data\n\t\tself.getSibling(\"txtGearRatio\").props.enabled \u003d False\t"
