      {
        "events": {
          "dom": {
            "onClick": {
              "config": {
                "script": "\t\"\"\"\n\t    Written By: Aniket Sagar\n\t    Written Date: 02/02/2025\n\t    Purpose: Print barcode with error handling\n\t\"\"\"\n\ttry:\n\t\t#wsName \u003d self.getSibling(\"drpStation\").props.options\n\t\t#system.perspective.print(\"wsName \u003d\u003d %s\" % wsName)\n\t\t\n\t\twsID \u003d self.getSibling(\"drpStation\").props.value\n\t\tsystem.perspective.print(\"wsID \u003d\u003d %s\" % wsID)\n\t\t\n\t\t# Fetch printer details\n\t\tres \u003d system.db.runNamedQuery(\"Project_VECV/Order/WashingMachine/GetPrinterDetails\", {\u0027WorkStation\u0027: wsID})\n\t\tpyres \u003d system.dataset.toPyDataSet(res)\n\t\t\n\t\tfor row in pyres:\n\t\t    IP \u003d row[\"IPAddress\"]\n\t\t    port \u003d row[\"Port\"]\n\t\t\n\t\t# Gather input data\n\t\tserialNumber \u003d self.getSibling(\"txtSerialNumber\").props.text\n\t\tserialNumber\u003dserialNumber.upper()\n\t\tModel \u003d serialNumber.split(\u0027-\u0027)[1]\n\t\tGearRatio \u003d self.getSibling(\"txtGearRatio\").props.text\n\t\tGearRatio\u003dGearRatio.upper()\n\t\tshift \u003d self.getSibling(\"txtShift\").props.text\n\t\tshift\u003dshift.upper()\n\t\tdate \u003d self.getSibling(\"DateTimeInput\").props.value\n\t\tdate \u003d system.date.format(date, \"dd/MM/yy\")\n\t\tUserName \u003d self.getSibling(\"txtUser\").props.text\n\t\t\n\t\t# Get User ID\n\t\tgetUserID \u003d system.db.runNamedQuery(\u0027Project_VECV/ITSupport/rePrint/getUsertoSave\u0027, {\u0027UserName\u0027: UserName})\n\t\tsystem.perspective.print(\"UserID \u003d\u003d %s\" % getUserID)\n\t\t\n\t\toptions \u003d self.getSibling(\"drpStation\").props.options\n\t\toptions \u003d system.dataset.toPyDataSet(options)\n\t\twsName\u003d\u0027\u0027\n\t\tfor i in options:\n\t\t\tif i[\u0027value\u0027] \u003d\u003d wsID:\n\t\t\t\twsName \u003d i[\u0027label\u0027]\n\t\t\t\tbreak\n\t\t# Print and database insertion based on WorkStation ID\n\t\tsystem.perspective.print(\"wsName \u003d\u003d %s\" % wsName)\n\t\tif wsID \u003d\u003d 278:  # LAD10\n\t\t    NoofPrint \u003d 3\n\t\t    system.perspective.print(\"LAD10\")\n\t\t    Project_VECV.Printer.GetPrint.getPrintHelp(serialNumber, GearRatio, shift, IP, port, NoofPrint, date)\n\t\t    system.perspective.print(\"Before Query\")\n\t\t    system.db.runNamedQuery(\"Project_VECV/ITSupport/InsertNumberPunchingStatus\", {\n\t\t        \"WorkStationName\": wsName, \"SerialNumber\": serialNumber, \"BOMNumber\": Model, \"CreatedBy\": getUserID})\n\t\t    system.perspective.print(\"After Query\")\n\t\telif wsID \u003d\u003d 357:  # TAWM02\n\t\t    NoofPrint \u003d 5\n\t\t    Project_VECV.Printer.GetPrint.getPrintHelp(serialNumber, GearRatio, shift, IP, port, NoofPrint, date)\n\t\t    system.db.runNamedQuery(\"Project_VECV/ITSupport/InsertNumberPunchingStatus\", {\n\t\t        \"WorkStationName\": wsName, \"SerialNumber\": serialNumber, \"BOMNumber\": Model, \"CreatedBy\": getUserID})\n\t\telif wsID \u003d\u003d 268:  # LAH20\n\t\t    NoofPrint \u003d 4\n\t\t    Project_VECV.Printer.GetPrint.getPrintHelp(serialNumber, GearRatio, shift, IP, port, NoofPrint, date)\n\t\t    system.db.runNamedQuery(\"Project_VECV/ITSupport/InsertNumberPunchingStatus\", {\n\t\t        \"WorkStationName\": wsName, \"SerialNumber\": serialNumber, \"BOMNumber\": Model, \"CreatedBy\": getUserID})\n\t\telif wsID \u003d\u003d 374:  # LAML10\n\t\t    NoofPrint \u003d 1\n\t\t    Project_VECV.Printer.GetPrint.getPrintHelp(serialNumber, GearRatio, shift, IP, port, NoofPrint, date)\n\t\t    system.db.runNamedQuery(\"Project_VECV/ITSupport/InsertNumberPunchingStatus\", {\n\t\t        \"WorkStationName\": wsName, \"SerialNumber\": serialNumber, \"BOMNumber\": Model, \"CreatedBy\": getUserID})\n\t\telse:\n\t\t    NoofPrint \u003d 1\n\t\t    Project_VECV.Printer.GetPrint.getPrintHelp(serialNumber, GearRatio, shift, IP, port, NoofPrint, date)\n\t\t\n\t\t# Success message\n\t\tmessage \u003d \"Barcode Generated successfully.\"\n\t\tstate \u003d \"info\"\n\t\tProject_VECV.PopUp.Alerts.showAlert(str(state), str(state.capitalize()), str(message), \"true\", \"Okay\", \"\", \"\", \"\", \"\", \n\t\t                                    \"closePopup\", \"closePopup\", \"closePopup\", \"\", \"\", \"\", \"\")\n\t\t\n\t\t# Reset fields\n\t\tself.getSibling(\"txtSerialNumber\").props.text \u003d \u0027\u0027\n\t\tself.getSibling(\"txtGearRatio\").props.text \u003d \u0027\u0027\n\t\tself.getSibling(\"drpStation\").props.value \u003d -1\n\t\tself.getSibling(\"DateTimeInput\").props.value \u003d None\n\t\tself.getSibling(\"txtShift\").props.text\u003d\u0027\u0027\n\t\tself.getSibling(\"txtUser\").props.text\u003d\u0027\u0027\n\t\tself.getSibling(\"txtPass\").props.text\u003d\u0027\u0027\n\t\tself.getSibling(\"txtPass\").props.enabled\u003dFalse\n\t\t#system.perspective.closePopup(\"rePrintSRWM\")\n\t\t\n\t\t\n\t\n\texcept Exception as e:\n\t    # Log the error and show an error popup\n\t    system.perspective.print(\"Error: %s\" % str(e))\n\t    message \u003d \"An error occurred: %s\" % str(e)\n\t    state \u003d \"error\"\n\t    Project_VECV.PopUp.Alerts.showAlert(str(state), str(state.capitalize()), str(message), \"true\", \"Okay\", \"\", \"\", \"\", \"\", \n\t                                        \"closePopup\", \"closePopup\", \"closePopup\", \"\", \"\", \"\", \"\")"
              },
              "scope": "G",
              "type": "script"
            }
          }
