            "onRowClick": {
              "config": {
                "script": "\t\"\"\"\n\tWritten By: Niladri Banerjee\n\tWritten Date: 05/06/2024\n\tPurpose:\t\t\t \n\t\t\tAlter Defect status value on row selection\t\n\t\"\"\"\n\ttry:\n\t\tsystem.perspective.print(self.props.selection.selectedColumn)\n\t\tsystem.perspective.print(\"action value returns: %s -\u003d\u003e\"%checkdata)\n\t\tsystem.perspective.print(\"CheckData: %s -\u003d\u003e\"%checkdata)\n\t\tcheckdata\u003dself.props.data[self.props.selection.selectedRow][\u0027Action\u0027]\n\t\tif checkdata\u003d\u003d0 and str(self.props.selection.selectedColumn)\u003d\u003d\"Action\":\n\t\t\tself.props.data[self.props.selection.selectedRow][\u0027Action\u0027]\u003d1\n\t\tif checkdata\u003d\u003d1 and str(self.props.selection.selectedColumn)\u003d\u003d\"Action\":\n\t\t\tself.props.data[self.props.selection.selectedRow][\u0027Action\u0027]\u003d0\n\texcept:\t\n\t\t#start of except block\t\t\n\t\tscreenName \u003d\u0027Defect Screen\u0027 \n\t\tfilePath\u003dstr(\u0027Project_VECV/Quality/Defect\u0027)\n\t\terrorFunction \u003d str(\u0027Event:onRowClick - Defect\u0027)\n\t\terrorType\u003dstr(\u0027Application\u0027)\n\t\terrorCode \u003d str(Project_VECV.Common.GenerateUUID.getUniqueUUID()) \n\t\tdescription\u003dstr(sys.exc_info()[1]) #error description\n\t\tlineNumber\u003dstr(sys.exc_info()[2].tb_lineno) #lineno on which error occur\t\t\t\n\t\tProject_VECV.Configuration.Common.AddLogDetails.AddErrorLogs(screenName,filePath,errorFunction,errorType,errorCode,description,lineNumber)\t\t\t"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
