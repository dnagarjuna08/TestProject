                  "component": {
                    "onActionPerformed": {
                      "config": {
                        "script": "\t\"\"\"\n\t\tWritten By: Amit Ravat\n\t\tWritten Date: 30/05/2024\n\t\tPurpose: Save defect in DB and reset all values on popup. \n\t\"\"\"\n\ttry:\n\t\tpayload \u003d {\u0027Id\u0027:self.parent.getChild(\"cntDefectType\").getChild(\"drpDefectType\").props.value,\n\t\t\u0027defectName\u0027:self.parent.getChild(\"cntDefectName\").getChild(\"txt\").props.text,\n\t\t\u0027comments\u0027:self.parent.getChild(\"cntDefectComment\").getChild(\"txtComments\").props.text}\n\t\tsystem.perspective.sendMessage(\u0027SaveOnlyDefect\u0027, payload\u003dpayload,scope\u003d\u0027page\u0027)\n\t\tsystem.perspective.sendMessage(\u0027refreshDefectForm\u0027, payload\u003dpayload,scope\u003d\u0027page\u0027)\n\texcept:\t\n\t\tscreenName \u003d\u0027QualityPopup\u0027\n\t\tfilePath\u003dstr(\u0027Project_VECV/Operator Dashboard/QualityPopUp\u0027)  \n\t\terrorFunction \u003d str(\u0027Event:onActionPerformed-\u003e TabContainer/cntColumnTakeOut/btnSave\u0027)  \n\t\terrorType\u003dstr(\u0027Application\u0027)  \n\t\terrorCode \u003d str(Project_VECV.Common.GenerateUUID.getUniqueUUID())   \n\t\tdescription\u003dstr(sys.exc_info()[1]) #error description \n\t\tlineNumber\u003dstr(sys.exc_info()[2].tb_lineno) #lineno on which error \n\t\tProject_VECV.Configuration.Common.AddLogDetails.AddErrorLogs(screenName,filePath,errorFunction,errorType,errorCode,description,lineNumber)"
                      },
                      "scope": "G",
                      "type": "script"
                    }
                  }
                },
