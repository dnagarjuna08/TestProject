{
  "custom": {},
  "params": {
    "value": false
  },
  "propConfig": {
    "params.value": {
      "paramDirection": "inout",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 50,
      "width": 50
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "ToggleSwitch"
        },
        "position": {
          "basis": "36px",
          "grow": 1
        },
        "propConfig": {
          "props.selected": {
            "binding": {
              "config": {
                "path": "view.params.value"
              },
              "type": "property"
            }
          }
        },
        "type": "ia.input.toggle-switch"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column"
    },
    "type": "ia.container.flex"
  }
}