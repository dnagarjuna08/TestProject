                  "code": "\tpyval \u003d system.dataset.toPyDataSet(value)\n\tcolor \u003d \u0027#FF0000\u0027\n\tfontcolor \u003d \u0027#FFFFFF\u0027\n\treturned_rows\u003d[]\n\tfor row in pyval:\t\n\t\trow_dict\u003d{}\n\t\tif row[\u0027Status\u0027] \u003d\u003d \u0027NOK\u0027:\n\t\t\trow_dict[\u0027Station\u0027]\u003d{\u0027value\u0027:row[\u0027Station\u0027],\u0027style\u0027:{  \"backgroundColor\": color,\"color\": fontcolor,\"fontWeight\": \"bold\"}}\n\t\t\trow_dict[\u0027Operation Name\u0027]\u003d{\u0027value\u0027:row[\u0027Operation Name\u0027],\u0027style\u0027:{  \"backgroundColor\": color,\"color\": fontcolor,\"fontWeight\": \"bold\"}}\n\t\t\trow_dict[\u0027Status\u0027]\u003d{\u0027value\u0027:row[\u0027Status\u0027],\u0027style\u0027:{  \"backgroundColor\": color,\"color\": fontcolor,\"fontWeight\": \"bold\"}}\n\t\t\trow_dict[\u0027Value\u0027]\u003d{\u0027value\u0027:row[\u0027Value\u0027],\u0027style\u0027:{  \"backgroundColor\": color,\"color\": fontcolor,\"fontWeight\": \"bold\"}}\n\t\t\trow_dict[\u0027UCL\u0027]\u003d{\u0027value\u0027:row[\u0027UCL\u0027],\u0027style\u0027:{  \"backgroundColor\": color,\"color\": fontcolor,\"fontWeight\": \"bold\"}}\n\t\t\trow_dict[\u0027LCL\u0027]\u003d{\u0027value\u0027:row[\u0027LCL\u0027],\u0027style\u0027:{  \"backgroundColor\": color,\"color\": fontcolor,\"fontWeight\": \"bold\"}}\n\t\telse:\n\t\t\trow_dict[\u0027Station\u0027]\u003drow[\u0027Station\u0027]\n\t\t\trow_dict[\u0027Operation Name\u0027]\u003drow[\u0027Operation Name\u0027]\n\t\t\trow_dict[\u0027Status\u0027]\u003drow[\u0027Status\u0027]\n\t\t\trow_dict[\u0027Value\u0027]\u003drow[\u0027Value\u0027]\n\t\t\trow_dict[\u0027UCL\u0027]\u003drow[\u0027UCL\u0027]\n\t\t\trow_dict[\u0027LCL\u0027]\u003drow[\u0027LCL\u0027]\n\t\treturned_rows.append(row_dict)\n\treturn returned_rows\n\t\t\t",
                  "type": "script"
