                        "script": "\ttry:\n\t\t\n\t\t\"\"\"\n\t\t\tWritten By: Amitkumar Ravat\n\t\t\tWritten Date: 27/03/2024\n\t\t\tPurpose:Sends data of row on which user have been clicked to the add/edit panel.\n\t\t\"\"\"\t\n\t#start of try block \n\t\tmessageType \u003d \u0027rolePanel\u0027   \n\t\theaderLabel \u003d \"Edit\"\n\t\tAction \u003d \"Update\"\n\t\tselectedRow \u003d self.props.selection.data\n\t\tfor data in\tselectedRow:\n\t\t\tRoleName \u003d data[\"Role name\"]\n\t\t\tDescription \u003d data[\"Description\"]\n\t\t\tIsActive \u003d data[\"IsActive\"]\n\t\t\tId \u003d data[\"MST_Role_Id\"]\n\t\t\tif IsActive:\n\t\t\t\tIsActive \u003d 1\n\t\t\telse:\n\t\t\t\tIsActive \u003d 0\n\t\t\t\n\t\t\tpayload \u003d {\u0027headerLabel\u0027:headerLabel,\n\t\t\t\u0027roleName\u0027:RoleName,\n\t\t\t\u0027description\u0027:Description,\n\t\t\t\u0027isActive\u0027:IsActive,\n\t\t\t\u0027Action\u0027:Action}\n\t\t\t\n\t\t# Description - Sends data of row on which user have been clicked to the add/edit panel.\n\t\tsystem.perspective.closeDock(\u0027rightp\u0027)\n\t\tsystem.perspective.openDock(\u0027rightView\u0027)\n\t\tsystem.perspective.sendMessage(messageType, payload, scope \u003d \u0027page\u0027 )\t\t\n\t\tself.session.custom.selectedRoleID \u003d Id\n\t\tsystem.perspective.sendMessage(\"isEditDisplay\",payload \u003d {\"IsVisible\":1}, scope \u003d \"page\")\n\t\tfolderName \u003d \u0027Project_VECV/Role\u0027\n\t\tcolName  \u003d \u0027Id\u0027\n\t\tsystem.perspective.sendMessage(\"deleteIsVisible\",payload \u003d {\"IsVisible\":1,\"RoleName\":RoleName,\"id\":int(Id),\"folder\":str(folderName),\"colName\":str(colName)}, scope \u003d \"page\")\t\n\t\t#End of try block\t\n\texcept: \n\t#start of except block  \n\t\tscreenName \u003d\u0027Role Configuration\u0027   \n\t\tfilePath\u003dstr(\u0027Project_VECV/Admin/Role\u0027)  \n\t\terrorFunction \u003d str(\u0027Event:onStartup -\u003e cntBody/tblRole\u0027)  \n\t\terrorType\u003dstr(\u0027Application\u00