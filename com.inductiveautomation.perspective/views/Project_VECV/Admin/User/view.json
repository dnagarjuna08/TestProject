{
  "custom": {
    "Timeout": null,
    "Timeout_SP_Seconds": ""
  },
  "events": {
    "system": {
      "onStartup": {
        "config": {
          "script": "\t\"\"\"\n\t\tWritten By: Amitkumar Ravat\n\t\tWritten Date: 12/03/2024\n\t\tPurpose:\t\t\t \n\t\t\t\tcheck whether user is authenticated if not return to login poge\n\t\"\"\"\t\n\ttry:\n\t#start of try block\n\t\t#Check if user is logged or not if not then navigate to login page\n\t\tpreviousPage \u003d self.session.custom.IsUserManagementAuthenticated\n\t\tif not previousPage:\n\t\t\tsystem.perspective.navigate(\u0027/\u0027)\n\t\telse:\n\t\t\tself.session.custom.TopViewHeader \u003d \"User Management\"\n\t\t\t#close neccessary view and open the required\n\t\t\tsystem.perspective.closeDock(\u0027rightp\u0027)\n\t\t\tsystem.perspective.openDock(\"rightView\")\n\t\t\t#refreshTable and remove selection when opening view\n\t\t\tmessageType \u003d \u0027tableRefresh\u0027    \t \t\t\t\n\t\t\tsystem.perspective.sendMessage(messageType,scope \u003d \u0027page\u0027 )\n\t#End of try block\t\t\n\texcept: \n\t#start of except block  \n\t\tscreenName \u003d\u0027User Managment\u0027   \n\t\tfilePath\u003dstr(\u0027Project_VECV/Configuration/User\u0027)  \n\t\terrorFunction \u003d str(\u0027Event:onStartup  -\u003e User\u0027)  \n\t\terrorType\u003dstr(\u0027Application\u0027)  \n\t\terrorCode \u003d str(Project_VECV.Common.GenerateUUID.getUniqueUUID())   \n\t\tdescription\u003dstr(sys.exc_info()[1]) #error description \n\t\tlineNumber\u003dstr(sys.exc_info()[2].tb_lineno) #lineno on which error \n\t\tProject_VECV.Configuration.Common.AddLogDetails.AddErrorLogs(screenName,filePath,errorFunction,errorType,errorCode,description,lineNumber) \n\t\t"
        },
        "scope": "G",
        "type": "script"
      }
    }
  },
  "params": {
    "Screenname": "User management"
  },
  "propConfig": {
    "custom.Timeout": {
      "persistent": true
    },
    "custom.Timeout_SP_Seconds": {
      "persistent": true
    },
    "params.Screenname": {
      "paramDirection": "input",
      "persistent": true
    }
  },
