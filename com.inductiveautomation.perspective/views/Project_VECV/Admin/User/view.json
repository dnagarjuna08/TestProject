            "type": "ia.display.view"
          },
          {
            "children": [
              {
                "events": {
                  "component": {
                    "onRowClick": {
                      "config": {
                        "script": "\ttry:\n\t\t\"\"\"\n\t\t\tWritten By: Amitkumar Ravat\n\t\t\tWritten Date: 27/03/2024\n\t\t\tPurpose: Add value from table to Edit panel on row selection.\n\t\t\"\"\"\t\n\t\t#get table data\n\t\tselectedRow \u003d self.props.selection.data\n\t\t\n\t\tmessageType \u003d \u0027userPanel\u0027   \n\t\theaderLabel \u003d \"Edit\"\n\t\tAction \u003d \"Update\"\n\t\tsystem.perspective.print(selectedRow)\n\t\tfor data in\tselectedRow:\n\t\t\t\n\t\t\tId \u003d data[\u0027Id\u0027]\n\t\t\tphoneNumber \u003d data[\"PhoneNumber\"]\n\t\t\tisActive \u003d data[\"IsActive\"]\n\t\t\tsystem.perspective.print(\"isActive\")\n\t\t\tsystem.perspective.print(type(isActive))\n\t\t\tif isActive:\n\t\t\t\tisActive \u003d 1\n\t\t\telse:\n\t\t\t\tisActive \u003d 0\n\t\t\tuserName \u003d data[\"UserName\"]\n\t\t\tpayload \u003d {\u0027headerLabel\u0027:headerLabel,\n\t\t\t\u0027firstName\u0027:data[\"FirstName\"],\n\t\t\t\u0027lastName\u0027:data[\"LastName\"],\n\t\t\t\u0027userName\u0027:data[\"UserName\"],\n\t\t\t\u0027eMail\u0027:data[\"Email\"],\n\t\t\t\u0027countryCode\u0027:phoneNumber.split(\" \")[0],\n\t\t\t\u0027phoneNumber\u0027:phoneNumber.split(\" \")[1],\n\t\t\t\u0027roleId\u0027:data[\"RoleId\"],\n\t\t\t\u0027password\u0027:data[\"Password\"],\n\t\t\t\u0027isActive\u0027:isActive,\n\t\t\t\u0027PasswordExpiry\u0027:str(data[\u0027PasswordExpiry\u0027]),\n\t\t\t\u0027Action\u0027:Action,}\n\t\t\n\t\tfolderName \u003d \u0027Project_VECV/User\u0027\n\t\tcolName \u003d \u0027Id\u0027\n\t\tself.session.custom.selectedUserId \u003d Id\n\t\tsystem.perspective.closeDock(\u0027rightp\u0027)\n\t\tsystem.perspective.openDock(\u0027rightView\u0027)\n\t\t#add value from table to Edit panel on row selection\n\t\tsystem.perspective.sendMessage(messageType, payload, scope \u003d \u0027page\u0027 )\n\t\t#make delete and edit button visible on row selection\n\t\tsystem.perspective.sendMessage(\"deleteIsVisible\",payload \u003d {\"IsVisible\":1,\"userName\":userName,\"id\":int(Id),\"folder\":str(folderName),\"colName\":str(colName)}, scope \u003d \"page\")\n\t\tsystem.perspective.sendMessage(\"isEditDisplay\",payload \u003d {\"IsVisible\":1}, scope \u003d \"page\")\n\texcept:\n\t\tscreenName \u003d\u0027User Managment\u0027   \n\t\tfilePath\u003dstr(\u0027Project_VECV/Admin/User\u0027)  \n\t\terrorFunction \u003d str(\u0027Event:onRowClick -\u003e cntBody/tblUser\u0027)  \n\t\terrorType\u003dstr(\u0027Application\u0027)  \n\t\terrorCode \u003d str(Project_VECV.Common.GenerateUUID.getUniqueUUID())   \n\t\tdescription\u003dstr(sys.exc_info()[1]) #error description \n\t\tlineNumber\u003dstr(sys.exc_info()[2].tb_lineno) #lineno on which error \n\t\tProject_VECV.Configuration.Common.AddLogDetails.AddErrorLogs(screenName,filePath,errorFunction,errorType,errorCode,description,lineNumber) "
                      },
                      "scope": "G",
                      "type": "script"
                    }
                  }
