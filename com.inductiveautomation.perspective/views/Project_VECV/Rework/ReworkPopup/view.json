              "dom": {
                "onClick": {
                  "config": {
                    "script": "\ttry:\n\t\tSerialNumber\u003dself.view.params.SerialNumber\n\t\tAreaId\u003dself.view.params.AreaId\n\t\tLineId\u003dself.view.params.LineId\n\t\tWorkStationId\u003dself.session.custom.CurrentWorkStationId\n\t\tTakeInWsId\u003dself.parent.parent.getChild(\"FlexContainer_5\").getChild(\"Dropdown\").props.value\n\t\tBOM\u003dself.view.params.BOM\n\t\tOrderNumber\u003dself.view.params.OrderNumber\n\t\tActionTaken\u003dself.parent.parent.getChild(\"FlexContainer_4\").getChild(\"Actiontxt\").props.text\n\t\tUserID\u003dself.session.custom.loggedInUserId\n\t\tShiftId\u003dsystem.db.runNamedQuery(\"Project_VECV/Shift/getMST_Shift_Id\",{\u0027Line\u0027:LineId})\n\t\tparams\u003d{\u0027SerialNumber\u0027:str(SerialNumber),\u0027WorkStation\u0027:int(WorkStationId),\u0027Line\u0027:int(LineId),\u0027Area\u0027:int(AreaId),\u0027Event\u0027:int(5),\n\t\t\u0027M_BOM_Id\u0027:int(BOM),\u0027Status\u0027:int(2),\u0027OrderNumber\u0027:str(OrderNumber),\u0027Shift\u0027:int(ShiftId),\u0027UserId\u0027:UserID}\n\t\tsystem.db.runNamedQuery(\"Project_VECV/Rework/insertReworkEvent\",params)\n\t\tparams1\u003d{\u0027SerialNumber\u0027:str(SerialNumber),\u0027TakeinStationId\u0027:int(TakeInWsId),\u0027LineId\u0027:int(LineId),\u0027AreaId\u0027:int(AreaId),\u0027Remarks\u0027:ActionTaken,\n\t\t\t\u0027BOM\u0027:int(BOM),\u0027ModifiedBy\u0027:UserID}\n\t\tResult1\u003dsystem.db.runNamedQuery(\"Project_VECV/Rework/updateReworkStatus\",params1)\n\t\tsystem.perspective.sendMessage(\"refreshTable\",scope\u003d\u0027page\u0027)\n\t\tsystem.perspective.closePopup(\"Reworkpopup\")\t\n\t\tstate \u003d \u0027success\u0027\n\t\tmessage \u003d \u0027Rework completed successfully !\u0027\n\t\tProject_VECV.PopUp.Alerts.showAlert(str(state), str(state.capitalize()), str(message), \"true\", \"Okay\", \"\", \"\", \"\", \"\", \"closePopup\", \"closePopup\", \"closePopup\",\"\",\"\",\"\",\"\")\t\n\texcept Exception as e:\n\t\tscreenName \u003d\u0027ErrorProofing Configuration\u0027   \n\t\tfilePath\u003dstr(\u0027Project_VECV/Pannel/ErProofPannel\u0027)  \n\t\terrorFunction \u003d str(\u0027Event:onActionPerformed -\u003e cntSave/btn_Save\u0027)  \n\t\terrorType\u003dstr(\u0027Application\u0027)  \n\t\terrorCode \u003d str(Project_VECV.Common.GenerateUUID.getUniqueUUID())   \n\t\tdescription\u003dstr(sys.exc_info()[1]) #error description \n\t\tlineNumber\u003dstr(sys.exc_info()[2].tb_lineno) #lineno on which error \n\t\tProject_VECV.Configuration.Common.AddLogDetails.AddErrorLogs(screenName,filePath,errorFunction,errorType,errorCode,description,lineNumber) \n\t#End of except block\t\n\t\tstate \u003d \u0027error\u0027\n\t\tmessage \u003d \u0027Update failed!\u0027\n\t\tProject_VECV.PopUp.Alerts.showAlert(str(state), str(state.capitalize()), str(message), \"true\", \"Okay\", \"\", \"\", \"\", \"\", \"closePopup\", \"closePopup\", \"closePopup\",\"\",\"\",\"\",\"\")\t"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
