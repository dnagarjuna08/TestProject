          "component": {
            "onRowClick": {
              "config": {
                "script": "\ttry:\n\t\tselectedRow \u003d self.props.selection.data\n\t\tfor data in\tselectedRow:\n\t\t\tSerialNumber \u003d data[\"SerialNumber\"]\n\t\t\tAreaName \u003d data[\"AreaName\"]\n\t\t\tLineName \u003d data[\"LineName\"]\n\t\t\tWorkStationName \u003d data[\"WorkStationName\"]\n\t\t\tOrderNumber \u003d data[\"OrderNumber\"]\n\t\t\tBOM\u003ddata[\"M_BOM_Id\"]\n\t\t\tAreaId\u003ddata[\"MST_Area_Id\"]\n\t\t\tLineId\u003ddata[\"MST_Line_Id\"]\n\t\t\tWorkStationId\u003ddata[\"MST_WorkStation_Id\"]\n\t\tpayload \u003d {\u0027SerialNumber\u0027:str(SerialNumber),\u0027OrderNumber\u0027:str(OrderNumber),\u0027BOM\u0027:int(BOM),\u0027AreaId\u0027:int(AreaId),\u0027AreaName\u0027:str(AreaName),\u0027LineId\u0027:int(LineId),\u0027LineName\u0027:str(LineName),\u0027WorkStationId\u0027:int(WorkStationId),\u0027WorkStationName\u0027:str(WorkStationName)}\n\t\tsystem.perspective.print(payload)\n\t\tsystem.perspective.sendMessage(\u0027ReworkStartButton\u0027, payload, scope \u003d \u0027page\u0027 )\t\n\texcept:\n\t\tscreenName \u003d\u0027Rework\u0027   \n\t\tfilePath\u003dstr(\u0027Project_VECV/Rework/Rework\u0027)  \n\t\terrorFunction \u003d str(\u0027Event:onRowClick -\u003e cntBody/table\u0027)  \n\t\terrorType\u003dstr(\u0027Application\u0027)  \n\t\terrorCode \u003d str(Project_VECV.Common.GenerateUUID.getUniqueUUID())   \n\t\tdescription\u003dstr(sys.exc_info()[1]) #error description \n\t\tlineNumber\u003dstr(sys.exc_info()[2].tb_lineno) #lineno on which error \n\t\tProject_VECV.Configuration.Common.AddLogDetails.AddErrorLogs(screenName,filePath,errorFunction,errorType,errorCode,description,lineNumber) "
              },
              "enabled": false,
              "scope": "G",
              "type": "script"
            }
          }
