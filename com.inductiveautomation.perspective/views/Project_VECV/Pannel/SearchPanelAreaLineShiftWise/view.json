                          "config": {
                            "script": "\n\t\"\"\"Created By : Niladri Banerjee\n\t\tDate : 08.05.2024\n\t\tPurpose : Passing dropdown values to Parameteres\"\"\" \n\t\t\n\n\tif self.parent.parent.parent.getChild(\"cntArea\").getChild(\"drpArea\").props.value\u003d\u003dNone:\n\t   \n\t\tself.view.params.Area\u003d-1\n\telse:\n\t\tself.view.params.Area\u003dself.parent.parent.parent.getChild(\"cntArea\").getChild(\"drpArea\").props.value\n\tif self.parent.parent.parent.getChild(\"cntLine\").getChild(\"drpLine\").props.value\u003d\u003dNone:\n\t\tself.view.params.Line\u003d-1\n\telse:\n\t\tself.view.params.Line\u003dself.parent.parent.parent.getChild(\"cntLine\").getChild(\"drpLine\").props.value\n\tif self.parent.parent.parent.getChild(\"cntShift\").getChild(\"drpShift\").props.value\u003d\u003dNone:\n\t\tself.view.params.Shift\u003d-1\n\telse:\n\t\tself.view.params.Shift\u003dself.parent.parent.parent.getChild(\"cntShift\").getChild(\"drpShift\").props.value\n\tif self.parent.parent.parent.getChild(\"cntProduct\").getChild(\"drpProduct\").props.value\u003d\u003dNone:\t\n\t\tself.view.params.ProductGroup\u003d-1\n\telse:\t\n\t\tself.view.params.ProductGroup\u003dself.parent.parent.parent.getChild(\"cntProduct\").getChild(\"drpProduct\").props.value\n\t\t\n\tsystem.perspective.print(\"self.view.params.Area\"+str(self.view.params.Area))\t\n\tsystem.perspective.print(\"Line \"+str(self.view.params.Line))\t\n\tsystem.perspective.print(\"Shift \"+str(self.view.params.Shift))\t\n\tsystem.perspective.print(\"ProductGroup \"+str(self.view.params.ProductGroup))\t\n\tself.session.custom.dsCycleTime\u003dProject_VECV.Master.CycleTime.GetCycleTime(self.view.params.Line,self.view.params.ProductGroup,self.view.params.Shift)\n\tsystem.perspective.sendMessage(\"CycleTimeTableRefresh\", scope \u003d \"page\")"
                          },
                          "scope": "G",
                          "type": "script"
                        }
                      }
