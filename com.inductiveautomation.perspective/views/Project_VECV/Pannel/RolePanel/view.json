                      "config": {
                        "script": "\ttry:\n\t\t\"\"\"\n\t\t\tWritten By: Amitkumar Ravat\n\t\t\tWritten Date: 27/04/2024\n\t\t\tPurpose: Save Add/Edit data to Table.\n\t\t\"\"\"\n\t\troleName \u003d self.parent.parent.getChild(\"cntName\").getChild(\"txt\").props.text\n\t\tdescription \u003d self.parent.parent.getChild(\"cntDesc\").getChild(\"txt\").props.text\n\t\tcreatedBy \u003d self.session.custom.loggedInUserId\n\t\tisActive \u003d self.parent.parent.getChild(\"cntIsActive\").getChild(\"drpIsActive\").props.value\n\t\tif self.parent.parent.getChild(\"cntHeader\").getChild(\"lblHeader\").props.text \u003d\u003d \u0027Add\u0027:\n\t\t\tId \u003d 0\n\t\t\tresult \u003d Project_VECV.NamedQuery.Admin.Roles.InsertRELRoleForm.InsertUpdateRolesConfiguration(roleName, description, createdBy, Id, isActive)\n\t\t\tif(result\u003d\u003d0):\n\t\t\t\tmessage \u003d str(roleName) +\" details Already Exists!\"\n\t\t\t\tstate \u003d \"warning\"\n\t\t\telif(result\u003d\u003d1):\n\t\t\t\tmessage \u003d str(roleName) +\" details Added successfully.\"\n\t\t\t\tstate \u003d \"success\"\n\t\t\t\tauditMsg\u003dmessage\n\t\telse:\n\t\t\tId \u003d self.session.custom.selectedRoleID\n\t\t\t#check data already exists or not\n\t\t\tresult \u003d Project_VECV.NamedQuery.Admin.Roles.InsertRELRoleForm.InsertUpdateRolesConfiguration(roleName, description, createdBy, Id, isActive)\n\t\t\tif(result\u003d\u003d0):\n\t\t\t\tmessage \u003d str(roleName) +\" details Already Exists!\"\n\t\t\t\tstate \u003d \"warning\"\n\t\t\telif(result\u003d\u003d1):\n\t\t\t\tmessage \u003d str(roleName) +\" details updated successfully.\"\n\t\t\t\tstate \u003d \"success\"\n\t\t\t\tauditMsg\u003dmessage\n\t\tProject_VECV.PopUp.Alerts.showAlert(str(state), str(state.capitalize()), str(message), \"true\", \"Okay\", \"\", \"\", \"\", \"\", \"closePopup\", \"closePopup\", \"closePopup\",\"\",\"\",\"\",\"\")\t\n\t\tsystem.perspective.closeDock(\u0027rightp\u0027)\n\t\tsystem.perspective.openDock(\"rightView\")\n\t\tmessageType \u003d \u0027tableRefresh\u0027    \t \t\t\t\n\t\tsystem.perspective.sendMessage(messageType,scope \u003d \u0027page\u0027)\n\t\t\n\t\t#addToAuditLogStrat\n\t\tsystem.perspective.print(auditMsg)\n\t\tcategory\u003d\u0027Adminstration\u0027\n\t\tsubCategory\u003d\u0027Role Configuration\u0027\n\t\tif(Id!\u003d0):\n\t\t\tprevDesc\u003dself.view.getChild(\"root\").custom.payload\n\t\t\t#curDesc\u003d{\"linetypecode\":LineTypeCode, \"mode\":mode, \"isActive\":isActive, \"Code\":bomId }\n\t\t\tcurDesc \u003d {\n\t\t\t\t\"roleName\":roleName,\n\t\t\t\t\"description\":description,\n\t\t\t\t\"isActive\":isActive\n\t\t\t}\n\t\t\tsystem.perspective.print(prevDesc)\n\t\t\tsystem.perspective.print(curDesc)\n\t\t\tdescription\u003dstr(auditMsg)+\"Where ID\u003d\"+str(Id)+\" With Previous Data-\u003e\"+str(prevDesc)+\" and Updated Data-\u003e\"+str(curDesc)\n\t\telse:\n\t\t\tdescription\u003dstr(auditMsg)\n\t\tcreatedBy\u003dself.session.custom.loggedInUserId\n\t\tProject_VECV.Configuration.Common.AddLogDetails.AddAuditLogs(category, subCategory, description, createdBy)\n\t\t#addAuditLogEnd\n\t\t\t\n\t#End of try block\t\n\texcept: \n\t#start of except block  \n\t\tscreenName \u003d\u0027Role Configuration\u0027   \n\t\tfilePath\u003dstr(\u0027Project_VECV/Pannel/RolePanel\u0027)  \n\t\terrorFunction \u003d str(\u0027Event:onActionPerformed -\u003e cntSave/btn_Save\u0027)  \n\t\terrorType\u003dstr(\u0027Application\u0027)  \n\t\terrorCode \u003d str(Project_VECV.Common.GenerateUUID.getUniqueUUID())   \n\t\tdescription\u003dstr(sys.exc_info()[1]) #error description \n\t\tlineNumber\u003dstr(sys.exc_info()[2].tb_lineno) #lineno on which error \n\t\tProject_VECV.Configuration.Common.AddLogDetails.AddErrorLogs(screenName,filePath,errorFunction,errorType,errorCode,description,lineNumber) \n\t#End of except block\t\t\t\n"
                      },
