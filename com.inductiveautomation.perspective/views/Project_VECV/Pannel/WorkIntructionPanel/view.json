                      "pageScope": true,
                      "script": "\t# implement your handler here\n\tload\u003dpayload.copy()\n\tsystem.perspective.print(payload)\n\tload.pop(\u0027headerLabel\u0027)\n\tload.pop(\u0027ID\u0027)\n\tload.pop(\u0027BOMID\u0027)\n\tload.pop(\u0027Action\u0027)\n\tload.pop(\u0027AreaID\u0027)\n\tload.pop(\u0027LineID\u0027)\n\tload.pop(\u0027WorkstationID\u0027)\n\tload.pop(\u0027ModelID\u0027)\n\timport json\n\tload_json \u003d json.dumps(load)\n\tself.view.getChild(\"root\").custom.payload\u003dload_json",
                      "sessionScope": false,
