                  "component": {
                    "onActionPerformed": {
                      "config": {
                        "script": "\timport re\n\ttry:\n\t\tUnitId \u003d self.view.custom.UnitId\n\t\theaderLabel \u003d self.parent.parent.getChild(\"cntHeader\").getChild(\"lblHeader\").props.text\n\t\tModelId \u003d self.parent.parent.getChild(\"cntModel\").getChild(\"drpModel\").props.value\n\t\tAreaId \u003d self.parent.parent.getChild(\"cntArea\").getChild(\"drpArea\").props.value\n\t\tLineId \u003d self.parent.parent.getChild(\"cntLine\").getChild(\"drpLine\").props.value\n\t\tWorkStationId \u003d self.parent.parent.getChild(\"cntWorkStation\").getChild(\"drpWorkStation\").props.value\n\t\tOPDefinitionId \u003d self.parent.parent.getChild(\"cntOPDefinition\").getChild(\"drpOPDefinition\").props.value\n\t\tWITypeId \u003d self.parent.parent.getChild(\"cntWIType\").getChild(\"drpWIType\").props.value\n\t\tOPCode \u003d self.parent.parent.getChild(\"cntOPCode\").getChild(\"txt\").props.text\n\t\tDesc \u003d self.parent.parent.getChild(\"cntDescription\").getChild(\"txt\").props.text\n\t\tAttributeText \u003d self.parent.parent.getChild(\"cntAttributeTxt\").getChild(\"txt\").props.text\n\t\tImagePath \u003d self.parent.parent.getChild(\"cntMAPImage\").getChild(\"imgStep\").props.source\n\t\tsystem.perspective.print(\"ImagePath\")\n\t\tsystem.perspective.print(ImagePath)\n\t\tIsActive \u003d self.parent.parent.getChild(\"cntIsActive\").getChild(\"drpIsActive\").props.value\n#\t\tsystem.perspective.print(\"Add Values:%s\"%(Header,UnitName,UnitDesc,UnitLevel,AttachedTo,IsActive,WorkStationType,IPaddress))\n\t\tCurrentUserId\u003dself.session.custom.loggedInUserId\n\t\tnext \u003d 0\n\t\tif(AreaId !\u003d -1 and LineId !\u003d -1 and ModelId !\u003d -1 and WorkStationId !\u003d -1 and OPDefinitionId!\u003d-1 and WITypeId!\u003d-1 and OPCode!\u003d1):\n\t\t\n\t\t\tparams \u003d {\"Name\":str(refName),\u0027OPCodeId\u0027:UnitId}\n\t\t\tcntStep \u003d system.db.runNamedQuery(\"Project_VECV/Master/OPCodeConfiguration/GetCount_ByName\",params)\n\t\t\t\n\t\t\tparams \u003d {\"OPCode\":OPCode}\n\t\t\tcntWI \u003d system.db.runNamedQuery(\"Project_VECV/Master/OPCodeConfiguration/Get_WICountbyOPCodeName\",params)\n\t\t\t\n\t\t\n\t\t\tif cntStep\u003e\u003d1:\n\t\t\t\tnext \u003d 0\n\t\t\t\tstate \u003d \u0027Warning\u0027\n\t\t\t\tmessage \u003d \"OPCode already exist.\"\n\t\t\telif cntWI\u003e0 and headerLabel\u003d\u003d\u0027Edit\u0027 and isActive\u003d\u003d0:\n\t\t\t\tnext \u003d 0\n\t\t\t\tstate \u003d \u0027Warning\u0027\n\t\t\t\tmessage \u003d \"Can not deactivate this OPCode. It is assigned to work instruction.\"\n\t\t\telif ImagePath\u003d\u003d\"\":\n\t\t\t\tnext \u003d 0\n\t\t\t\tstate \u003d \u0027Warning\u0027\n\t\t\t\tmessage \u003d \"Please add image.\"\n\t\t\telse:\n\t\t\t\tnext \u003d 1\n\t\tif(next \u003d\u003d1):\n\t\t\tif IPaddress\u003d\u003d\u0027\u0027:\n\t\t\t\tIPaddress\u003dNone\n\t        if(str(headerLabel) \u003d\u003d \u0027Add\u0027):\n\t            if(str(UnitDesc) \u003d\u003d \u0027 \u0027):\n\t                UnitDesc \u003d \u0027\u0027\t\t\n\t\n\t            params \u003d {\"UnitName\":UnitName,\"Description\":UnitDesc,\"Level\":UnitLevel,\"AttachedTo\":AttachedTo,\"CreatedBy\":CurrentUserId,\"IPAddress\":IPaddress,\u0027WorkStationTypeId\u0027:WorkStationType}\n\t            system.perspective.print(\"Insert Values:%s\"%params)\n\t            result \u003d system.db.runNamedQuery(\"Project_VECV/Plant/Insert_Plant\",params)\t\t\n\t            if(int(result) \u003e 0):\t\t\n\t                state \u003d \u0027success\u0027\n\t                message \u003d \"Record added successfully.\"\n\t                \n\t            else:\n\t                state \u003d \u0027error\u0027\n\t                message \u003d \"Record not added. Please contact system administrator.\"\n\t        elif(str(headerLabel) \u003d\u003d \u0027Edit\u0027):\n\t            if(str(UnitDesc) \u003d\u003d \u0027 \u0027):\n\t                UnitDesc \u003d \u0027\u0027\n\t            params \u003d {\"UnitName\":UnitName,\"Description\":UnitDesc,\"UnitId\":UnitId,\"LevelId\":UnitLevel,\"AttachedTo\":AttachedTo,\"IsActive\":IsActive,\"IPAddress\":IPaddress,\"ModifiedBy\":CurrentUserId,\u0027WorkStationTypeId\u0027:WorkStationType}\n\t            system.perspective.print(\"Update Values:%s\"%params)\n\t            result \u003d system.db.runNamedQuery(\"Project_VECV/Plant/Update_Plant\",params)\t\t\n\t            if(int(result) \u003e 0):\t\t\n\t                state \u003d \u0027success\u0027\n\t                message \u003d \"Record updated successfully.\"\n\t               \n\t            else:\n\t                state \u003d \u0027error\u0027\n\t                message \u003d \"Record not updated. Please contact system administrator.\"\n        \tif(str(result) \u003e \u00270\u0027):\n\t\t\t\theaderLabel \u003d \"Add\"\n\t\t\t\tmessageType \u003d \u0027equipPanel\u0027   \t\t\t\t\n\t\t\t\tpayload \u003d {\u0027headerLabel\u0027:headerLabel,\u0027id\u0027:\u0027\u0027,\u0027name\u0027:\u0027\u0027,\u0027desc\u0027:\u0027\u0027,\u0027level\u0027:int(-1),\u0027attached\u0027:int(-1),\u0027isActive\u0027:int(1),\u0027deviceType\u0027:int(-1),\u0027ipAddress\u0027:\u0027\u0027,\u0027asset\u0027:\u0027\u0027,\u0027attachedWorkStationId\u0027:int(-1),\u0027isDualWorkStationEnabled\u0027:int(1),\u0027lineTypeId\u0027:-1,\u0027plcIndex\u0027:-1,\u0027isDualWorkStation\u0027:-1}\t\t \t\t\t\n\t\t\t\tsystem.perspective.sendMessage(messageType, payload, scope \u003d \u0027page\u0027 )\n\t\t\t\tsystem.perspective.openDock(\"rightView\")\n\t\n\t\t\t\tmessageType \u003d \u0027tableRefresh\u0027    \t \t\t\t\n\t\t\t\tsystem.perspective.sendMessage(messageType,scope \u003d \u0027page\u0027 )\n\n\t\t\t\tsystem.perspective.sendMessage(\"tableRow\",payload \u003d {\"Index\":-1}, scope \u003d \"page\")\t\n\t\t\t\tsystem.perspective.sendMessage(\"deleteIsVisible\",payload \u003d {\"IsVisible\":0}, scope \u003d \"page\")\t\n\t\t\t\tsystem.perspective.sendMessage(\"isEditDisplay\",payload \u003d {\"IsVisible\":0}, scope \u003d \"page\")\t\n\t\tProject_VECV.PopUp.Alerts.showAlert(str(state), str(state.capitalize()), str(message), \"true\", \"Okay\", \"\", \"\", \"\", \"\", \"closePopup\", \"closePopup\", \"closePopup\",\"\",\"\",\"\",\"\")\n\t\t\n\t\t\n\t\t\n\texcept:\n\t\tscreenName \u003d\u0027Plant Configuration\u0027   \n\t\tfilePath\u003dstr(\u0027Project_VECV/Pannel/PlantHierarchyPannel\u0027)  \n\t\terrorFunction \u003d str(\u0027Event:onActionPerformed -\u003e cntSave/btn_Save\u0027)  \n\t\terrorType\u003dstr(\u0027Application\u0027)  \n\t\terrorCode \u003d str(Project_VECV.Common.GenerateUUID.getUniqueUUID())   \n\t\tdescription\u003dstr(sys.exc_info()[1]) #error description \n\t\tlineNumber\u003dstr(sys.exc_info()[2].tb_lineno) #lineno on which error \n\t\tProject_VECV.Configuration.Common.AddLogDetails.AddErrorLogs(screenName,filePath,errorFunction,errorType,errorCode,description,lineNumber) \n\t#End of except block\t\t"
                      },
                      "enabled": false,
                      "scope": "G",
                      "type": "script"
                    }
                  }
                },
