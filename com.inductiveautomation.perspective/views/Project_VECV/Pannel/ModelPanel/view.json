                      "config": {
                        "script": "\t\"\"\"\n\t\tWritten By: Sagar Iparkar\n\t\tWritten Date: 20/05/2024\n\t\tPurpose: Add/Update values in db. \n\t\"\"\"\t\n\ttry:\n\t\theader\u003dself.parent.parent.getChild(\"cntHeader\").getChild(\"lblHeader\").props.text\n\t\tLineTypeCode\u003dself.parent.parent.getChild(\"cntModel\").getChild(\"drpModel\").props.value\n\t\tmode\u003dself.parent.parent.getChild(\"cntMode\").getChild(\"drpMode\").props.value\n\t\tisActive\u003dself.parent.parent.getChild(\"cntIsActive\").getChild(\"drpIsActive\").props.value\n\t\tbomId \u003d self.parent.parent.getChild(\"cntTMCode\").getChild(\"drpCode\").props.value\n\t\toptions \u003d self.parent.parent.getChild(\"cntTMCode\").getChild(\"drpCode\").props.options\n\t\tsystem.perspective.print(options)\n\t\tcode \u003d None\n\t\tfor option in options:\n\t\t    if option[\u0027value\u0027] \u003d\u003d bomId:\n\t\t        code \u003d option[\u0027label\u0027]\n\t\t        break\n\t\tcurrentUserId\u003dself.session.custom.loggedInUserId\n\t\t\n\t\tif(self.parent.parent.getChild(\"cntHeader\").getChild(\"lblHeader\").props.text\u003d\u003d\"Add\"):\n\t\t\tId\u003d0\n\t\t\tparams \u003d {\"LineTypeCode\":LineTypeCode,\"Mode\":mode,\"IsActive\":isActive,\"createdBy\":currentUserId,\"M_BOM_Id\":bomId,\"Id\":Id}\n\t\t\tqueryPath\u003d\"Project_VECV/Master/ModelConfiguration/insertUpdate\"\n\t\t\tdataset\u003dsystem.db.runNamedQuery(queryPath,params)\n\t\t\tfor data in dataset:\n\t\t\t\tresult \u003d data[\u0027Result\u0027]\n\t\t\tif(result\u003d\u003d0):\n\t\t\t\tmessage \u003d str(code) +\" Configuration Already Exists!\"\n\t\t\t\tstate \u003d \"warning\"\n\t\t\telif(result\u003d\u003d1):\n\t\t\t\tmessage \u003d str(code) +\" Configuration details added successfully.\"\n\t\t\t\tstate \u003d \"success\"\n\t\t\t\tauditMsg\u003dstr(code) +\" Configuration details added successfully.\"\n\t\telse:\n\t\t\tId\u003dself.session.custom.selectedModelConfigId\n\t\t\tparams \u003d {\"LineTypeCode\":LineTypeCode,\"Mode\":mode,\"IsActive\":isActive,\"Id\":Id,\"createdBy\":currentUserId,\"M_BOM_Id\":bomId}\n\t\t\tqueryPath\u003d\"Project_VECV/Master/ModelConfiguration/insertUpdate\"\n\t\t\tdataset\u003dsystem.db.runNamedQuery(queryPath,params)\n\t\t\tfor data in dataset:\n\t\t\t\tresult \u003d data[\u0027Result\u0027]\n\t\t\tif(result\u003d\u003d0):\n\t\t\t\tmessage \u003d str(code) +\" Configuration Already Exists!\"\n\t\t\t\tstate \u003d \"warning\"\n\t\t\telif(result\u003d\u003d1):\n\t\t\t\tmessage \u003dstr(code) +\" Configuration details updated successfully.\"\n\t\t\t\tstate \u003d \"success\"\n\t\t\t\tauditMsg\u003dstr(code) +\" Configuration details updated successfully.\"\n\t\t\t\t\n\t\tProject_VECV.PopUp.Alerts.showAlert(str(state), str(state.capitalize()), str(message), \"true\", \"Okay\", \"\", \"\", \"\", \"\", \"closePopup\", \"closePopup\", \"closePopup\",\"\",\"\",\"\",\"\")\t\n\t\t\n\t\tmessageType \u003d \u0027tableRefresh\u0027    \t \t\t\t\n\t\tsystem.perspective.sendMessage(messageType,payload\u003d{},scope \u003d \u0027page\u0027 )\n\t\t\n\t\tsystem.perspective.closeDock(\u0027rightp\u0027)\n\t\tsystem.perspective.openDock(\"rightView\")\n\t\t#addToAuditLog\n\t\tsystem.perspective.print(auditMsg)\n\t\tcategory\u003d\u0027Master Configuration\u0027\n\t\tsubCategory\u003d\u0027Model Configuration\u0027\n\t\tif(Id!\u003d0):\n\t\t\tprevDesc\u003dself.view.getChild(\"root\").custom.payload\n\t\t\t#curDesc\u003d{\"linetypecode\":LineTypeCode, \"mode\":mode, \"isActive\":isActive, \"Code\":bomId }\n\t\t\tcurDesc \u003d {\n\t\t\t\t\t\t\t\"Code\": bomId,\n\t\t\t\t\t\t    \"linetypecode\": LineTypeCode,\n\t\t\t\t\t\t    \"isActive\": isActive,\n\t\t\t\t\t\t    \"mode\": mode   \n\t\t\t\t\t\t}\n\t\t\tsystem.perspective.print(prevDesc)\n\t\t\tsystem.perspective.print(curDesc)\n\t\t\tdescription\u003dstr(auditMsg)+\"Where ID\u003d\"+str(Id)+\" With Previous Data-\u003e\"+str(prevDesc)+\" and Updated Data-\u003e\"+str(curDesc)\n\t\telse:\n\t\t\tdescription\u003dstr(auditMsg)\n\t\tcreatedBy\u003dself.session.custom.loggedInUserId\n\t\tProject_VECV.Configuration.Common.AddLogDetails.AddAuditLogs(category, subCategory, description, createdBy)\n\t\t\n\texcept:\n\t\tscreenName \u003d\u0027Model Configuration\u0027   \n\t\tfilePath\u003dstr(\u0027Project_VECV/Pannel/Master/ModelPanel\u0027)  \n\t\terrorFunction \u003d str(\u0027Event:onActionPerformed -\u003e cntSave/btn_Save\u0027)  \n\t\terrorType\u003dstr(\u0027Application\u0027)  \n\t\terrorCode \u003d str(Project_VECV.Common.GenerateUUID.getUniqueUUID())   \n\t\tdescription\u003dstr(sys.exc_info()[1]) #error description \n\t\tlineNumber\u003dstr(sys.exc_info()[2].tb_lineno) #lineno on which error \n\t\tProject_VECV.Configuration.Common.AddLogDetails.AddErrorLogs(screenName,filePath,errorFunction,errorType,errorCode,description,lineNumber) \n\t#End of except block\t"
                      },
