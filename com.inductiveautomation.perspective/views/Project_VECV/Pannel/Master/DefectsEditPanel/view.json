                  "dom": {
                    "onClick": {
                      "config": {
                        "script": "\t\n# Written By: Anand Choudhary\n# Date: 12/02/2026\n# Purpose: Edit defects in defect mapping\n\n\ttry:\n\t\tsystem.perspective.print(\"Inside try block in save\")\n\t\tpayload \u003d self.view.getChild(\"root\").custom.payload\n\t\t\n\t\tdefectCategoryId \u003d self.view.getChild(\"root\").custom.DefectCategoryId\n\t\tdefectNameId \u003d self.view.getChild(\"root\").custom.DefectNameId\n\t\tdefectSubnameId \u003d self.view.getChild(\"root\").custom.DefectSubnameId\n\t\t\n\t\tdefectSubname \u003d self.parent.parent.getChild(\"cntUnitName\").getChild(\"txt\").props.text \n\t\tdefectCategory \u003d self.parent.parent.getChild(\"cntDefectLevel1\").getChild(\"txt\").props.text\n\t\tdefectName \u003d self.parent.parent.getChild(\"cntDefectLevel2\").getChild(\"txt\").props.text\n\t\tdemerit \u003d self.parent.parent.getChild(\"cntDemerit\").getChild(\"txt\").props.text\n\t\t\n\t\tif(defectCategory !\u003d \"\" and defectName !\u003d \"\" and defectSubname !\u003d \"\" and demerit !\u003d \"\"):\n\t\t\tif payload[\u0027DefectCategory\u0027] !\u003d defectCategory:\n\t\t\t\tparam \u003d {\n\t\t\t\t \u0027DefectCategory\u0027: defectCategory,\n\t\t\t\t \u0027DefectCategoryId\u0027: defectCategoryId\n\t\t\t\t}\n\t\t\t\tsystem.db.runNamedQuery(\u0027Project_VECV/Defects/updateDefectCategory\u0027, param)\n\t\t\t\n\t\t\tif payload[\u0027DefectName\u0027] !\u003d defectName:\n\t\t\t\tparam \u003d {\n\t\t\t\t \u0027DefectName\u0027: defectName,\n\t\t\t\t \u0027DefectNameId\u0027: defectNameId\n\t\t\t\t}\n\t\t\t\tsystem.db.runNamedQuery(\u0027Project_VECV/Defects/updateDefectName\u0027, param)\n\t\n\t\t\tif (payload[\u0027DefectSubName\u0027] !\u003d defectSubname) or (payload[\u0027Demerit\u0027] !\u003d demerit):\n\t\t\t\tparam \u003d {\n\t\t\t\t \u0027DefectSubname\u0027: defectSubname,\n\t\t\t\t \u0027Demerit\u0027: demerit,\n\t\t\t\t \u0027DefectSubnameId\u0027: defectSubnameId\n\t\t\t\t}\n\t\t\t\tsystem.db.runNamedQuery(\u0027Project_VECV/Defects/updateDefectSubname\u0027, param)\n\t\t\t\tmessage \u003d \"Defect edited successfully \"\n\t\t\t\tProject_VECV.PopUp.Alerts.showAlert(\"success\", \"success\", message, \"true\", \"Okay\", \"\", \"\", \"\", \"\", \"closePopup\", \"closePopup\", \"closePopup\", \"\", \"\", \"\", \"\")\n\t\telse:\n\t\t\tmessage \u003d \"Input field can\u0027t be empty\"\n\t\t\tProject_VECV.PopUp.Alerts.showAlert(\"info\", \"Info\", message, \"true\", \"Okay\", \"\", \"\", \"\", \"\", \"closePopup\", \"closePopup\", \"closePopup\", \"\", \"\", \"\", \"\")\n\t\t\n\t\tsystem.perspective.sendMessage(\u0027refreshDefectMappingTable\u0027)\n\t\tsystem.perspective.closeDock(\"editDefectView\")\n\t\tsystem.perspective.openDock(\"rightView\")\n\texcept Exception as e:\n\t\timport traceback\n\t\tsystem.perspective.print(\"Error: \" + str(e))\n\t\tsystem.perspective.print(\"Traceback: \" + traceback.format_exc())"
                      },
                      "scope": "G",
                      "type": "script"
                    }
