                        "expression": "if(\r\n  !isNull({/root.custom.selectedLevel}),\r\n  case(\r\n    {/root.custom.selectedLevel},\r\n\r\n    // 🔹 Level 0 — Just Unit Name\r\n    0, len(trim({.../cntUnitName/txt.props.text} + \"\")) \u003e 0,\r\n\r\n    // 🔹 Level 1 — Must have Unit Name AND selectedDefectValue\r\n    1, len(trim({.../cntUnitName/txt.props.text} + \"\")) \u003e 0 \u0026\u0026\r\n       !isNull({/root.custom.selectedDefectValue} + \"\") \u0026\u0026\r\n       ({/root.custom.selectedDefectValue} + \"\") !\u003d \"\" \u0026\u0026\r\n       toInt({/root.custom.selectedDefectValue}) \u003e -1,\r\n\r\n    // 🔹 Level 2 — Must have Unit Name AND selectedDefectValue\r\n    2, len(trim({.../cntUnitName/txt.props.text} + \"\")) \u003e 0 \u0026\u0026\r\n           !isNull({/root.custom.selectedDefectValue}) \u0026\u0026\r\n           ({/root.custom.selectedDefectValue} + \"\") !\u003d \"\" \u0026\u0026\r\n           toInt({/root.custom.selectedDefectValue}) \u003e -1,\r\n\r\n    false\r\n  ),\r\n  false\r\n)\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n"
