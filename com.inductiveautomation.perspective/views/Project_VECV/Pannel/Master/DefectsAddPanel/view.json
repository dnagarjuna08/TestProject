                  "dom": {
                    "onClick": {
                      "config": {
                        "script": "\n\ttry:\n\t    level \u003d self.view.getChild(\"root\").custom.selectedLevel\n\t    selectedValue \u003d self.view.getChild(\"root\").custom.selectedDefectValue\n\t    selectedValueL2 \u003d self.view.getChild(\"root\").custom.selectedLevel2\n\t    unitName \u003d self.parent.parent.getChild(\"cntUnitName\").getChild(\"txt\").props.text.strip()\n\t    #if no demerit is selected insert none to avoid empty cell in db table\n\t    txt \u003d self.parent.parent.getChild(\"cntDemerit\").getChild(\"txt\").props.text\n\t    demerit \u003d txt.strip() if txt and txt.strip() else None\n\t    \n\t    system.perspective.print(\"Demerit %s\" %demerit)\n\t    createdBy \u003d int(self.session.custom.loggedInUserId)\n\n\t    message \u003d \"\"\n\t    auditMsg \u003d \"\"\n\t    \n\n\t    if level \u003d\u003d 0:\n\t    \tsystem.perspective.print(\"In if level \u003d\u003d 0\")\n\t        system.db.runNamedQuery(\"Project_VECV/Defects/insertDefect\", {\n\t            \"unitName\": unitName,\n\t            \"createdBy\": createdBy\n\t        })\n\t        message \u003d \"Defect added successfully.\"\n\t        auditMsg \u003d \"Defect added.\"\n\t        system.perspective.sendMessage(\u0027refreshDefectLevel1\u0027, scope\u003d\u0027page\u0027)\t        \n\n\t    elif level \u003d\u003d 1:\n\t    \tsystem.perspective.print(\"In if level \u003d\u003d 1\")\n\t        system.db.runNamedQuery(\"Project_VECV/Defects/insertDefectName\", {\n\t            \"MST_Defect_Id\": selectedValue,\n\t            \"unitName\": unitName,\n\t            \"createdBy\": createdBy\n\t        })\n\t        message \u003d \"Defect Name added successfully.\"\n\t        auditMsg \u003d \"Defect Name added.\"\n\t        system.perspective.sendMessage(\u0027refreshDefectLevel2\u0027, scope\u003d\u0027page\u0027)\n\t    elif level \u003d\u003d 2:\n\t    \tsystem.perspective.print(\"In if level \u003d\u003d 2\")\n\t        result \u003d system.db.runNamedQuery(\"Project_VECV/Defects/insertDefectSubName\", {\n\t            \"MST_DefectName_Id\": selectedValueL2,\n\t            \"unitName\": unitName,\n\t            \"Demerit\": demerit,\n\t            \"createdBy\": createdBy\n\t        })\n\t        #message \u003d \"Defect Sub Name added successfully.\"\n\t        message \u003d result\n\t        auditMsg \u003d \"Defect Sub Name added.\"\n\t        \n\t        \n\t    else:\n\t        system.perspective.print(\"Invalid Unit Level selected.\")\n\t        return  \n\n\t    system.perspective.print(\"popup\")\n\t    Project_VECV.PopUp.Alerts.showAlert(\"success\", \"Success\", message, \"true\", \"Okay\", \"\", \"\", \"\", \"\", \"closePopup\", \"closePopup\", \"closePopup\", \"\", \"\", \"\", \"\")\n\t    \n\t    self.view.getChild(\"root\").custom.selectedDefectValue\u003d\u0027\u0027\n\t    self.parent.parent.getChild(\"cntLevel\").getChild(\"drpLevel\").props.value\u003d\u0027\u0027\n\t    self.parent.parent.getChild(\"cntUnitName\").getChild(\"txt\").props.text\u003d\"\"\n\t    self.parent.parent.getChild(\"cntDemerit\").getChild(\"txt\").props.text\u003d\"\"\n\n\t    \n\t    system.perspective.print(auditMsg)\n\n\t \n\t    system.perspective.sendMessage(\"refreshDefectMappingTable\")\n\t    system.perspective.print(\"message handler called on save button of defect add panel \")\n\t    system.perspective.closeDock(\u0027rightp\u0027)\n\t    system.perspective.openDock(\u0027rightView\u0027)\n\t    \n\t    \n           \n\texcept Exception as e:\n\t    import traceback\n\t    system.perspective.print(\"Error: \" + str(e))\n\t    system.perspective.print(\"Traceback: \" + traceback.format_exc())"
                      },
                      "scope": "G",
                      "type": "script"
                    }
