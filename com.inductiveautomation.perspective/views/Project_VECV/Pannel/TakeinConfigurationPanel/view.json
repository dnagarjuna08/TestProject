                        "script": "\t\"\"\"\n\t\tWritten By: Gaurav Amrutkar\n\t\tWritten Date: 30/07/2024\n\t\tPurpose: Add/update values into db.\n\t\"\"\"\n\timport re\n\ttry:\n\t\tAreaId \u003d self.parent.parent.getChild(\"cntArea\").getChild(\"drpArea\").props.value\n\t\tLineId \u003d self.parent.parent.getChild(\"cntLine\").getChild(\"drpLine\").props.value\n\t\tWorkStationId \u003d self.parent.parent.getChild(\"cntWorkStation\").getChild(\"drpWorkStation\").props.value\n\t\tSerialNumber \u003d self.parent.parent.getChild(\"cntSerialNumber\").getChild(\"txt\").props.text\n\t\tActionTaken\u003d\u0027Take-in from Support form\u0027\n\t\tCurrentUserId\u003dself.session.custom.loggedInUserId\n\t\tBOM\u003dsystem.db.runNamedQuery(\"Project_VECV/Rework/getBOMId\",{\u0027SerialNumber\u0027:SerialNumber})\n\t\tif(AreaId !\u003d -1 and LineId !\u003d -1 and WorkStationId !\u003d -1):\n\t\t\tparams1\u003d{\u0027SerialNumber\u0027:str(SerialNumber),\u0027TakeinStationId\u0027:int(WorkStationId),\u0027LineId\u0027:int(LineId),\u0027AreaId\u0027:int(AreaId),\u0027Remarks\u0027:ActionTaken,\n\t\t\t\t\u0027BOM\u0027:int(BOM),\u0027ModifiedBy\u0027:CurrentUserId}\n\t\t\tResult\u003dsystem.db.runNamedQuery(\"Project_VECV/Rework/updateReworkStatus\",params1)\n\t\n\t\t\tstate \u003d \u0027success\u0027\n\t\t\tmessage \u003d \"Take-in Configuration updated successfully.\"  \n\t\t\tProject_VECV.PopUp.Alerts.showAlert(str(state), str(state.capitalize()), str(message), \"true\", \"Okay\", \"\", \"\", \"\", \"\", \"closePopup\", \"closePopup\", \"closePopup\",\"\",\"\",\"\",\"\")\n\t\t\tmessageType \u003d \u0027tablerefresh\u0027    \t \t\t\t\n\t\t\tsystem.perspective.sendMessage(messageType,scope \u003d \u0027page\u0027 )\t\n\t\tsystem.perspective.closeDock(\u0027rightp\u0027)\n#\t\tsystem.perspective.openDock(\"rightView\")\n\texcept:\n\t\tstate \u003d \u0027error\u0027\n\t\tmessage \u003d \"Record not updated. Please contact system administrator.\"\n\t\tProject_VECV.PopUp.Alerts.showAlert(str(state), str(state.capitalize()), str(message), \"true\", \"Okay\", \"\", \"\", \"\", \"\", \"closePopup\", \"closePopup\", \"closePopup\",\"\",\"\",\"\",\"\")\n\t\tscreenName \u003d\u0027Takein Configuration\u0027   \n\t\tfilePath\u003dstr(\u0027Project_VECV/Pannel/TakeinconfigurationPannel\u0027)  \n\t\terrorFunction \u003d str(\u0027Event:onActionPerformed -\u003e cntSave/btn_Save\u0027)  \n\t\terrorType\u003dstr(\u0027Application\u0027)  \n\t\terrorCode \u003d str(Project_VECV.Common.GenerateUUID.getUniqueUUID())   \n\t\tdescription\u003dstr(sys.exc_info()[1]) #error description \n\t\tlineNumber\u003dstr(sys.exc_info()[2].tb_lineno) #lineno on which error \n\t\tProject_VECV.Configuration.Common.AddLogDetails.AddErrorLogs(screenName,filePath,errorFunction,errorType,errorCode,description,lineNumber) \n\t#End of except block\t\t"
