                        "script": "\t\"\"\"\n\t\tWritten By: Sagar Iparkar\n\t\tWritten Date: 15/05/2024\n\t\tPurpose: Add/Update values into db. \n\t\"\"\"\n\ttry:\n\t\tself.props.enabled\u003d0\n\t\tMST_Area_Id\u003dself.parent.parent.getChild(\"cntAreaName\").getChild(\"drpAreaName\").props.value\n#\t\tMST_Line_Id\u003dself.parent.parent.getChild(\"cntLineName\").getChild(\"drpLineName\").props.value\n\t\tbomList\u003dself.parent.parent.getChild(\"cntBomName\").getChild(\"drpBOMName\").props.value\n\t\tds\u003dself.parent.parent.getChild(\"cntBomName\").getChild(\"drpBOMName\").props.options\n#\t\tds\u003dsystem.dataset.t\n#\t\tblist\u003d[]\n#\t\tfor bm in bomList:\n#\t\t\tfor i in ds:\n#\t\t\t\tif bm\u003d\u003di[0]:\n#\t\t\t\t\tblist.append(i[1])\n#\t\t\t\t\tbreak\n\t\t\t\t\n#\t\tbomList\u003dblist\n\t\tif type(bomList)!\u003dint:\n\t\t\tvalues \u003d \u0027,\u0027.join(map(str, bomList))\n\t\t\tBOM_Id \u003d values\n#\t\t\tBOM_Id \u003d \"(\"+values+\")\"\n\t\telse:\n\t\t\tBOM_Id\u003dbomList\n\t\tgroupName\u003dself.parent.parent.getChild(\"cntGroupName\").getChild(\"txtGroupName\").props.text\n\t\tgroupDesc\u003dself.parent.parent.getChild(\"cntGroupDescription\").getChild(\"txtGroupDesc\").props.text\n\t\tIsActive \u003d self.parent.parent.getChild(\"cntIsActive\").getChild(\"drpIsActive\").props.value\n\t\tgroupName\u003dstr(groupName).strip()\n\t\tgroupDesc\u003dstr(groupDesc).strip()\n\t\t\n\t\tif self.parent.parent.getChild(\"cntHeader\").getChild(\"lblHeader\").props.text \u003d\u003d \u0027Add\u0027:\n\t\t\tCreatedBy \u003d self.session.custom.loggedInUserId\n\t\t\tgroupConfigurationID\u003d0\n\t\t\tId\u003d0\n\t\n\t\t\tparams \u003d {\"MST_Area_Id\":MST_Area_Id,\"ModifiedBy\":CreatedBy,\"M_BOM_Id\":BOM_Id,\"GroupName\":groupName,\"GroupDescription\":groupDesc,\"IsActive\":IsActive,\"MST_GroupConfId\":groupConfigurationID}\n\t\t\tsystem.perspective.print(\"params \"+str(params))\n\t\t\tresult \u003d system.db.runNamedQuery(\"Project_VECV/GroupConfiguration/AddUpdateGroupConfiguration\",params)\n\t\t\t\n\t\t\tresult\u003dstr(result[0][0]).strip()\n\t\t\tif(result!\u003d\u00271\u0027):\n\t\t\t\tmessage \u003d str(result)\n\t\t\t\tstate \u003d \"warning\"\n\t\t\telif(result\u003d\u003d\u00271\u0027):\n\t\t\t\tmessage \u003d \"Group details added successfully.\"\n\t\t\t\tstate \u003d \"success\"\n\t\t\t\tauditMsg\u003dstr(groupName) + \" \" + message \n\t\telse:\n\t\t\tModifiedBy \u003d self.session.custom.loggedInUserId\n\t\t\tgroupConfigurationID \u003d self.session.custom.selectedMSTGroupConfigID\n\t\t\tId\u003dgroupConfigurationID\n\t\t\tparams \u003d {\"MST_Area_Id\":MST_Area_Id,\"ModifiedBy\":ModifiedBy,\"M_BOM_Id\":BOM_Id,\"GroupName\":groupName,\"GroupDescription\":groupDesc,\"IsActive\":IsActive,\"MST_GroupConfId\":groupConfigurationID}\n\t\t\tsystem.perspective.print(\"params \"+str(params))\t\t\t\n\t\t\tresult \u003d system.db.runNamedQuery(\"Project_VECV/GroupConfiguration/AddUpdateGroupConfiguration\",params)\n\n\t\t\tresult\u003dresult[0][0]\n\t\t\tresult\u003dstr(result)\n\t\t\tif(result!\u003d\u00271\u0027):\n\t\t\t\tmessage \u003d str(result)\n\t\t\t\tstate \u003d \"warning\"\n\t\t\telif(result\u003d\u003d\u00271\u0027):\n\t\t\t\tmessage \u003d \"Group details Updated successfully.\"\n\t\t\t\tstate \u003d \"success\"\n\t\t\t\tauditMsg\u003dstr(groupName) + \" \" + message \n\t\t\t\t\n\t\tProject_VECV.PopUp.Alerts.showAlert(str(state), str(state.capitalize()), str(message), \"true\", \"Okay\", \"\", \"\", \"\", \"\", \"closePopup\", \"closePopup\", \"closePopup\",\"\",\"\",\"\",\"\")\t\t\n\t\tif str(message).strip().lower()!\u003d\u0027Please select valid BOM\u0027.strip().lower():\t\t\n\t\t\t\t\n\t\t\tsystem.perspective.closeDock(\u0027rightp\u0027)\n\t\t\tsystem.perspective.openDock(\"rightView\")\n\t\t\tmessageType \u003d \u0027tableRefresh\u0027    \t \t\t\t\n\t\t\tsystem.perspective.sendMessage(messageType,scope \u003d \u0027page\u0027 )\n\t\t\tself.parent.parent.getChild(\"cntAreaName\").getChild(\"drpAreaName\").props.value\u003d-1\n\t#\t\tself.parent.parent.getChild(\"cntLineName\").getChild(\"drpLineName\").props.value\u003d-1\n\t\t\tself.parent.parent.getChild(\"cntBomName\").getChild(\"drpBOMName\").props.value\u003d-1\n\t\t\tself.parent.parent.getChild(\"cntGroupName\").getChild(\"txtGroupName\").props.text\u003d\u0027\u0027\n\t\t\tself.parent.parent.getChild(\"cntGroupDescription\").getChild(\"txtGroupDesc\").props.text\u003d\u0027\u0027\n\t\t\t#addToAuditLogStrat\n\t\t\tsystem.perspective.print(auditMsg)\n\t\t\tcategory\u003d\u0027Master Configuration\u0027\n\t\t\tsubCategory\u003d\u0027Group Configuration\u0027\n\t\t\tif(Id!\u003d0):\n\t\t\t\tprevDesc\u003dself.view.getChild(\"root\").custom.payload\n\t\t\t\tcurDesc \u003d {\n\t\t\t\t\t\"AreaName\":MST_Area_Id,\n\t\t\t\t\t\"GroupName\":groupName,\n\t\t\t\t\t\"GroupDesc\":groupDesc,\n\t\t\t\t\t\"IsActive\":IsActive,\n\t\t\t\t\t\"BOMName\":BOM_Id\n\t\t\t\t}\n\t\t\t\timport json\n\t\t\t\tcurDesc_json \u003d json.dumps(curDesc)\n\t\t\t\tcurDesc\u003dcurDesc_json\n\t\t\t\tsystem.perspective.print(prevDesc)\n\t\t\t\tsystem.perspective.print(curDesc)\n\t\t\t\tdescription\u003dstr(auditMsg)+\"Where ID\u003d\"+str(Id)+\" With Previous Data-\u003e\"+str(prevDesc)+\" and Updated Data-\u003e\"+str(curDesc)\n\t\t\telse:\n\t\t\t\tdescription\u003dstr(auditMsg)\n\t\t\tcreatedBy\u003dself.session.custom.loggedInUserId\n\t\t\tProject_VECV.Configuration.Common.AddLogDetails.AddAuditLogs(category, subCategory, description, createdBy)\n\t\t\t#addAuditLogEnd\n\t\t\n\texcept:\n\t\tscreenName \u003d\u0027GorupConfigurationPanel\u0027   \n\t\tfilePath\u003dstr(\u0027Project_VECV/Pannel/GroupConfiguration\u0027)  \n\t\terrorFunction \u003d str(\u0027Event:onActionPerformed  -\u003ecntSave/btn_Save\u0027)  \n\t\terrorType\u003dstr(\u0027Application\u0027)  \n\t\terrorCode \u003d str(Project_VECV.Common.GenerateUUID.getUniqueUUID())   \n\t\tdescription\u003dstr(sys.exc_info()[1]) #error description \n\t\tlineNumber\u003ds