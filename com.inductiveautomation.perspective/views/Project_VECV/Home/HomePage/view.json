{
  "custom": {
    "Timeout": null,
    "Timeout_SP_Seconds": null
  },
  "events": {
    "system": {
      "onStartup": {
        "config": {
          "script": "\t\"\"\"\n\t\tWritten By: Amitkumar Ravat\n\t\tWritten Date: 27/03/2024\n\t\tPurpose: If not logged in then navigate to login page.\t\n\t\"\"\"\n\tpreviousPage \u003d self.session.custom.IsLoggedIn\n\tif not previousPage:\n\t\tsystem.perspective.navigate(\u0027/\u0027)"
        },
        "scope": "G",
        "type": "script"
      }
    }
  },
  "params": {},
  "propConfig": {
    "custom.Timeout": {
      "binding": {
        "config": {
          "expression": "now(1000)"
        },
        "transforms": [
          {
            "code": "\tvalue\u003dself.custom.Timeout-1\n\tif value\u003c\u003d0:\n\t\tself.session.custom.previousPageUrl \u003d\u0027\u0027\n\t\tself.view.custom.Timeout \u003d self.view.custom.Timeout_SP_Seconds\t\n\t\tsystem.perspective.closePopup(\"\")\t\n\t\tsystem.perspective.navigate(\"/\")\n\treturn value",
            "type": "script"
          }
        ],
        "type": "expr"
      },
      "persistent": true
    },
    "custom.Timeout_SP_Seconds": {
      "binding": {
        "config": {
          "fallbackDelay": 2.5,
          "mode": "direct",
          "tagPath": "[default]Project_VECV/ClientTags/IdleTimeSP_Seconds"
        },
        "type": "tag"
      },
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "width": 1000
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "cntColumn"
        },
        "position": {
          "height": "100%",
          "width": "100%"
        },
        "props": {
          "breakpoints": [
            {
              "minWidth": 0,
              "name": "sm"
            },
            {
              "minWidth": 480,
              "name": "md"
            },
            {
              "minWidth": 700,
              "name": "lg"
            }
          ],
          "style": {
            "overflow": "hidden"
          }
        },
        "type": "ia.container.column"
      }
