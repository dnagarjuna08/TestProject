    "events": {
      "system": {
        "onStartup": {
          "config": {
            "script": "\t\"\"\"\n\t\tWritten By: Amitkumar Ravat\n\t\tWritten Date: 27/03/2024\n\t\tPurpose: Hide and Show Navigation Menu.\t\n\t\"\"\"\t\n\tself.session.custom.TopViewHeader \u003d \"Home\"\n\tif not self.session.custom.showMenu:\n\t\tsystem.perspective.alterDock(\u0027leftNav\u0027, { \u0027handle\u0027: \u0027hide\u0027})\n\t\tsystem.perspective.closeDock(\"leftNav\")\n\telse:\n\t\tsystem.perspective.alterDock(\u0027leftNav\u0027, { \u0027handle\u0027: \u0027show\u0027})\n\t\tsystem.perspective.openDock(\"leftNav\")"
          },
          "scope": "G",
          "type": "script"
        }
      }
    },
