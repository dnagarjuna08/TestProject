{
  "custom": {},
  "events": {
    "system": {
      "onStartup": {
        "config": {
          "script": "\t\"\"\"\n\t\tWritten By: Sagar Iparkar\n\t\tWritten Date: 27/05/2024\n\t\tPurpose: Check user authenticated or not, if not then navigate to login oage. \n\t\"\"\"\n\ttry:\n\t#start of try block\n\t\tpreviousPage \u003d self.session.custom.IsLoggedIn\n\t\tif not previousPage:\n\t\t\tsystem.perspective.navigate(\u0027/\u0027)\n\t\telse:\n\t\t\tself.session.custom.TopViewHeader \u003d \"Washing Machine\"\n\t\t\tif self.session.custom.showSingleView:\n\t\t\t\tsystem.perspective.alterDock(\u0027Nav\u0027, {\u0027handle\u0027:\u0027hide\u0027})\n\t\t\t\tsystem.perspective.closeDock(\u0027Nav\u0027)\n\n\t#End of try block\n\texcept: \n\t#start of except block  \n\t\tscreenName \u003d\u0027WashingMachine\u0027   \n\t\tfilePath\u003dstr(\u0027Project_VECV/Order/WashingMachine\u0027)  \n\t\terrorFunction \u003d str(\u0027Event:onStartup  -\u003e WashingMachine\u0027)  \n\t\terrorType\u003dstr(\u0027Application\u0027)  \n\t\terrorCode \u003d str(Project_VECV.Common.GenerateUUID.getUniqueUUID())   \n\t\tdescription\u003dstr(sys.exc_info()[1]) #error description \n\t\tlineNumber\u003dstr(sys.exc_info()[2].tb_lineno) #lineno on which error \n\t\tProject_VECV.Configuration.Common.AddLogDetails.AddErrorLogs(screenName,filePath,errorFunction,errorType,errorCode,description,lineNumber) \n\t\t\t"
        },
        "scope": "G",
        "type": "script"
      }
    }
  },
  "params": {},
  "props": {},
  "root": {
    "children": [
      {
        "children": [
          {
            "custom": {
              "selectedRow": {},
              "selectedRowIndex": ""
            },
            "events": {
              "component": {
                "onRowClick": {
                  "config": {
                    "script": "\t\"\"\"\n\t\tWritten By: Sagar Iparkar\n\t\tWritten Date: 27/05/2024\n\t\tPurpose: Show up and down arrows for Released orders\n\t\"\"\"\n\tselectedRow \u003d self.props.selection.data\n\tself.custom.selectedRowIndex \u003d self.props.selection.selectedRow\n\tfor data in\tselectedRow:\n\t\tif data[\u0027Status\u0027] \u003d\u003d \u0027Released\u0027:\n\t\t\tself.parent.parent.getChild(\"cntAction\").getChild(\"imgUp\").meta.visible \u003d True\n\t\t\tself.parent.parent.getChild(\"cntAction\").getChild(\"imgDown\").meta.visible \u003d True\n\t\t\tself.custom.selectedRow \u003d selectedRow\n\t\telse:\n\t\t\tself.parent.parent.getChild(\"cntAction\").getChild(\"imgUp\").meta.visible \u003d False\n\t\t\tself.parent.parent.getChild(\"cntAction\").getChild(\"imgDown\").meta.visible \u003d False\n"
                  },
                  "enabled": false,
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "tblOrder"
            },
            "position": {
              "breakpoints": [
                {
                  "colIndex": 0,
                  "name": "sm",
                  "order": 0,
                  "rowIndex": 0,
                  "span": 12
                },
                {
                  "colIndex": 0,
                  "name": "md",
                  "order": 1,
                  "rowIndex": 0,
                  "span": 12
                },
                {
                  "colIndex": 0,
                  "name": "lg",
                  "order": 0,
                  "rowIndex": 0,
                  "span": 12
                }
              ],
              "height": 500
            },
            "propConfig": {
              "props.data": {
                "binding": {
                  "config": {
                    "path": "session.custom.CurrentAreaId"
                  },
                  "transforms": [
                    {
                      "code": "\tvariable \u003d \u0027declare @MST_Area_Id int\u003d \u0027 + str(value) + \u0027\u0027\u0027begin\n\t\n\t\tDeclare @PRODUCTION_ORDER Table(\n\t\torder_number VARCHAR(200),\n\t\tserial_number NVARCHAR(200),\n\t\tM_BOMNumber VARCHAR(50),\n\t\tDescription VARCHAR(200),\n\t\tOrderStatusid INT,\n\t\tOrderStatus VARCHAR(50),\n\t\torder_category VARCHAR(255),\n\t\tm_BOM_id INT,\n\t\tMST_Area_Id INT,\n\t\tMST_Event_Id INT,\n\t\tspecial_instruction VARCHAR(255),\n\t\tid INT,\n\t\tActionT INT,\n\t\tpsn INT\n\t\t);\n\t\n\t\tINSERT INTO @PRODUCTION_ORDER\n\t\tselect PO.order_number,isnull(po.serial_number,\u0027\u0027) as serial_number,\n\t\tmb.M_BOMNumber,mb.Description,POS.OrderStatusid,POS.OrderStatus,po.order_category\n\t\t,PO.m_BOM_id,PO.MST_Area_Id,se.MST_Event_Id,\n\t\tisnull(PO.special_instruction,\u0027\u0027) as special_instruction,\n\t\tPO.id,0 as ActionT , PO.psn \n\t\tfrom PRODUCTION_ORDER PO WITH(NOLOCK)\n\t\tinner join m_bom MB WITH(NOLOCK)  on PO.m_BOM_id\u003dMB.m_BOM_id\n\t\tinner join MST_Production_OrderStatus POS WITH(NOLOCK) on POS.OrderStatusid\u003dPO.OrderStatusid\n\t\tand POS.OrderStatusid in(2,4,6)\n\t\tleft outer join TRN_Station_Events SE WITH(NOLOCK) on Se.SerialNumber\u003dpo.serial_number\n\t\n\t\twhere (se.MST_Event_Id \u003c\u003e5 or se.MST_Event_Id is null) and po.IsWashingMachineStatus \u003d 0\n\t\tand PO.MST_Area_Id\u003d@MST_Area_Id order by PO.psn\n\t\t\n\t\tif exists(select top 1 1  from @PRODUCTION_ORDER where OrderStatusid\u003d6)\n\t\tbegin\n\t\tupdate @PRODUCTION_ORDER\n\t\tset ActionT\u003d2\n\t\t where OrderStatusid\u003d6\n\t\n\t\t update @PRODUCTION_ORDER\n\t\tset ActionT\u003d0\n\t\t where OrderStatusid \u003c\u003e 6\n\t\n\t\tend\n\t\telse\n\t\tif exists(select top 1 1 from @PRODUCTION_ORDER where OrderStatusid\u003d4)\n\t\tbegin\n\t\tupdate @PRODUCTION_ORDER\n\t\tset ActionT\u003d1\n\t\t where OrderStatusid\u003d4\n\t\n\t\t update @PRODUCTION_ORDER\n\t\tset ActionT\u003d0\n\t\t where OrderStatusid \u003c\u003e 4\n\t\tEND\n\tselect * from @PRODUCTION_ORDER  \n\torder by psn\n\tEND\u0027\u0027\u0027\n\treturn system.db.runPrepQuery(variable)",
                      "type": "script"
                    }
                  ],
                  "type": "property"
                }
              }
            },
