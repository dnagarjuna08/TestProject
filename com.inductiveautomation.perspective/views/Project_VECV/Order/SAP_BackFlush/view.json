    "system": {
      "onStartup": {
        "config": {
          "script": "\ttry:\n\t#start of try block\n\t\t#Check if user is logged or not if not then navigate to login page\n\t\tpreviousPage \u003d self.session.custom.IsLoggedIn\n\t\tif not previousPage:\n\t\t\tsystem.perspective.navigate(\u0027/\u0027)\n\t\telse:\n\t\t\tsystem.perspective.print(\"New Session\")\n\t\t\t\n\t\t\n\t#End of try block\t\t\n\texcept: \n\t#start of except block  \n\t\tscreenName \u003d\u0027SAP BackFlush\u0027   \n\t\tfilePath\u003dstr(\u0027Project_VECV/Order/SAP BackFlush\u0027)  \n\t\terrorFunction \u003d str(\u0027Event:onStartup  -\u003e SAP BackFlush\u0027)  \n\t\terrorType\u003dstr(\u0027Application\u0027)  \n\t\terrorCode \u003d str(Project_VECV.Common.GenerateUUID.getUniqueUUID())   \n\t\tdescription\u003dstr(sys.exc_info()[1]) #error description \n\t\tlineNumber\u003dstr(sys.exc_info()[2].tb_lineno) #lineno on which error \n\t\tProject_VECV.Configuration.Common.AddLogDetails.AddErrorLogs(screenName,filePath,errorFunction,errorType,errorCode,description,lineNumber) \n\t\t"
        },
        "enabled": false,
        "scope": "G",
        "type": "script"
      }
    }
  },
