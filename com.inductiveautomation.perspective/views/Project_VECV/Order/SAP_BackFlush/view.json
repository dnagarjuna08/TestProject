                  "messageHandlers": [
                    {
                      "messageType": "SendBackFlush",
                      "pageScope": true,
                      "script": "\t# implement your handler here\n\t\"\"\"\n\t\tWritten By: Amitkumar Ravat\n\t\tWritten Date: 04/09/2024\n\t\tPurpose: Update BackFlush Data in Table\n\t\"\"\"\t\n\ttry:\n\t\tSAP_OutboundOrderDetail_Id \u003d self.custom.SAP_OutboundOrderDetail_Id\n\t\tModifiedBy \u003d self.session.custom.loggedInUserId\n\t\tsystem.db.runNamedQuery(\"Project_VECV/Order/SAP_BackFlush/UpdateBackFlushState\",{\"SAP_OutboundOrderDetail_Id\":SAP_OutboundOrderDetail_Id,\"ModifiedBy\":ModifiedBy})\n\t\tself.refreshBinding(\"props.data\")\n\t\tstate \u003d \u0027success\u0027\n\t\tmessage \u003d \u0027BackFlush Sent Successfully.\u0027\n\t\tProject_VECV.PopUp.Alerts.showAlert(str(state), str(state.capitalize()), str(message), \"true\", \"Okay\", \"\", \"\", \"\", \"\", \"closePopup\", \"closePopup\", \"closePopup\",\"\",\"\",\"\",\"\")\n\texcept:\n\t\tscreenName \u003d\u0027SAP BackFlush\u0027   \n\t\tfilePath\u003dstr(\u0027Project_VECV/Orders/SAP BackFlush\u0027)\n\t\terrorFunction \u003d str(\u0027Message Handler--\u003eSendBackFlush\u0027)  \n\t\terrorType\u003dstr(\u0027Application\u0027)  \n\t\terrorCode \u003d str(Project_VECV.Common.GenerateUUID.getUniqueUUID())   \n\t\tdescription\u003dstr(sys.exc_info()[1]) #error description \n\t\tlineNumber\u003dstr(sys.exc_info()[2].tb_lineno) #lineno on which error \n\t\tProject_VECV.Configuration.Common.AddLogDetails.AddErrorLogs(screenName,filePath,errorFunction,errorType,errorCode,description,lineNumber) \n\t\tsystem.perspective.print(lineNumber)\n\t\tstate \u003d \u0027error\u0027\n\t\tmessage \u003d \u0027Something went wrong.\u0027\n\t\tProject_VECV.PopUp.Alerts.showAlert(str(state), str(state.capitalize()), str(message), \"true\", \"Okay\", \"\", \"\", \"\", \"\", \"closePopup\", \"closePopup\", \"closePopup\",\"\",\"\",\"\",\"\")\n\t\n\t\t\t",
                      "sessionScope": false,
                      "viewScope": false
                    }
                  ]
                },
