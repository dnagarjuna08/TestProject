{
  "custom": {},
  "params": {
    "Id": "",
    "fieldName": "",
    "roleID": ""
  },
  "propConfig": {
    "params.Id": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.fieldName": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.roleID": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 40,
      "width": 250
    }
  },
  "root": {
    "children": [
      {
        "events": {
          "dom": {
            "onClick": {
              "config": {
                "script": "\tsystem.perspective.sendMessage(messageType\u003d\"Action\", payload\u003d{},scope\u003d\"page\")\n\timport time \n\ttime.sleep(0.1)\n\tpayload \u003d {\"userID\":self.view.params.Id}\n\tsystem.perspective.sendMessage(messageType\u003d\"usermoduleData\", payload\u003dpayload, scope\u003d\"page\")\n\tsystem.perspective.sendMessage(messageType\u003d\"userscreenData\", payload\u003dpayload, scope\u003d\"page\")"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "Label"
        },
        "position": {
          "basis": "50px",
          "grow": 1
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.fieldName"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "classes": "Project_VECV/Roles/selectionHover",
            "paddingLeft": "10px"
          }
        },
        "type": "ia.display.label"
      }
    ],
    "meta": {
      "name": "root"
    },
    "type": "ia.container.flex"
  }
}