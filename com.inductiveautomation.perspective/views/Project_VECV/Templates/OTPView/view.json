                    "script": "\t\"\"\"\n\tWritten By: Amitkuamr Ravat\n\tWritten Date: 25/08/2024\n\tPurpose:\t\t\t \n\t\t\tPerform OTP validation. \n\t\"\"\"\t\n\tif event.key \u003d\u003d \u0027Enter\u0027:\n\t\totp \u003d self.getSibling(\"TextField\").props.text\n\t\tif str(otp) \u003d\u003d \u0027\u0027:\n\t\t\tself.getSibling(\"FlexWarning\").meta.visible \u003d True\n\t\t\tself.parent.getChild(\"FlexWarning\").getChild(\"lblmessage\").props.text \u003d \"Please Enter OTP\"\n\t\telif str(otp) !\u003d str(self.session.custom.OTP):\n\t\t\tself.getSibling(\"FlexWarning\").meta.visible \u003d True\n\t\t\tself.parent.getChild(\"FlexWarning\").getChild(\"lblmessage\").props.text \u003d \"Invalid OTP\"\n\t\telse:\n\t\t\tself.getSibling(\"FlexWarning\").meta.visible \u003d False\n\t\t\tsystem.perspective.closePopup(\"#OTP\")\n\t\t\tsystem.perspective.sendMessage(\"buttonClick\",payload \u003d {}, scope \u003d \"page\")\n\t\t"
