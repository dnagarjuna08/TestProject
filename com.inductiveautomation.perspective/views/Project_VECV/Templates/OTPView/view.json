                        "script": "\t\"\"\"\n\tWritten By: AmitKumar ravat\n\tWritten Date: 25/08/2024\n\tPurpose:\t\t\t \n\t\t\tResend OTP. \n\t\"\"\"\n\tsystem.perspective.print(\"resend\")\n\tself.session.custom.OTP \u003d Project_VECV.ActiveDirectory.OTP.getOTP()\n\tbody \u003d \"\u003cHTML\u003e\u003cBODY\u003e\u003cH1\u003eMES OTP Authentication\u003c/H1\u003e\"\n\tbody +\u003d \"\u003cP\u003ePlease enter Below OTP to Complete MES Authentication.\u003c/P\u003e\u003c/br\u003e\u003cP\u003e\u003cB\u003e\"\n\tbody +\u003d str(self.session.custom.OTP)\n\tbody +\u003d \"\u003c/B\u003e\u003c/P\u003e\"\n\tbody+\u003d\"\u003c/br\u003e\u003cP\u003eIf you did not requested for this OTP, Please ignore the mail or contact support\u003c/P\u003e\u003c/BODY\u003e\u003c/HTML\u003e\"\n\t\n\trecipients \u003d [str(self.view.params.Email)]\n\tsystem.net.sendEmail(\"\",\"qdigitalization@vecvnet.com\", \"MES OTP Auth\", body, 1, recipients, smtpProfile \u003d \u0027SMTPEmail\u0027)"
