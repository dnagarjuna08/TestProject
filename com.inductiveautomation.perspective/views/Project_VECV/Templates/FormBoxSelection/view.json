{
  "custom": {},
  "params": {
    "Id": "",
    "IsSelected": false,
    "fieldName": "",
    "moduleId": ""
  },
  "propConfig": {
    "params.Id": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.IsSelected": {
      "paramDirection": "inout",
      "persistent": true
    },
    "params.fieldName": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.moduleId": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 40,
      "width": 250
    }
  },
  "root": {
    "children": [
      {
        "events": {
          "dom": {
            "onClick": {
              "config": {
                "script": "\tsystem.perspective.sendMessage(messageType\u003d\"saveButton\", payload\u003d{},scope\u003d\"page\")"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "Checkbox"
        },
        "position": {
          "basis": "250px",
          "grow": 1
        },
        "propConfig": {
          "props.selected": {
            "binding": {
              "config": {
                "bidirectional": true,
                "path": "view.params.IsSelected"
              },
              "type": "property"
            },
            "onChange": {
              "enabled": null,
              "script": "\tif self.props.selected:\n\t\tpayload \u003d {\"formID\":self.view.params.Id, \"moduleID\":self.view.params.moduleId}\n\t\tmessageType \u003d \u0027formSelection\u0027\n\t\tsystem.perspective.sendMessage(messageType, payload \u003d payload, scope \u003d \"page\")\n\telif not self.props.selected:\n\t\tpayload \u003d {\"formID\":self.view.params.Id, \"moduleID\":self.view.params.moduleId}\n\t\tmessageType \u003d \u0027formDeSelection\u0027\n\t\tsystem.perspective.sendMessage(messageType, payload \u003d payload, scope \u003d \"page\")\n\tsystem.perspective.print(\"value change for form selection and deselection\")"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.fieldName"
              },
              "type": "property"
            }
          }
        },
        "type": "ia.input.checkbox"
      }
    ],
    "meta": {
      "name": "root"
    },
    "type": "ia.container.flex"
  }
}