{
  "custom": {},
  "params": {
    "Dropdowndata": "",
    "Header": "",
    "Selected": -1
  },
  "propConfig": {
    "params.Dropdowndata": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.Header": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.Selected": {
      "paramDirection": "inout",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 68,
      "width": 253
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "Header"
        },
        "position": {
          "basis": "32px"
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "expression": "{view.params.Header}"
              },
              "type": "expr"
            }
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "Dropdown"
        },
        "position": {
          "basis": "36px"
        },
        "propConfig": {
          "props.options": {
            "binding": {
              "config": {
                "path": "view.params.Dropdowndata"
              },
              "type": "property"
            }
          },
          "props.value": {
            "onChange": {
              "enabled": null,
              "script": "\tif currentValue\u003d\u003dNone:\n\t\tself.view.params.Selected\u003d-1\n\telse:\n\t\tself.view.params.Selected\u003dcurrentValue"
            }
          }
        },
        "props": {
          "value": -1
        },
        "type": "ia.input.dropdown"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column"
    },
    "type": "ia.container.flex"
  }
}