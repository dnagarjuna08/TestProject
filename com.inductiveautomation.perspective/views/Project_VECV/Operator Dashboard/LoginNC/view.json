                  "messageHandlers": [
                    {
                      "messageType": "qualitylogin",
                      "pageScope": true,
                      "script": "\t\"\"\"\n\t\tWritten By: Amitkumar Ravat\n\t\tWritten Date: 02/06/2024\n\t\tPurpose: Accept valid users.\n\t\"\"\"\n\tqueryPath \u003d \u0027Project_VECV/Login/Authenticate\u0027\n\tuserName \u003d self.getSibling(\"txtUserName\").props.text\n\tpassword \u003d self.getSibling(\"txtPassword\").props.text\n\tqueryParams \u003d {\"userName\":userName,\"password\":password}\n\tdataset \u003d system.db.runNamedQuery(queryPath,queryParams)\n\tpyData \u003d system.dataset.toPyDataSet(dataset)\n\tfor data in pyData:\n\t\tisAuthenticate \u003d data[\u0027Result\u0027]\n\t\tself.session.custom.qualityLoginID \u003d data[\u0027ID\u0027]\n\tif isAuthenticate \u003d\u003d 1:\n\t\tsystem.perspective.closePopup(\u0027#login\u0027)\n\telse:\n\t\twarningMessage \u003d \"Invalid Credentials\"\n\t\tstate \u003d \"warning\"\n\t\tProject_VECV.PopUp.Alerts.showAlert(str(state), str(state.capitalize()), str(warningMessage), \"true\", \"Okay\", \"\", \"\", \"\", \"\", \"closePopup\", \"closePopup\", \"closePopup\",\"\",\"\",\"\",\"\")\t\n\t\t\t\t\n\t",
                      "sessionScope": false,
                      "viewScope": false
                    }
                  ]
