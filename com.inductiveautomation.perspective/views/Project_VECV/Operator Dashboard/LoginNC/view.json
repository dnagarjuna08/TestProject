                        "script": "\t# Description - Calls message handler to start authontication process\n\tif event.key \u003d\u003d \u0027Enter\u0027:\n\t\tsystem.perspective.sendMessage(\"qualitylogin\",payload \u003d {\"Index\":-1}, scope \u003d \"page\")\n\t\t"
