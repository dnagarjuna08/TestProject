            {
              "instancePosition": {},
              "instanceStyle": {
                "classes": ""
              }
            }
          ],
          "path": "Project_VECV/Operator Dashboard/subViewPartialStart",
          "useDefaultViewWidth": false
        },
        "type": "ia.display.flex-repeater"
      },
      {
        "events": {
          "dom": {
            "onClick": {
              "config": {
                "script": "\t\"\"\"\n\t\tWritten By: Amit Ravat\n\t\tWritten Date: 18/06/2024\n\t\tPurpose: Initiate Partial new start logic. \n\t\"\"\"\n\tvalues \u003d self.session.custom.selectedOPCode\n\ttagPath \u003d \u0027[default]Dewas/%s/%s/%s/CommonTags/Partial_New_Start_OP_Code\u0027%(self.session.custom.CurrentAreaName,self.session.custom.CurrentLineName,self.session.custom.CurrentWorkStation)\n\tsystem.tag.writeBlocking(tagPath, values)\n\ttagPath \u003d \u0027[default]Dewas/%s/%s/%s/CommonTags/Partial_New_Start\u0027%(self.session.custom.CurrentAreaName,self.session.custom.CurrentLineName,self.session.custom.CurrentWorkStation)\n\tsystem.tag.writeBlocking(tagPath, 1)\n\tsystem.tag.writeBlocking(\"[default]Dewas/%s/%s/%s/CommonTags/OP_Ready_ACK\"%(self.session.custom.CurrentAreaName,self.session.custom.CurrentLineName,self.session.custom.CurrentWorkStation),0)\n\tself.session.custom.selectedOPCode \u003d \u0027\u0027\n\tsystem.perspective.closePopup(\"#partialStart\")\n\tsystem.perspective.sendMessage(\u0027partialStart\u0027,scope\u003d\u0027page\u0027)"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
