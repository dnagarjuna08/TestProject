    },
    "props": {
      "direction": "column",
      "style": {
        "borderBottomLeftRadius": "5px",
        "borderBottomRightRadius": "5px",
        "borderStyle": "ridge",
        "borderTopLeftRadius": "5px",
        "borderTopRightRadius": "5px",
        "borderWidth": "2px"
      }
    },
    "scripts": {
      "customMethods": [
        {
          "name": "unselectedAllmenu",
          "params": [],
          "script": "\t# implement your method here\n\tfor menu in self.getChild(\"FlexRepeater\").props.instances:\n\t\tsystem.perspective.print(\"menu %s\"%menu)\n\t\tmenu[\u0027Selected\u0027] \u003d False"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "select_op",
          "pageScope": true,
          "script": "\t# implement your handler here\n\tself.unselectedAllmenu()\n\tinstances \u003d self.getChild(\"FlexRepeater\").props.instances\n\tOPCode \u003d payload[\u0027OPCode\u0027]\n\tfor menu in instances:\n\t\tif menu[\u0027opcode\u0027] \u003d\u003d OPCode:\n\t\t\tmenu[\u0027Selected\u0027]\u003dTrue",
          "sessionScope": false,
          "viewScope": false
        },
        {
          "messageType": "unselect_op",
          "pageScope": true,
          "script": "\t# implement your handler here\n\tself.unselectedAllmenu()",
          "sessionScope": false,
          "viewScope": false
        }
      ]
    },
    "type": "ia.container.flex"
  }
