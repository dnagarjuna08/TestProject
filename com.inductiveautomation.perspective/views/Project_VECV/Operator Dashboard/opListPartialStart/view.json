{
  "custom": {},
  "events": {
    "system": {
      "onStartup": {
        "config": {
          "script": "\t\"\"\"\n\t\tWritten By: Amit Ravat\n\t\tWritten Date: 18/06/2024\n\t\tPurpose: Form OPCode list of current operation. \n\t\"\"\"\n\tself.session.custom.selectedOPCode \u003d \u0027\u0027\n\tcurrentIndex \u003d self.params.currentIndex\n\tArea\u003dself.session.custom.CurrentAreaName\n\tLine\u003dself.session.custom.CurrentLineName\n\tWS\u003dself.session.custom.CurrentWorkStation\n\ttagPath\u003d\u0027[default]Dewas/%s/%s/%s/CommonTags/OPList\u0027%(Area,Line,WS)\n\tdata \u003d system.tag.readBlocking(tagPath)[0].value\n\topPartialStartList \u003d []\n\tsystem.perspective.print(\"data %s--\u003e\"%data)\n\tcurrentIndex \u003d self.params.currentIndex\n\tsystem.perspective.print(currentIndex)\n\tfor i in range(len(data)):\n\t\tmydata \u003d {}\n\t\tmydata[\u0027opcode\u0027] \u003d data[i][\u0027WorkInstruction\u0027].split(\u0027-\u0027)[0]\n\t\tmydata[\u0027opDefinition\u0027] \u003d data[i][\u0027WorkInstruction\u0027].split(\u0027-\u0027)[1]\n\t\tmydata[\u0027seqNo\u0027] \u003d data[i][\u0027Number\u0027].split(\u0027#\u0027)[1]\n\t\tmydata[\u0027Selected\u0027] \u003d False\n\t\tif i \u003d\u003d currentIndex:\n\t\t\tif str(data[i][\u0027Status\u0027]) \u003d\u003d \u0027\u0027:\n\t\t\t\tbreak\n\t\t\telse:\n\t\t\t\topPartialStartList.append(mydata)\n\t\t\t\tbreak\n\t\telse:\n\t\t\topPartialStartList.append(mydata)\n\tself.getChild(\"root\").getChild(\"FlexRepeater\").props.instances \u003d opPartialStartList"
        },
        "scope": "G",
        "type": "script"
      }
    }
  },
  "params": {
    "currentIndex": "",
    "selectedOPCode": ""
  },
  "propConfig": {
    "params.currentIndex": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.selectedOPCode": {
      "paramDirection": "input",
      "persistent": true
    }
  },
