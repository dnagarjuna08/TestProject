{
  "custom": {},
  "params": {
    "Selected": false,
    "opDefinition": "value",
    "opcode": "value",
    "seqNo": "value"
  },
  "propConfig": {
    "params.Selected": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.opDefinition": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.opcode": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.seqNo": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 50,
      "width": 300
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "lblSeqNo"
        },
        "position": {
          "basis": "80px"
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.seqNo"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "textAlign": "center"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "lblOpcode"
        },
        "position": {
          "basis": "70px"
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.opcode"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "textAlign": "center"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "lblOpDesc"
        },
        "position": {
          "basis": "50px",
          "grow": 1
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.opDefinition"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "textAlign": "center"
          }
        },
        "type": "ia.display.label"
      }
    ],
    "events": {
      "dom": {
        "onClick": {
          "config": {
            "script": "\tsystem.perspective.print(\"on click\")\n\tself.session.custom.selectedOPCode \u003d self.view.params.opcode\n\tsystem.perspective.print(\"self.view.params.Selected %s\"%self.view.params.Selected)\n\tif str(self.view.params.Selected).upper() \u003d\u003d \u0027False\u0027.upper():\n\t\tmessageType\u003d\u0027select_op\u0027\n\t\tsystem.perspective.sendMessage(messageType,{\u0027OPCode\u0027:self.view.params.opcode},scope\u003d\u0027page\u0027)\n\telse:\n\t\tmessageType\u003d\u0027unselect_op\u0027\n\t\tsystem.perspective.sendMessage(messageType,scope\u003d\u0027page\u0027)"
          },
          "scope": "G",
          "type": "script"
        }
      }
    },
    "meta": {
      "name": "root"
    },
    "propConfig": {
      "props.style.classes": {
        "binding": {
          "config": {
            "path": "view.params.Selected"
          },
          "transforms": [
            {
              "code": "\tif not value:\n\t\treturn \u0027Project_VECV/OperatorDashboard/HoverOpList\u0027\n\telse:\n\t\treturn \u0027Project_VECV/OperatorDashboard/ActiveOpList\u0027",
              "type": "script"
            }
          ],
          "type": "property"
        }
      }
    },
    "props": {
      "style": {
        "fontSize": "15px"
      }
    },
    "type": "ia.container.flex"
  }
}