                      "config": {
                        "script": "#\tPlant\u003d\u0027Dewas\u0027\n#\tAreaVal\u003dself.parent.parent.parent.getChild(\"cntFlex\").getChild(\"cntArea\").getChild(\"drpArea\").props.value\n#\tLineVal\u003dself.parent.parent.parent.getChild(\"cntFlex\").getChild(\"cntLine\").getChild(\"drpLine\").props.value\n#\tWorkstationVal\u003dself.parent.parent.parent.getChild(\"cntFlex\").getChild(\"cntStation\").getChild(\"drpStation\").props.value\n#\tif AreaVal!\u003d-1 and LineVal!\u003d-1 and WorkstationVal!\u003d-1:\n#\t\tAreadtset\u003dself.parent.parent.parent.getChild(\"cntFlex\").getChild(\"cntArea\").getChild(\"drpArea\").props.options\n#\t\tAreadtset1\u003dsystem.dataset.toPyDataSet(Areadtset)\n#\t\tfor i in Areadtset1:\n#\t\t\tif i[0]\u003d\u003dAreaVal:\n#\t\t\t\tArea\u003di[1]\n#\t\t\n#\t\tLinedtset\u003dself.parent.parent.parent.getChild(\"cntFlex\").getChild(\"cntLine\").getChild(\"drpLine\").props.options\n#\t\tLinedtset1\u003dsystem.dataset.toPyDataSet(Linedtset)\n#\t\tfor i in Linedtset1:\n#\t\t\tif i[0]\u003d\u003dLineVal:\n#\t\t\t\tLine\u003di[1]\n#\t\t\n#\t\tWorkstationdtset\u003dself.parent.parent.parent.getChild(\"cntFlex\").getChild(\"cntStation\").getChild(\"drpStation\").props.options\n#\t\tWorkstationdtset1\u003dsystem.dataset.toPyDataSet(Workstationdtset)\n#\t\tfor i in Workstationdtset1:\n#\t\t\tif i[0]\u003d\u003dWorkstationVal:\n#\t\t\t\tWorkstation\u003di[1]\n#\n#\t\tresults \u003d system.tag.browse(\"[default]\"+Plant+\"/\"+Area+\"/\"+Line+\"/\"+Workstation)\n#\t\ttagPath \u003d []\n#\t\tfor i in results:\n#\t\t    stringPath \u003d str(i[\u0027fullPath\u0027])\n#\t\t    tagPath.append(stringPath)\n#\t\t\n#\t\tdata \u003d []\n#\t\tdata1\u003d[]\n#\t\tfor path in tagPath:\n#\t\t\tresults1 \u003d system.tag.browse(path)\n#\t\t\tfor i in results1.getResults():\n#\t\t\t\tAllPath \u003d {}\n#\t\t\t\tstringPath1 \u003d str(i[\u0027fullPath\u0027])\n#\t\t\t\tif stringPath1\u003d\u003dpath+\"/OPList\" or stringPath1\u003d\u003dpath+\"/StationInProgress\":\n#\t\t\t\t\tpass\n#\t\t\t\telse:\n#\t\t\t\t\tAllPath[\"TagName\"] \u003d stringPath1\n#\t\t\t\t\tAllPath[\"TagValue\"] \u003d system.tag.readBlocking(stringPath1)[0].value\n#\t\t\t\t\tdata.append(AllPath)\n#\t\tself.parent.parent.parent.getChild(\"Table\").props.data\u003ddata\n#\telse:\n#\t\tself.parent.parent.parent.getChild(\"Table\").props.data\u003d{}"
