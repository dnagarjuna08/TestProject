        "propConfig": {
          "props.data": {
            "binding": {
              "config": {
                "expression": "now(250)"
              },
              "transforms": [
                {
                  "code": "\ttry:\n\t\tPlant\u003d\u0027Dewas\u0027\n\t\tAreaVal\u003dself.parent.getChild(\"cntFlex\").getChild(\"cntArea\").getChild(\"drpArea\").props.value\n\t\tLineVal\u003dself.parent.getChild(\"cntFlex\").getChild(\"cntLine\").getChild(\"drpLine\").props.value\n\t\tWorkstationVal\u003dself.parent.getChild(\"cntFlex\").getChild(\"cntStation\").getChild(\"drpStation\").props.value\n\t\tif AreaVal!\u003d-1 and LineVal!\u003d-1 and WorkstationVal!\u003d-1:\n\t\t\tAreadtset\u003dself.parent.getChild(\"cntFlex\").getChild(\"cntArea\").getChild(\"drpArea\").props.options\n\t\t\tAreadtset1\u003dsystem.dataset.toPyDataSet(Areadtset)\n\t\t\tfor i in Areadtset1:\n\t\t\t\tif i[0]\u003d\u003dAreaVal:\n\t\t\t\t\tArea\u003di[1]\n\t\t\t\n\t\t\tLinedtset\u003dself.parent.getChild(\"cntFlex\").getChild(\"cntLine\").getChild(\"drpLine\").props.options\n\t\t\tLinedtset1\u003dsystem.dataset.toPyDataSet(Linedtset)\n\t\t\tfor i in Linedtset1:\n\t\t\t\tif i[0]\u003d\u003dLineVal:\n\t\t\t\t\tLine\u003di[1]\n\t\t\t\n\t\t\tWorkstationdtset\u003dself.parent.getChild(\"cntFlex\").getChild(\"cntStation\").getChild(\"drpStation\").props.options\n\t\t\tWorkstationdtset1\u003dsystem.dataset.toPyDataSet(Workstationdtset)\n\t\t\tfor i in Workstationdtset1:\n\t\t\t\tif i[0]\u003d\u003dWorkstationVal:\n\t\t\t\t\tWorkstation\u003di[1]\n\t\n\t\t\tresults \u003d system.tag.browse(\"[default]\"+Plant+\"/\"+Area+\"/\"+Line+\"/\"+Workstation)\n\t\t\ttagPath \u003d []\n\t\t\tfor i in results:\n\t\t\t    stringPath \u003d str(i[\u0027fullPath\u0027])\n\t\t\t    tagPath.append(stringPath)\n\t\t\t\n\t\t\tdata \u003d []\n\t\t\tfor path in tagPath:\n\t\t\t\tresults1 \u003d system.tag.browse(path)\n\t\t\t\tfor i in results1.getResults():\n\t\t\t\t\tAllPath \u003d {}\n\t\t\t\t\tstringPath1 \u003d str(i[\u0027fullPath\u0027])\n\t\t\t\t\tTagName \u003d str(i[\u0027name\u0027])\n\t\t\t\t\tDatatype\u003dstr(i[\u0027dataType\u0027])\n\t\t\t\t\tSource\u003dstr(i[\u0027valueSource\u0027])\n\t\t\t\t\tif stringPath1\u003d\u003dpath+\"/OPList\" or stringPath1\u003d\u003dpath+\"/StationInProgress\":\n\t\t\t\t\t\tpass\n\t\t\t\t\telse:\n\t\t\t\t\t\tAllPath[\"TagPath\"] \u003d stringPath1.split(\u0027/\u0027)[-2]\n\t\t\t\t\t\tAllPath[\"TagName\"] \u003d TagName\n\t\t\t\t\t\tAllPath[\"TagValue\"] \u003d system.tag.readBlocking(stringPath1)[0].value\n\t\t\t\t\t\tAllPath[\"Timestamp\"] \u003d system.tag.readBlocking(stringPath1)[0].timestamp\n\t\t\t\t\t\tAllPath[\"DataType\"] \u003d Datatype\n\t\t\t\t\t\tAllPath[\"ValueSource\"] \u003d Source\n\t\t\t\t\t\tdata.append(AllPath)\n\t\t\treturn data\n\t\telse:\n\t\t\treturn {}\n\texcept:\n\t\tpass",
                  "type": "script"
                }
              ],
              "type": "expr"
            },
            "persistent": true
          }
        },
