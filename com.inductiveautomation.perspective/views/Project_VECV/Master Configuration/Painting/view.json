              "component": {
                "onRowClick": {
                  "config": {
                    "script": "\t\"\"\"\n\t\tWritten By: Sagar Iparkar\n\t\tWritten Date: 26/07/2024\n\t\tPurpose: Add/Update data on row selection. \n\t\"\"\"\n\ttry:\n\t\t#To open and close rightviews on table click\n\t\tsystem.perspective.closeDock(\u0027rightView\u0027)\n\t\tsystem.perspective.openDock(\u0027rightp\u0027)\n\t\t\n\t\t#imageTable data retrieving\n\t\tselectedRow \u003d self.props.selection.data\n\t\tmessageType \u003d \u0027PaintingConfigurationPanel\u0027  \n\t\theaderLabel \u003d \"Edit\"\n\t\tAction \u003d \"Update\"\n\t\t\n\t\tfor data in\tselectedRow:\n\t\t\tId \u003d data[\u0027MST_PaintingTypeConf_Id\u0027]\n\t\t\tisActive \u003d data[\"IsActive\"]\n\t\t\tif isActive:\n\t\t\t\tisActive \u003d 1\n\t\t\telse:\n\t\t\t\tisActive \u003d 0\n#\t\t\tname \u003d data[\"View\"]\n\t\t\tpayload \u003d {\u0027headerLabel\u0027:headerLabel,\n\t\t\t\u0027areaId\u0027:data[\"MST_Area_Id\"],\n\t\t\t\u0027categoryId\u0027:data[\"MST_PaintingType_Id\"],\n\t\t\t\u0027categoryName\u0027:data[\"Name\"],\n\t\t\t\u0027areaName\u0027:data[\"AreaName\"],\n\t\t\t\u0027imageName\u0027:data[\"ImageName\"],\n\t\t\t\u0027imagePath\u0027:data[\"View\"],\n\t\t\t\u0027stepNo\u0027:data[\"StepNo\"],\n\t\t\t\u0027isActive\u0027:isActive,\n\t\t\t\u0027Id\u0027:Id\n\t\t\t}\n\t\t#image url passed to session custom for image removal\n\t\tself.session.custom.paintingImageRemove \u003d payload[\u0027imagePath\u0027]\n\t\t\n\t\tfolderName \u003d \u0027Project_VECV/Painting\u0027\n\t\tcolName \u003d \u0027Id\u0027\n#\t\tself.session.custom.selectedImageId \u003d Id\n#\t\tself.session.custom.SelectedImageURL \u003d name\n\t\tsystem.perspective.sendMessage(messageType, payload, scope \u003d \u0027page\u0027 )\t\n\t\tsystem.perspective.sendMessage(\"deleteIsVisible\",payload \u003d {\"IsVisible\":1,\"id\":int(Id),\"folder\":str(folderName),\"colName\":str(colName)}, scope \u003d \"page\")\n\t\tsystem.perspective.sendMessage(\"isEditDisplay\",payload \u003d {\"IsVisible\":1}, scope \u003d \"page\")\n\texcept:\n\t\tscreenName \u003d\u0027Image Master Configuration\u0027   \n\t\tfilePath\u003dstr(\u0027Project_VECV/Master Configuration/ImageConfiguration\u0027)  \n\t\terrorFunction \u003d str(\u0027MessageHandler--\u003eImageMasterConfiguration\u0027)  \n\t\terrorType\u003dstr(\u0027Application\u0027)  \n\t\terrorCode \u003d str(Project_VECV.Common.GenerateUUID.getUniqueUUID())   \n\t\tdescription\u003dstr(sys.exc_info()[1]) #error description \n\t\tlineNumber\u003dstr(sys.exc_info()[2].tb_lineno) #lineno on which error \n\t\tProject_VECV.Configuration.Common.AddLogDetails.AddErrorLogs(screenName,filePath,errorFunction,errorType,errorCode,description,lineNumber) "
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
