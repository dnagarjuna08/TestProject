            "onRowClick": {
              "config": {
                "script": "\t\"\"\"\n\t\tWritten By: Gaurav Amrutkar\n\t\tWritten Date: 12/08/2024\n\t\tPurpose: Add/Update data on row selection. \n\t\"\"\"\n\ttry:\n\t\tselectedRow \u003d self.props.selection.data\n\t\tmessageType \u003d \"TakeinPanel\"\n\t\theaderLabel \u003d \"Edit\"\n\t\tAction \u003d \"Update\"\n\t\tfor data in\tselectedRow:\n\t\t\tAreaId \u003d data[\"AreaId\"]\n\t\t\tLineId \u003d data[\"LineId\"]\n\t\t\tSerialNumber \u003d data[\"Serial Number\"]\n\t\tpayload \u003d {\u0027headerLabel\u0027:str(headerLabel),\n\t\t\u0027AreaId\u0027:int(AreaId),\n\t\t\u0027LineId\u0027:int(LineId),\n\t\t\u0027SerialNumber\u0027:str(SerialNumber),\n\t\t\u0027Action\u0027:str(Action)}\t\n\t\tsystem.perspective.print(payload)\n\t\tsystem.perspective.openDock(\u0027rightp\u0027)\n\t\tsystem.perspective.sendMessage(messageType, payload, scope \u003d \u0027page\u0027 )\t\n\t\t\t\n\texcept:\n\t\tscreenName \u003d\u0027Takein Configuration\u0027   \n\t\tfilePath\u003dstr(\u0027Project_VECV/Master Configuration/Takein Configuration\u0027)  \n\t\terrorFunction \u003d str(\u0027Event:onRowClick -\u003e cntBody/table\u0027)  \n\t\terrorType\u003dstr(\u0027Application\u0027)  \n\t\terrorCode \u003d str(Project_VECV.Common.GenerateUUID.getUniqueUUID())   \n\t\tdescription\u003dstr(sys.exc_info()[1]) #error description \n\t\tlineNumber\u003dstr(sys.exc_info()[2].tb_lineno) #lineno on which error \n\t\tProject_VECV.Configuration.Common.AddLogDetails.AddErrorLogs(screenName,filePath,errorFunction,errorType,errorCode,description,lineNumber) "
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
