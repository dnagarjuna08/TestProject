{
  "custom": {
    "Timeout": null,
    "Timeout_SP_Seconds": ""
  },
  "events": {
    "system": {
      "onStartup": {
        "config": {
          "script": "\t\"\"\"\n\t\tWritten By: Gaurav Amrutkar\n\t\tWritten Date: 07/05/2024\n\t\tPurpose: If previous page not logged in then revert to login page. \n\t\"\"\"\n\ttry:\n\t#start of try block\n\t\t#Check if user is logged or not if not then navigate to login page\n\t\tpreviousPage \u003d self.session.custom.IsDefectMappingAunthenticated\n\t\tif not previousPage:\n\t\t\tsystem.perspective.print(\"New Session\")\n\t\t\tsystem.perspective.navigate(\u0027/\u0027)\n\t\telse:\n\t\t\tsystem.perspective.closeDock(\u0027rightp\u0027)\n\t\t\tsystem.perspective.openDock(\"rightView\")\n\t\t\tmessageType \u003d \u0027tableRefresh\u0027    \t \t\t\t\n\t\t\tsystem.perspective.sendMessage(messageType,scope \u003d \u0027page\u0027 )\n\t#End of try block\t\t\n\texcept: \n\t#start of except block  \n\t\tscreenName \u003d\u0027ErrorProofing Configuration\u0027   \n\t\tfilePath\u003dstr(\u0027Project_VECV/Configuration/DefectMapping\u0027)  \n\t\terrorFunction \u003d str(\u0027Event:onStartup  -\u003e DefectMapping\u0027)  \n\t\terrorType\u003dstr(\u0027Application\u0027)  \n\t\terrorCode \u003d str(Project_VECV.Common.GenerateUUID.getUniqueUUID())   \n\t\tdescription\u003dstr(sys.exc_info()[1]) #error description \n\t\tlineNumber\u003dstr(sys.exc_info()[2].tb_lineno) #lineno on which error \n\t\tProject_VECV.Configuration.Common.AddLogDetails.AddErrorLogs(screenName,filePath,errorFunction,errorType,errorCode,description,lineNumber) "
        },
        "scope": "G",
        "type": "script"
      }
    }
  },
  "params": {
    "Screenname": "Defect Mapping"
  },
  "propConfig": {
    "custom.Timeout": {
      "persistent": true
    },
    "custom.Timeout_SP_Seconds": {
      "persistent": true
    },
    "params.Screenname": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "width": 1000
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "children": [
              {
                "events": {
                  "component": {
                    "onRowClick": {
                      "config": {
                        "script": "\ttry:\n\t\tselectedRow \u003d self.props.selection.data\n\t\tsystem.perspective.print(selectedRow)\n\t\tmessageType \u003d \u0027DefectsMappingEditPanel\u0027  # Message for defect edit panel\n\t\t\n\t\tfor data in selectedRow:\n\t\t\tsystem.perspective.print(\"data \u003d %s\" % data)\n\n\t\t\tisActive \u003d data.get(\"Is Active\", 0)\n\n\t\t\tdefectCategory \u003d data.get(\"Defect\",\"\")\n\t\t\tdefectName \u003d data.get(\"Defect Name\",\"\")\n\t\t\tdefectSubName \u003d data.get(\"Defect SubName\",\"\")\n\t\t\tdemerit \u003d data.get(\"Demerit\",\"\")\n\t\t\tdefect_Id \u003d data.get(\"MST_Defect_Id\",\"\")\n\t\t\tdefectName_Id \u003d data.get(\"MST_DefectName_Id\",\"\")\n\t\t\tdefectSUBName_Id \u003d data.get(\"MST_DefectSUBName_Id\",\"\")\n\t\t\tpayload \u003d {\n\t\t\t\t\u0027DefectCategory\u0027: defectCategory,\n\t\t\t\t\u0027DefectName\u0027: defectName,\n\t\t\t\t\u0027DefectSubName\u0027: defectSubName,\n\t\t\t\t\u0027Demerit\u0027:demerit,\n\t\t\t\t\u0027Defect_Id\u0027: defect_Id,\n\t\t\t\t\u0027DefectName_Id\u0027: defectName_Id,\n\t\t\t\t\u0027DefectSUBName_Id\u0027: defectSUBName_Id,\n\t\t\t}\n\t\t\tsystem.perspective.print(payload)\n\t\tfolderName \u003d \u0027Project_VECV/Defects\u0027\n\n\t\tif defect_Id !\u003d None and defectName_Id !\u003d None and defectSUBName_Id !\u003d None:\n\t\t\tsystem.perspective.openDock(\"editDefectView\")\n\t\telse:\n\t\t\tmessage \u003d \u0027Please add defect name and subname first\u0027\n\t\t\tProject_VECV.PopUp.Alerts.showAlert(\"info\", \"Info\", message, \"true\", \"Okay\", \"\", \"\", \"\", \"\", \"closePopup\", \"closePopup\", \"closePopup\", \"\", \"\", \"\", \"\")\n\t\tsystem.perspective.sendMessage(messageType, payload, scope\u003d\u0027page\u0027)\n\t\t\n\texcept:\n\t\timport sys\n\t\tscreenName \u003d\u0027ErrorProofing Configuration\u0027\n\t\tfilePath\u003dstr(\u0027Project_VECV/Configuration/DefectMapping\u0027)  \n\t\terrorFunction \u003d \u0027MessageHandler--\u003eDefectsMappingEditPanel\u0027\n\t\terrorType \u003d \u0027Application\u0027\n\t\terrorCode \u003d str(Project_VECV.Common.GenerateUUID.getUniqueUUID())\n\t\tdescription \u003d str(sys.exc_info()[1])\n\t\tlineNumber \u003d str(sys.exc_info()[2].tb_lineno)\n\t\tProject_VECV.Configuration.Common.AddLogDetails.AddErrorLogs(\n\t\t\tscreenName, filePath, errorFunction, errorType, errorCode, description, lineNumber\n\t\t)"
                      },
                      "scope": "G",
                      "type": "script"
                    }
                  }
                },
