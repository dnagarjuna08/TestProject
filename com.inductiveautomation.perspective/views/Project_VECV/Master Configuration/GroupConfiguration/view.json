{
  "custom": {},
  "events": {
    "system": {
      "onStartup": {
        "config": {
          "script": "\t\"\"\"\n\t\tWritten By: Sagar Iparkar\n\t\tWritten Date: 15/05/2024\n\t\tPurpose: If previous page not logged in then revert to login page. \n\t\"\"\"\n\ttry:\n\t#start of try block\n\t\tpreviousPage \u003d self.session.custom.IsMaterialGroupConfigurationAuthenticated\n\t\tif not previousPage:\n\t\t\tsystem.perspective.navigate(\u0027/\u0027)\n\t\telse:\n\t\t\tself.session.custom.TopViewHeader \u003d \"Material Group Configuration\"\n\t\t\tsystem.perspective.closeDock(\u0027rightp\u0027)\n\t\t\tsystem.perspective.openDock(\"rightView\")\n\t\t\tmessageType \u003d \u0027tableRefresh\u0027    \t \t\t\t\n\t\t\tsystem.perspective.sendMessage(messageType,scope \u003d \u0027page\u0027 )\n\t#End of try block\t\t\n\texcept: \n\t#start of except block  \n\t\tscreenName \u003d\u0027Group Configuration\u0027   \n\t\tfilePath\u003dstr(\u0027Project_VECV/Master Configuration/GroupConfiguration\u0027)  \n\t\terrorFunction \u003d str(\u0027Event:onStartup  -\u003e GroupConfiguration\u0027)  \n\t\terrorType\u003dstr(\u0027Application\u0027)  \n\t\terrorCode \u003d str(Project_VECV.Common.GenerateUUID.getUniqueUUID())   \n\t\tdescription\u003dstr(sys.exc_info()[1]) #error description \n\t\tlineNumber\u003dstr(sys.exc_info()[2].tb_lineno) #lineno on which error \n\t\tProject_VECV.Configuration.Common.AddLogDetails.AddErrorLogs(screenName,filePath,errorFunction,errorType,errorCode,description,lineNumber) \n\t\t"
        },
        "scope": "G",
        "type": "script"
      }
    }
  },
  "params": {
    "Screenname": "User management"
  },
  "propConfig": {
    "params.Screenname": {
      "paramDirection": "input",
      "persistent": true
    }
  },
