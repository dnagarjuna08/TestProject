          {
            "children": [
              {
                "events": {
                  "component": {
                    "onRowClick": {
                      "config": {
                        "script": "\t\"\"\"\n\t\tWritten By: Sagar Iparkar\n\t\tWritten Date: 15/05/2024\n\t\tPurpose: Add/Update data on row selection. \n\t\"\"\"\n\ttry:\n\t\tmessageType \u003d \u0027groupPanel\u0027   \n\t\theaderLabel \u003d \"Edit\"\n\t\tAction \u003d \u0027Update\u0027\n\t\t\n\t\tselectedRow \u003d self.props.selection.data\n\t\tsystem.perspective.print(selectedRow)\n\t\tfor data in\tselectedRow:\n\t\t\tGroupName \u003d data[\u0027ModelName\u0027]\n\t\t\tGroupDescription \u003d data[\u0027Description\u0027]\n\t\t\tBOMNumber\u003d data[\u0027M_BOM_Ids\u0027]\n\n#\t\t\tBOMNumber\u003dstr(BOMNumber)\n\t\t\tif \",\" in BOMNumber:\n\t\t\t\tBOMNumber\u003d\u0027[\u0027+BOMNumber+\u0027]\u0027\n\t\t\t\timport ast\n\t\t\t\tBOMNumber\u003dast.literal_eval(BOMNumber)\t\t\t\t\n\t\t\telse:\n\t\t\t\tBOMNumber\u003dint(BOMNumber)\t\n\t\t\tIsActive \u003d data[\u0027IsActive\u0027]\n\t\t\tselectedMSTGroupConfigID \u003d data[\u0027id\u0027]\n\t\t\tif IsActive:\n\t\t\t\tIsActive \u003d 1\n\t\t\telse:\n\t\t\t\tIsActive \u003d 0\n\t\t\tAreaName \u003d data[\u0027MST_Area_Id\u0027]\n\t\t\tLineName \u003d 0\n\t\t\t\t\n\t\t\tpayload \u003d {\u0027headerLabel\u0027:headerLabel,\n\t\t\t\t\t\t\t\u0027AreaName\u0027:AreaName,\n\t\t\t\t\t\t\t\u0027LineName\u0027:LineName,\n\t\t\t\t\t\t\t\u0027BOMName\u0027:BOMNumber,\n\t\t\t\t\t\t\t\u0027GroupName\u0027:GroupName,\n\t\t\t\t\t\t\t\u0027GroupDesc\u0027:GroupDescription,\n\t\t\t\t\t\t\t\u0027IsActive\u0027:IsActive,\n\t\t\t\t\t\t\t\u0027Action\u0027:Action}\n\t\t\t\n\t\t\t\n\t\n\t\tfolderName \u003d \u0027Project_VECV/GroupConfiguration\u0027\n\t\tcolName \u003d \u0027Id\u0027\n\t\tself.session.custom.selectedMSTGroupConfigID\u003dselectedMSTGroupConfigID\n\t\tsystem.perspective.sendMessage(messageType, payload, scope \u003d \u0027page\u0027 )\t\n\t\tsystem.perspective.sendMessage(\"deleteIsVisible\",payload \u003d {\"IsVisible\":1,\"id\":int(selectedMSTGroupConfigID),\"folder\":str(folderName),\"colName\":str(colName)}, scope \u003d \"page\")\n\t\tsystem.perspective.sendMessage(\"isEditDisplay\",payload \u003d {\"IsVisible\":1}, scope \u003d \"page\")\n\t\tsystem.perspective.closeDock(\u0027rightp\u0027)\n\t\tsystem.perspective.openDock(\u0027rightView\u0027)\n\texcept:\n\t\tscreenName \u003d\u0027GroupConfiguration\u0027   \n\t\tfilePath\u003dstr(\u0027Project_VECV/Master/GroupConfiguration\u0027)  \n\t\terrorFunction \u003d str(\u0027Event:onRowClick -\u003e cntBody/cntBody/tblGroupConfiguration\u0027)   \n\t\terrorType\u003dstr(\u0027Application\u0027)  \n\t\terrorCode \u003d str(Project_VECV.Common.GenerateUUID.getUniqueUUID())\n\t\tdescription\u003dstr(sys.exc_info()[1]) #error description \n\t\tlineNumber\u003dstr(sys.exc_info()[2].tb_lineno) #lineno on which error \n\t\tProject_VECV.Configuration.Common.AddLogDetails.AddErrorLogs(screenName,filePath,errorFunction,errorType,errorCode,description,lineNumber) "
                      },
                      "scope": "G",
                      "type": "script"
                    }
                  }
