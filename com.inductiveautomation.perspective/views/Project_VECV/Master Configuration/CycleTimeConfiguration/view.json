                    {
                      "messageType": "CycleTimeTableRefresh",
                      "pageScope": true,
                      "script": "\t\"\"\"\n\t\tWritten By: Sagar Iparkar\n\t\tWritten Date: 12/05/2024\n\t\tPurpose: Refersh Table. \n\t\"\"\"\n\t# implement your handler here\n\tself.props.data\u003dself.session.custom.dsCycleTime\n\tself.refreshBinding(\"props.data\")\n\t\n#\tsystem.perspective.sendMessage(\"isEditDisplay\",payload \u003d {\"IsVisible\":0}, scope \u003d \"page\")\n\tsystem.perspective.sendMessage(\"tableRow\",payload \u003d {\"Index\":-1}, scope \u003d \"page\")\n\t\n#\tsystem.perspective.sendMessage(\"CycleTimeTableRefresh\", scope \u003d \"page\")",
                      "sessionScope": false,
                      "viewScope": false
                    },
                    {
                      "messageType": "tableRow",
                      "pageScope": true,
                      "script": "\t# implement your handler here\n\tself.props.selection.selectedRow \u003d payload[\u0027Index\u0027]",
                      "sessionScope": false,
                      "viewScope": false
                    },
                    {
                      "messageType": "UpdateCycleTime",
                      "pageScope": true,
                      "script": "\t\"\"\"\n\t\tWritten By: Sagar Iparkar\n\t\tWritten Date: 12/05/2024\n\t\tPurpose: Update cycle time for selected row. \n\t\"\"\"\n\ttry:\n\t\tno\u003dpayload[\u0027No\u0027]\n\t\tselRow\u003dpayload[\u0027SelctedRow\u0027]\n\t#\tselRow\u003d2\n\t\tselColumn\u003dpayload[\u0027columnName\u0027]\n\t\tupdateRowResultDs \u003d {selColumn:no}\n\t\tdtSet\u003dself.session.custom.dsCycleTime\n\t\tresultpyData \u003d system.dataset.updateRow(dtSet,selRow,updateRowResultDs)\t\n\t\tds\u003d system.dataset.toPyDataSet(resultpyData)\t\n\t#\tself.props.data\u003dds\n\t\tself.session.custom.dsCycleTime\u003dds\n\t\tsystem.perspective.sendMessage(\"CycleTimeTableRefresh\", scope \u003d \"page\")\n\texcept:\n\t\tscreenName \u003d\u0027CycleTimeConfiguration\u0027\n\t\tfilePath\u003dstr(\u0027Project_VECV/Master Configuration/CycleTimeConfiguration\u0027)  \n\t\terrorFunction \u003d str(\u0027Message Handler:UpdateCycleTime -\u003e cntBody/tblCycleTime\u0027)  \n\t\terrorType\u003dstr(\u0027Application\u0027) \n\t\terrorCode \u003d str(Project_VECV.Common.GenerateUUID.getUniqueUUID())\n\t\tdescription\u003dstr(sys.exc_info()[1]) #error description \n\t\tlineNumber\u003dstr(sys.exc_info()[2].tb_lineno) #lineno on which error \n\t\tProject_VECV.Configuration.Common.AddLogDetails.AddErrorLogs(screenName,filePath,errorFunction,errorType,errorCode,description,lineNumber)",
                      "sessionScope": false,
                      "viewScope": false
                    },
                    {
                      "messageType": "UpdateCycleTimeApplyAll",
                      "pageScope": true,
                      "script": "\t\"\"\"\n\t\tWritten By: Sagar Iparkar\n\t\tWritten Date: 12/05/2024\n\t\tPurpose: Update cycle time for all rows. \n\t\"\"\"\n\ttry:\n\t\tdtSet\u003dself.session.custom.dsCycleTime\n\t\tno\u003dpayload[\u0027No\u0027]\n\t\tselColumn\u003dpayload[\u0027columnName\u0027]\n\t\tSelctedRow\u003dpayload[\u0027SelctedRow\u0027]\n\t\tsystem.perspective.print(\"Inside MEssage handler\")\n\t\tno\u003ddtSet[1][\u0027CycleTime\u0027]\n\t\tsystem.perspective.print(\"no \"+str(no))\n\t\tsystem.perspective.print(\"SelctedRow \"+str(SelctedRow))\n\t\tupdateRowResultDs \u003d {selColumn:no}\n\t\tsystem.perspective.print(\"len(dtSet) \"+str(len(dtSet)))\n#\t\tno\u003ddtSet[1][\u0027CycleTime\u0027]\n\t\tfor i in range(len(dtSet)):\n\t\t\tsystem.perspective.print(\"i \u003d \"+str(i))\n\t\t\tif i \u003e 0:\t\t\t\n\t\t\t\tdtSet \u003d system.dataset.updateRow(dtSet,i,updateRowResultDs)\t\n\t\t\t\tdtSet\u003d system.dataset.toPyDataSet(dtSet)\t\n\t\tself.session.custom.dsCycleTime\u003ddtSet\n\t\tsystem.perspective.sendMessage(\"CycleTimeTableRefresh\", scope \u003d \"page\")\n\texcept:\n\t\tscreenName \u003d\u0027CycleTimeConfiguration\u0027\n\t\tfilePath\u003dstr(\u0027Project_VECV/Master Configuration/CycleTimeConfiguration\u0027)  \n\t\terrorFunction \u003d str(\u0027Message Handler:UpdateCycleTimeApplyAll -\u003e cntBody/tblCycleTime\u0027)  \n\t\terrorType\u003dstr(\u0027Application\u0027) \n\t\terrorCode \u003d str(Project_VECV.Common.GenerateUUID.getUniqueUUID())\n\t\tdescription\u003dstr(sys.exc_info()[1]) #error description \n\t\tlineNumber\u003dstr(sys.exc_info()[2].tb_lineno) #lineno on which error \n\t\tProject_VECV.Configuration.Common.AddLogDetails.AddErrorLogs(screenName,filePath,errorFunction,errorType,errorCode,description,lineNumber)",
                      "sessionScope": false,
                      "viewScope": false
                    }
