          {
            "meta": {
              "name": "LblToDate"
            },
            "position": {
              "basis": "69px"
            },
            "props": {
              "text": " To Date:"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "InpToDate"
            },
            "position": {
              "basis": "189px"
            },
            "propConfig": {
              "props.value": {
                "persistent": false
              }
            },
            "props": {
              "formattedValue": null,
              "style": {
                "classes": "rptIpDd"
              }
            },
            "type": "ia.input.date-time-input"
          },
          {
            "events": {
              "dom": {
                "onClick": {
                  "config": {
                    "script": "\tFromDate\u003dself.getSibling(\"InpFromDate\").props.value\n\tToDate\u003dself.getSibling(\"InpToDate\").props.value\n\tsystem.perspective.print(FromDate)\n\tsystem.perspective.print(ToDate)\n\tif FromDate !\u003d None and FromDate !\u003d\u0027\u0027 and  ToDate !\u003d None and ToDate !\u003d\u0027\u0027:\n\t\t\n\t\tParams\u003d{\u0027FromDate\u0027:FromDate,\u0027ToDate\u0027:ToDate}\n\t\tResult\u003dsystem.db.runNamedQuery(\"Project_VECV/Report/DriveheadConsumptionStatus\",Params)\n\t\tsystem.perspective.print(Result)\n\t\tself.parent.parent.getChild(\"Table\").props.data\n\t\tself.parent.parent.getChild(\"Table\").props.data\u003dResult\n\t\tsystem.perspective.print(\"Hellotab1\")\n\telse:\n\t\tsystem.perspective.print(\"Hello\")\n\t\t"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "BtnRetrieve"
            },
            "position": {
              "basis": "80px"
            },
            "props": {
              "text": "Retrieve"
            },
            "type": "ia.input.button"
          },
          {
            "events": {
              "dom": {
                "onClick": {
                  "config": {
                    "script": "\tself.parent.parent.getChild(\"Table\").props.data\u003d\u0027\u0027\n\tself.getSibling(\"InpFromDate\").props.value\u003d\u0027\u0027\n\tself.getSibling(\"InpToDate\").props.value\u003d\u0027\u0027"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "BtnClear"
            },
            "position": {
              "basis": "83px"
            },
            "props": {
              "text": "Clear"
            },
            "type": "ia.input.button"
          },
          {
            "events": {
              "dom": {
                "onClick": {
                  "config": {
                    "script": "\timport system\n\ttableData \u003d self.parent.parent.getChild(\"Table\").props.data\n\tif tableData:\n#\t\t# Extract headers dynamically from table columns\n#\t\tif len(tableData) \u003e 0:\n#\t\t    headers \u003d list(tableData.getColumnNames())\n#\t\telse:\n#\t\t    headers \u003d []\n#\t\t# Prepare rows of data from the table\n#\t\trows \u003d []\n#\t\tfor row in tableData:\n#\t\t    rows.append([row[col] for col in headers])\n#\t\tdataset \u003d system.dataset.toDataSet(headers, rows) \n\t\tcsvData \u003d system.dataset.toCSV(tableData, showHeaders\u003dTrue)\n\t\tfilePath \u003d system.file.getTempFile(\"DHconsumption.csv\")\n\t\tsystem.file.writeFile(filePath, csvData)\n\t\tfileName \u003d \"DHconsumption.csv\"\n\t\tcsvBytes \u003d system.file.readFileAsBytes(filePath)\n\t\tsystem.perspective.download(fileName, csvBytes)\n\t\tmessage\u003d\u0027File downloaded Successfully\u0027\n\t\tsetMessage(\"Success\",message)\t\n\telse:\n\t\tmessage\u003d\u0027Please first Retrieve data and then Download excel\u0027\n\t\tsetMessage(\"Error\",message)\t\n\n\ndef setMessage(status,message):\n\tsystem.perspective.sendMessage(\n\t    messageType\u003d\"setMessage\",\n   \t\tpayload\u003d{\n        \t\"message\": message,\n        \t\"status\": status\n    \t},\n    \tscope\u003d\"view\"  \n\t)"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
