                },
                "propConfig": {
                  "props.options": {
                    "binding": {
                      "config": {
                        "queryPath": "Project_VECV/Report/WIP/BOM_FETCHING"
                      },
                      "type": "query"
                    }
                  },
                  "props.value": {
                    "persistent": false
                  }
                },
                "props": {
                  "style": {
                    "borderBottomLeftRadius": 4,
                    "borderBottomRightRadius": 4,
                    "borderColor": "#060000",
                    "borderStyle": "solid",
                    "borderTopLeftRadius": 4,
                    "borderTopRightRadius": 4,
                    "borderWidth": "0.5px"
                  }
                },
                "type": "ia.input.dropdown"
              },
              {
                "meta": {
                  "name": "Label_1"
                },
                "position": {
                  "basis": "12px"
                },
                "type": "ia.display.label"
              },
              {
                "events": {
                  "dom": {
                    "onClick": {
                      "config": {
                        "script": "   \n    from java.util import Date\n    from java.text import SimpleDateFormat\n    \n    StartDate \u003d self.getSibling(\"fromDatePicker\").props.value\n    EndDate \u003d self.getSibling(\"toDatePicker\").props.value\n    TMCode \u003d self.getSibling(\"bomNoDD\").props.value\n    \n    if not TMCode:\n        TMCode \u003d \u0027All\u0027\n    tableComp \u003d self.parent.parent.getChild(\"TableCnt\").getChild(\"Table\")\n    msgStatus \u003d self.parent.parent.getChild(\"msgStatus\")\n    \n    # Check if StartDate and EndDate are valid\n    if StartDate and EndDate:\n        # Format the dates\n        date_format \u003d SimpleDateFormat(\u0027yyyy-MM-dd HH:mm:ss\u0027)\n        StartDate \u003d date_format.format(StartDate)\n        EndDate \u003d date_format.format(EndDate)\n    \n        if TMCode !\u003d \u0027All\u0027:\n            # Fetch data with both date range and TM code\n            data \u003d system.db.runNamedQuery(\"Project_VECV/Report/WIP/WIP_WITH_DATE_AND_TMCODE\", {\"TMCode\": TMCode, \"fromDate\": StartDate, \"toDate\": EndDate})\n            if not data:\n                message \u003d \u0027No data found for the selected date range and BOM number.\u0027\n                msgStatus.props.text\u003d message\n                setMessage(\"Success\", message)\n            else:\n                tableComp.props.data \u003d data\n                message \u003d \u0027Data filtered successfully for Date and BOM Number\u0027\n                msgStatus.props.text\u003d message\n                setMessage(\"Success\", message)\n        else:  # TMCode is \u0027All\u0027\n            # Fetch data with just date range\n            data \u003d system.db.runNamedQuery(\"Project_VECV/Report/WIP/WIP_DATE\", {\"fromDate\": StartDate, \"toDate\": EndDate})\n            if not data:\n                message \u003d \u0027No data found for the selected date range.\u0027\n                msgStatus.props.text\u003d message\n                setMessage(\"Success\", message)\n            else:\n                tableComp.props.data \u003d data\n                message \u003d \u0027Data filtered successfully for Date\u0027\n                msgStatus.props.text\u003d message\n                setMessage(\"Success\", message)\n    else:\n        # Handle the case where dates are not provided\n        message \u003d \u0027Please select Start Date and End Date\u0027\n        msgStatus.props.text\u003d message\n        setMessage(\"Error\", message)\n    \n    # Formatting date in the resulting data\n    for row in tableComp.props.data:\n        if \u0027start_time\u0027 in row:\n            row[\u0027start_time\u0027] \u003d date_format.format(row[\u0027start_time\u0027])\n    \ndef setMessage(status, message):\n        system.perspective.sendMessage(\n            messageType\u003d\"setMessage\",\n            payload\u003d{\n                \"message\": message,\n                \"status\": status\n            },\n            scope\u003d\"view\"  \n        )"
                      },
                      "scope": "G",
                      "type": "script"
                    }
                  }
                },
                "meta": {
