                        "script": "\t\t\n\t    self.getSibling(\"fromDatePicker\").props.value\u003dNone\n\t    self.getSibling(\"toDatePicker\").props.value\u003dNone\n\t    self.getSibling(\"bomNoDD\").props.value\u003dNone\n\t    self.parent.parent.getChild(\"msgStatus\").props.text\u003d\u0027\u0027\n\t    self.parent.parent.getChild(\"TableCnt\").getChild(\"Table\").props.data\u003d\u0027\u0027\n\t    self.parent.parent.getChild(\"msgStatus\").meta.visible\u003dFalse"
                      },
                      "scope": "G",
