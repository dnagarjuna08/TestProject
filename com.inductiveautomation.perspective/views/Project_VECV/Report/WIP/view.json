                },
                "type": "ia.display.label"
              },
              {
                "events": {
                  "dom": {
                    "onClick": {
                      "config": {
                        "script": "    import system\n    \n    \n    # Get the table data from the component\n   \n    tableData \u003d self.parent.parent.getChild(\"TableCnt\").getChild(\"Table\").props.data\n    \n    if tableData:\n        # Extract headers dynamically from table columns\n        headers \u003d list(tableData.getColumnNames()) if tableData.getRowCount() \u003e 0 else []\n        \n        # Prepare rows of data from the table\n        rows \u003d []\n        for row in tableData:\n            rows.append([row[col] for col in headers])\n        \n        # Create a dataset from headers and rows\n        dataset \u003d system.dataset.toDataSet(headers, rows)\n        \n        # Convert the dataset to CSV format\n        csvData \u003d system.dataset.toCSV(dataset, showHeaders\u003dTrue)\n        \n        # Specify the file path and write CSV data to a file\n        filePath \u003d system.file.getTempFile(\"WIPReport.csv\")\n        system.file.writeFile(filePath, csvData)\n        \n        # Read the file as bytes for download\n        fileName \u003d \"WIPReport.csv\"\n        csvBytes \u003d system.file.readFileAsBytes(filePath)\n        \n        # Trigger the download in the Perspective view\n        system.perspective.download(fileName, csvBytes)\n        \n        message \u003d \u0027File downloaded successfully\u0027\n        setMessage(\"Success\",message)\n    else:\n        message \u003d \u0027Please first retrieve data and then download the file\u0027\n        setMessage(\"Error\",message)\n        \ndef setMessage(status,message):\n      \tsystem.perspective.sendMessage(\n      \t    messageType\u003d\"setMessage\",\n         \t\tpayload\u003d{\n              \t\"message\": message,\n              \t\"status\": status\n          \t},\n          \tscope\u003d\"view\"  \n      \t)  "
                      },
                      "scope": "G",
                      "type": "script"
                    }
                  }
                },
