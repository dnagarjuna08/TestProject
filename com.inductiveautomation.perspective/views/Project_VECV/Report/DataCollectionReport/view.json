                        "onChange": {
                          "enabled": null,
                          "script": "\tAreaID \u003d self.props.value\n\tAreaOptions \u003d self.props.options\n\tfor dt in AreaOptions:\n\t\tif AreaID\u003d\u003ddt[\u0027value\u0027]:\n\t\t\tself.view.params.AreaValue\u003ddt[\u0027label\u0027]\n\tif str(AreaID).upper() \u003d\u003d \u0027All\u0027.upper():\n\t\tAreaID \u003d self.props.options\n\t\tAreaIds \u003d \u0027\u0027\n\t\tfor dt in AreaID:\n\t\t\tif str(dt[\u0027value\u0027]) !\u003d \u0027All\u0027:\n\t\t\t\tAreaIds +\u003d str(dt[\u0027value\u0027]) + \u0027,\u0027\n\telse:\n\t\tAreaIds \u003d str(AreaID) + \u0027,\u0027\n\tself.view.params.Area \u003d AreaIds\n\tparams \u003d {\u0027Area\u0027:AreaIds}\n\tdataset \u003d system.db.runNamedQuery(\"Project_VECV/Panel/getSerialNumberfromArea\",params)\n\tself.parent.parent.getChild(\"cntSerialNumber\").getChild(\"drpSerial\").props.options\u003ddataset"
