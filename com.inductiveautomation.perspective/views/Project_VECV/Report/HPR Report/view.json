            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\tfrom java.util import Date\n\tfrom java.text import SimpleDateFormat\n\tfrom java.util import Date\n\tfrom java.text import SimpleDateFormat\n\t\n\ttry:\n\t    startTime \u003d self.getSibling(\"dateFrom\").props.value\n\t    endTime \u003d self.getSibling(\"dateTo\").props.value\n\t\n\t    self.parent.parent.getChild(\"flexTable\").getChild(\"Table\").props.data \u003d \u0027\u0027\n\t    area \u003d self.getSibling(\"drpArea\").props.value\n\t    line \u003d self.getSibling(\"drpLine\").props.value\n\t    station \u003d self.getSibling(\"drpStation\").props.value\n\t\n\t    system.perspective.print(\"outside area line station if\")\n\t\n\t    if (area \u003d\u003d -1 or area \u003d\u003d \u0027\u0027) or line \u003d\u003d -1 or station \u003d\u003d -1:\n\t        system.perspective.print(\"Inside area line station if\")\n\t        message \u003d \"Please select AlL Area -\u003e Line -\u003e Station\"\n\t        system.perspective.print(message)\n\t        setMessage(\"Error\", message)\n\t        system.perspective.print(\"end of IF\")\n\t    else:\n\t        if (startTime is None or startTime \u003d\u003d \u0027\u0027) or (endTime is None or endTime \u003d\u003d \u0027\u0027):\n\t            message \u003d \u0027From date and To date cannot be Empty\u0027\n\t            setMessage(\"Error\", message)\n\t            system.perspective.print(\"end of IF2\")\n\t        else:\n\t            try:\n\t                # Calculate the difference in days\n\t                diffMillis \u003d endTime.getTime() - startTime.getTime()\n\t                diffDays \u003d diffMillis / (1000 * 60 * 60 * 24)\n\t                system.perspective.print(\"diffDays %s\" % diffDays)\n\t\n\t                if diffDays \u003c 0:\n\t                    message \u003d \u0027End date cannot be greater than Start Date\u0027\n\t                    setMessage(\"Error\", message)\n\t                    system.perspective.print(\"message %s\" % message)\n\t                elif diffDays \u003e 30:\n\t                    message \u003d \u0027Date range cannot be greater than a Month\u0027\n\t                    setMessage(\"Error\", message)\n\t                    system.perspective.print(\"message %s\" % message)\n\t                else:\n\t                    try:\n\t                        # Format dates\n\t                        startTimeFormatted \u003d SimpleDateFormat(\"yyyy-MM-dd HH:mm:ss\").format(startTime)\n\t                        endTimeFormatted \u003d SimpleDateFormat(\"yyyy-MM-dd HH:mm:ss\").format(endTime)\n\t                        system.perspective.print(startTimeFormatted)\n\t                        system.perspective.print(endTimeFormatted)\n\t\n\t                        # Fetch workstation data\n\t                        WorkStation \u003d self.getSibling(\"drpStation\").props.value\n\t                        cols \u003d system.db.runNamedQuery(\n\t                            \u0027Project_VECV/Report/HPR_Report/getHPRtableData\u0027,\n\t                            {\u0027FromDate\u0027: startTimeFormatted, \u0027ToDate\u0027: endTimeFormatted, \u0027WorkStation\u0027: WorkStation}\n\t                        )\n\t                        \n\t                        # Update the table with the retrieved data\n\t                        self.parent.parent.getChild(\"flexTable\").getChild(\"Table\").props.data \u003d cols\n\t                        self.parent.parent.getChild(\"flexTable\").meta.visible \u003d True\n\t                        message \u003d \u0027HPR fetching successful\u0027\n\t                        setMessage(\"Success\", message)\n\t                    except Exception as e:\n\t                        system.perspective.print(\"Error fetching data or updating table: %s\" % str(e))\n\t                        setMessage(\"Error\", \"An error occurred while fetching data.\")\n\t            except Exception as e:\n\t                system.perspective.print(\"Error in date range calculation: %s\" % str(e))\n\t                setMessage(\"Error\", \"Invalid date range.\")\n\texcept Exception as e:\n\t    system.perspective.print(\"Unexpected error in script: %s\" % str(e))\n\t    setMessage(\"Error\", \"An unexpected error occurred.\")\n\n\ndef setMessage(status, message):\n    system.perspective.sendMessage(\n        messageType\u003d\"setMessage\",\n        payload\u003d{\n            \"message\": message,\n            \"status\": status\n        },\n        scope\u003d\"view\"\n    )"
                  },
                  "scope": "G",
                  "type": "script"
                }
