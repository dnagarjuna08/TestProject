          {
            "events": {
              "dom": {
                "onClick": {
                  "config": {
                    "script": "   try:\n       # Get the table data\n       table_data \u003d self.parent.parent.getChild(\"flexTable\").getChild(\"Table\").props.data\n       \n       # Initialize message text\n       message_text \u003d \"\"\n   \n       # Check if the table contains data\n       if table_data is not None and len(table_data) \u003e 0:\n           try:\n               # If data is available, export it to Excel and trigger download\n               excel_data \u003d system.dataset.toExcel(True, [table_data])\n               system.perspective.download(fileName\u003d\"HPR Report.xlsx\", data\u003dexcel_data)\n               message \u003d \"HPR download successful to your local system in Excel format.\"\n               setMessage(\"Success\", message)\n           except Exception as e:\n               # Handle errors during Excel export or download\n               system.perspective.print(\"Error during export or download: %s\" % str(e))\n               message \u003d \"An error occurred during export. Please try again or contact MES team\"\n               setMessage(\"Error\", message)\n       else:\n           # Handle case where no data is available\n           message \u003d \"No data available to export for given Inputs.\"\n           setMessage(\"Error\", message)\n   \n   except Exception as e:\n       # Handle unexpected errors in the overall script\n       system.perspective.print(\"Unexpected error: %s\" % str(e))\n       setMessage(\"Error\", \"An unexpected error occurred. Please Contact MES team\")\n\ndef setMessage(status, message):\n    system.perspective.sendMessage(\n        messageType\u003d\"setMessage\",\n        payload\u003d{\n            \"message\": message,\n            \"status\": status\n        },\n        scope\u003d\"view\"\n    )\n   "
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
