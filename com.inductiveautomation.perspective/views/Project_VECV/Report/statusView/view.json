{
  "custom": {},
  "params": {
    "value": ""
  },
  "propConfig": {
    "params.value": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 39,
      "width": 68
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "Label"
        },
        "position": {
          "height": 37,
          "rotate": {
            "anchor": "36% 25%"
          },
          "width": 68,
          "y": 2
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.value"
              },
              "transforms": [
                {
                  "code": "\tif value \u003d\u003d \u0027OK\u0027:\n\t\treturn value\n\telif value \u003d\u003d \u0027NOK\u0027:\n\t\treturn \u0027NOK\u0027\n\telse:\n\t\treturn \u0027\u0027",
                  "type": "script"
                }
              ],
              "type": "property"
            }
          },
          "props.textStyle.backgroundColor": {
            "binding": {
              "config": {
                "path": "this.props.text"
              },
              "transforms": [
                {
                  "code": "\tif value\u003d\u003d\u0027OK\u0027:\n\t   return \u0027green\u0027\n\telif value \u003d\u003d \u0027NOK\u0027:\n\t   return \u0027red\u0027\n\telse:\n\t\treturn \u0027\u0027\n\t",
                  "type": "script"
                }
              ],
              "type": "property"
            }
          }
        },
        "props": {
          "textStyle": {
            "color": "#FFFFFF",
            "fontSize": 20,
            "fontWeight": "bold",
            "textAlign": "center"
          }
        },
        "type": "ia.display.label"
      }
    ],
    "meta": {
      "name": "root"
    },
    "propConfig": {
      "props.style.backgroundColor": {
        "binding": {
          "config": {
            "path": "./Label.props.text"
          },
          "transforms": [
            {
              "code": "\tif value\u003d\u003d\u0027OK\u0027:\n\t  return \u0027green\u0027\n\telif value \u003d\u003d \u0027NOK\u0027:\n\t  return \u0027red\u0027\n\telse:\n\t  return \u0027\u0027",
              "type": "script"
            }
          ],
          "type": "property"
        }
      }
    },
    "type": "ia.container.coord"
  }
}