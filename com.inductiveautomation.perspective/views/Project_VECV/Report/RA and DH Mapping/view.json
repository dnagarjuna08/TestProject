                        "script": "\n\tArea \u003d self.parent.parent.getChild(\"cntArea\").getChild(\"drpArea\").props.value\n\tsystem.perspective.print(\"AreaID: %s\" %Area)\n\t\n\tBOM \u003d str(self.parent.parent.getChild(\"cntBOM\").getChild(\"drpBOM\").props.value)\n\tsystem.perspective.print(\"BOM: %s\" %BOM)\n\n\tif (Area \u003d\u003d \u0027\u0027 or Area \u003d\u003d -1):\n\t\tself.parent.parent.parent.getChild(\"msgStrip\").props.style.display \u003d \u0027block\u0027\n\t\tmessage \u003d \u0027Please Select Area..\u0027\n\t\tsetMessage(\"Error\", message)\n\telse:\n\t\ttry:\n\t\t\tsystem.perspective.print(\"Inside try\")\n\t\t\tif Area \u003d\u003d 1:\n\t\t\t\tsystem.perspective.print(\"Inside IF\")\n\t\t\t\tparam \u003d {\n\t\t\t\t\u0027AreaID\u0027: Area,\n\t\t\t\t\u0027BOM\u0027: BOM,\n\t\t\t\t\u0027WorkStationName\u0027: \u0027LAML130\u0027\n\t\t\t\t}\n\t\t\t\tsystem.perspective.print(\"Param: %s\"%param)\n\t\t\t\tfetchResult  \u003d system.db.runNamedQuery(\u0027Project_VECV/Report/RAandDH_Mapping/FetchBomAndPartNumber\u0027,param)\n\t\t\t\tsystem.perspective.print(\"Legacy Fetch Result: %s\"%fetchResult)\n\t\t\t\tif fetchResult.rowCount !\u003d 0:\n\t\t\t\t\tsystem.perspective.print(\"Legacy Fetch Result: %s\"%fetchResult.rowCount)\n\t\t\t\t\tself.parent.parent.parent.getChild(\"Table\").props.data \u003d fetchResult\n\t\t\t\t\t\n\t\t\t\t\tmessage \u003d \u0027Data Fetched.\u0027\n\t\t\t\t\tsystem.perspective.print(message)\n\t\t\t\telse:\n\t\t\t\t\tself.parent.parent.parent.getChild(\"msgStrip\").props.style.display \u003d \u0027block\u0027\n\t\t\t\t\tmessage \u003d \u0027No Record Found.\u0027\n\t\t\t\t\tsetMessage(\"Error\", message)\n\t\t\telif Area \u003d\u003d 2:\n\t\t\t\tsystem.perspective.print(\"Inside IF\")\n\t\t\t\tparam \u003d {\n\t\t\t\t\u0027AreaID\u0027: Area,\n\t\t\t\t\u0027BOM\u0027: BOM,\n\t\t\t\t\u0027WorkStationName\u0027: \u0027TAML30\u0027\n\t\t\t\t}\n\t\t\t\tsystem.perspective.print(\"Param: %s\"%param)\n\t\t\t\tfetchResult  \u003d system.db.runNamedQuery(\u0027Project_VECV/Report/RAandDH_Mapping/FetchBomAndPartNumber\u0027,param)\n\t\t\t\tsystem.perspective.print(\"Legacy Fetch Result: %s\"%fetchResult)\n\t\t\t\tif fetchResult.rowCount !\u003d 0:\n\t\t\t\t\tsystem.perspective.print(\"Legacy Fetch Result: %s\"%fetchResult.rowCount)\n\t\t\t\t\tself.parent.parent.parent.getChild(\"Table\").props.data \u003d fetchResult\n\t\t\t\t\t\n\t\t\t\t\tmessage \u003d \u0027Data Fetched.\u0027\n\t\t\t\t\tsystem.perspective.print(message)\n\t\t\t\telse:\n\t\t\t\t\tself.parent.parent.parent.getChild(\"msgStrip\").props.style.display \u003d \u0027block\u0027\n\t\t\t\t\tmessage \u003d \u0027No Record Found.\u0027\n\t\t\t\t\tsetMessage(\"Error\", message)\n\t\t\telse:\n\t\t\t\tself.parent.parent.parent.getChild(\"msgStrip\").props.style.display \u003d \u0027block\u0027\n\t\t\t\tmessage \u003d \u0027No Area Selected.\u0027\n\t\t\t\tsetMessage(\"Error\", message)\n\t\texcept Exception as e:\n\t\t\tself.parent.parent.parent.getChild(\"msgStrip\").props.style.display \u003d \u0027block\u0027\n\t\t\tsystem.perspective.print(\"Unexpected error in script: %s\" % str(e))\n\t\t\tsetMessage(\"Error\", \"An unexpected error occurred.\")\n\t\t\t\ndef setMessage(status, message):\n    system.perspective.sendMessage(\n        messageType\u003d\"setMessage\",\n        payload\u003d{\n            \"message\": message,\n            \"status\": status\n        },\n        scope\u003d\"view\"\n    )"
