                        "script": "   try:\n       # Get the table data\n       table_data \u003d self.parent.parent.parent.getChild(\"Table\").props.data\n   \n       # Check if the table contains data\n       if table_data is not None and len(table_data) \u003e 0:\n           try:\n               # If data is available, export it to Excel and trigger download\n               excel_data \u003d system.dataset.toExcel(True, [table_data])\n               system.perspective.download(fileName\u003d\"RA and DH Mapping Report.xlsx\", data\u003dexcel_data)\n               message \u003d \"Defect Report download successful to your local system in Excel format.\"\n               self.parent.parent.parent.getChild(\"msgStrip\").props.style.display \u003d \u0027block\u0027\n               setMessage(\"Success\", message)\n           except Exception as e:\n               # Handle errors during Excel export or download\n               system.perspective.print(\"Error during export or download: %s\" % str(e))\n               message \u003d \"An error occurred during export. Please try again or contact MES team\"\n               self.parent.parent.parent.getChild(\"msgStrip\").props.style.display \u003d \u0027block\u0027\n               setMessage(\"Error\", message)\n       else:\n           # Handle case where no data is available\n        \tmessage \u003d \"No data available to export for given Inputs.\"\n        \tself.parent.parent.parent.getChild(\"msgStrip\").props.style.display \u003d \u0027block\u0027\n        \tsetMessage(\"Error\", message)\n   \n   except Exception as e:\n       # Handle unexpected errors in the overall script\n\t\tsystem.perspective.print(\"Unexpected error: %s\" % str(e))\n\t\tself.parent.parent.parent.getChild(\"msgStrip\").props.style.display \u003d \u0027block\u0027\n\t\tsetMessage(\"Error\", message)\n       \ndef setMessage(status, message):\n    system.perspective.sendMessage(\n        messageType\u003d\"setMessage\",\n        payload\u003d{\n            \"message\": message,\n            \"status\": status\n        },\n        scope\u003d\"view\"\n    )"
