True\n      params.update({\u0027LineName\u0027: LineName})\n  elif WorkStation !\u003d \"\" and LineName \u003d\u003d \"\":\n      valid_combination \u003d True\n      params.update({\u0027WorkStation\u0027: WorkStation})\n  elif ETCode !\u003d \"\" and TMCode !\u003d \"\":\n      valid_combination \u003d True\n      params.update({\u0027ETCode\u0027: ETCode, \u0027TMCode\u0027: TMCode})\n  elif AreaName !\u003d \"\":\n      valid_combination \u003d True\n      params.update({\u0027AreaName\u0027: AreaName})\n  \n  # Log the parameters to check if they are set correctly\n  system.perspective.print(\"Running Named Query with Parameters: {params}\")\n  \n  # If a valid combination is found, proceed with the query\n  if valid_combination:\n      # Show success message\n      self.getSibling(\"msgStrip\").props.text \u003d \"Report is Ready to View\"\n      self.getSibling(\"msgStrip\").props.style.backgroundColor \u003d \"#2ECB11FA\"  # Green background for success\n      self.getSibling(\"msgStrip\").props.style.color \u003d \"Black\"\n  \n      # Run the Named Query with the parameters\n      result \u003d system.db.runNamedQuery(\"Sadhana/PokaYoke_Queries/query_getAllData\", params)\n  \n      # Check if result is not empty\n      if result:\n          # Set the result into the table container\n          self.parent.getChild(\"table_container\").getChild(\"Table\").props.data \u003d result\n      else:\n          # If no data is returned, show a message\n          self.parent.getChild(\"table_container\").getChild(\"Table\").props.data \u003d \u0027\u0027\n          self.getSibling(\"msgStrip\").props.text \u003d \"No Data Found for the Selected Criteria\"\n          self.getSibling(\"msgStrip\").props.style.backgroundColor \u003d \"#FF4747\"  # Red background for error\n          self.getSibling(\"msgStrip\").props.style.color \u003d \"Black\"\n  else:\n      # If no valid combination is made, show error message\n      self.getSibling(\"msgStrip\").props.text \u00