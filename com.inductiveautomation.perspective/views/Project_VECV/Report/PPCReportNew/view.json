                    "script": "\tfrom datetime import datetime  \n    #Fetch values from dropdowns and input fields\n\tAreaName \u003d self.parent.parent.getChild(\"cntFlexInputs\").getChild(\"DDArea\").props.value\n\tLineName \u003d self.parent.parent.getChild(\"cntFlexInputs\").getChild(\"DDLine\").props.value\n\tRACode \u003d self.parent.parent.getChild(\"cntFlexInputs\").getChild(\"DDRaCode\").props.value\n\tStartDate \u003d self.getSibling(\"InpFromDate\").props.value\n\tEndDate \u003d self.getSibling(\"InpToDate\").props.value\n\tOrderState \u003d self.getSibling(\"DDStatus\").props.value\n\tserial_number \u003d self.parent.parent.getChild(\"cntFlexInputs\").getChild(\"TFSerialNumber\").props.text\n\tdisplayMsgArea \u003d self.parent.parent.getChild(\"msgStrip\").props\n\t\n\t\n\t# Initialize the message text variable\n\tmessage_text \u003d \"\"\n\t\n\t# Check if StartDate and EndDate are both selected and calculate the difference in days\n\tif StartDate is not None and EndDate is not None:\n\t    # Convert Java date to string in the \u0027dd-MM-yyyy HH:mm:ss\u0027 format\n\t    start_date_str \u003d system.date.format(StartDate, \"dd-MM-yyyy HH:mm:ss\")\n\t    end_date_str \u003d system.date.format(EndDate, \"dd-MM-yyyy HH:mm:ss\")\n\t    \n\t    # Parse the date strings into Python datetime objects\n\t    start_date_py \u003d datetime.strptime(start_date_str, \"%d-%m-%Y %H:%M:%S\")\n\t    end_date_py \u003d datetime.strptime(end_date_str, \"%d-%m-%Y %H:%M:%S\")\n\t    \n\t    # Calculate the difference in days\n\t    date_diff \u003d (end_date_py - start_date_py).days\n\t\n\t    # If the date difference exceeds 60 days, display an error message and stop\n\t    if date_diff \u003e 60:\n\t        message_text +\u003d \"Date range exceeds 60 days. Please select a shorter date range.\"\n\t        self.parent.parent.getChild(\"msgStrip\").props.style.backgroundColor\u003d\"#FF4747\"\n\t        self.parent.parent.getChild(\"msgStrip\").props.style.color\u003d\"Black\"\n\t        self.parent.parent.getChild(\"msgStrip\").props.text\u003dmessage_text\n\t        return  # Stop further execution of the script\n\t\n\t# Set the message based on the dropdown selections\n\tif AreaName !\u003d \"\":\n\t    if serial_number !\u003d \"\":\n\t        message_text +\u003d \"Report Ready To View\"\n\t        displayMsgArea.style.backgroundColor \u003d \"#2ECB11FA\"\n\t        displayMsgArea.style.color \u003d \"Black\"\n\t        result \u003d system.db.runNamedQuery(\"Project_VECV/Report/PPC_Report(Queries)/Serialno._AreaName\", {\u0027AreaName\u0027: AreaName, \u0027serial_number\u0027: serial_number})\n\t        self.parent.parent.getChild(\"cntCoordinateTable\").getChild(\"Table_0\").props.data \u003d result\n\t\n\t    elif StartDate is not None or EndDate is not None:\n\t        if RACode !\u003d \"\" and OrderState !\u003d \"\":\n\t            message_text +\u003d \"Report Ready To View \"\n\t            displayMsgArea.style.backgroundColor \u003d \"#2ECB11FA\"\n\t            displayMsgArea.style.color \u003d \"Black\"\n\t            result \u003d system.db.runNamedQuery(\"Project_VECV/Report/PPC_Report(Queries)/area_date_orderst_ra\", {\u0027AreaName\u0027: AreaName, \u0027StartDate\u0027: StartDate, \u0027EndDate\u0027: EndDate, \u0027RACode\u0027: RACode, \u0027OrderState\u0027: OrderState})\n\t            self.parent.parent.getChild(\"cntCoordinateTable\").getChild(\"Table_0\").props.data \u003d result\n\t            #self.parent.parent.getChild(\"msgStrip\").props.text\u003dresult\n\t        elif RACode !\u003d \"\":\n\t            message_text +\u003d \"Report Ready To View \"\n\t            displayMsgArea.style.backgroundColor \u003d \"#2ECB11FA\"\n\t            displayMsgArea.style.color \u003d \"Black\"\n\t            result \u003d system.db.runNamedQuery(\"Project_VECV/Report/PPC_Report(Queries)/date_area_RA\", {\u0027AreaName\u0027: AreaName, \u0027StartDate\u0027: StartDate, \u0027EndDate\u0027: EndDate, \u0027RACode\u0027: RACode})\n\t            self.parent.parent.getChild(\"cntCoordinateTable\").getChild(\"Table_0\").props.data \u003d result\n\t        elif OrderState !\u003d \"\":\n\t            message_text +\u003d \"Report Ready To View \"\n\t            displayMsgArea.style.backgroundColor \u003d \"#2ECB11FA\"\n\t            displayMsgArea.style.color \u003d \"Black\"\n\t            result \u003d system.db.runNamedQuery(\"Project_VECV/Report/PPC_Report(Queries)/date_area_orderst\", {\u0027AreaName\u0027: AreaName, \u0027StartDate\u0027: StartDate, \u0027EndDate\u0027: EndDate, \u0027OrderState\u0027: OrderState})\n\t            self.parent.parent.getChild(\"cntCoordinateTable\").getChild(\"Table_0\").props.data \u003d result\n\t        else:\n\t            message_text +\u003d \"Report Ready To View\"\n\t            displayMsgArea.style.backgroundColor \u003d \"#2ECB11FA\"\n\t            displayMsgArea.style.color \u003d \"Black\"\n\t            result \u003d system.db.runNamedQuery(\"Project_VECV/Report/PPC_Report(Queries)/date_area\", {\u0027AreaName\u0027: AreaName, \u0027StartDate\u0027: StartDate, \u0027EndDate\u0027: EndDate})\n\t            self.parent.parent.getChild(\"cntCoordinateTable\").getChild(\"Table_0\").props.data \u003d result\n\t    else:\n\t        message_text +\u003d \"Either Dates or Serial Number is Mandatory to View the Report\"\n\t        displayMsgArea.style.backgroundColor \u003d \"#FF4747\"\n\t        displayMsgArea.style.color \u003d \"Black\"\n\telse:\n\t    message_text +\u003d \"Area Selection is Mandatory to View Report\"\n\t    displayMsgArea.style.backgroundColor \u003d \"#FF4747\"\n\t    displayMsgArea.style.color \u003d \"Black\"\n\t\n\t\n\tself.parent.parent.getChild(\"msgStrip\").props.text \u003d message_text"
                  },
