ePopup\", \"closePopup\", \"closePopup\",\"\",\"\",\"\",\"\")\n\telse:\n\t\tstate \u003d \u0027success\u0027\n\t\tmessage \u003d \u0027Transmission Type created successfully !\u0027\n\t\tProject_VECV.PopUp.Alerts.showAlert(str(state), str(state.capitalize()), str(message), \"true\", \"Okay\", \"\", \"\", \"\", \"\", \"closePopup\", \"closePopup\", \"closePopup\",\"\",\"\",\"\",\"\")\t\n\t\n\tself.parent.parent.parent.parent.getChild(\"FlexContainer_0\").getChild(\"TMCodetxt\").props.text\u003d\u0027\u0027\n\tself.parent.parent.parent.parent.getChild(\"FlexContainer_0\").getChild(\"ModelCodetxt\").props.text\u003d\u0027\u0027\n\tself.parent.parent.parent.parent.getChild(\"FlexContainer_0\").getChild(\"PunchingCodetxt\").props.text\u003d\u0027\u0027\n\tself.parent.parent.parent.parent.getChild(\"FlexContainer_1\").getChild(\"PunchingGrouptxt\").props.text\u003d\u0027\u0027\n\tself.parent.parent.parent.parent.getChild(\"FlexContainer_1\").getChild(\"WormSpeedratiotxt\").props.text\u003d\u0027\u0027\n\tself.parent.parent.parent.parent.getChild(\"FlexContainer_1\").getChild(\"Designtxt\").props.text\u003d\u0027\u0027\n\tsystem.perspective.sendMessage(\"refreshTable\",scope\u003d\u0027page\u0027)"
