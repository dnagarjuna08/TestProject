                  "code": "\tresult \u003d []\n\tdataset \u003d system.dataset.toPyDataSet(value)\n\tfor dt in dataset:\n\t\taction \u003d {\"Id\" : dt[\"ID\"],\"Design\" : dt[\"Design\"],\"WormSpeedoRatio\" : dt[\"Worm Speedo Ratio\"],\"PunchingGroup\" : dt[\"Punching Group\"],\"PunchingCode\" : dt[\"Punching Code\"],\n\t\t\"Model\" : dt[\"Model\"],\"TMCode\" : dt[\"TM Code\"]}\n\t\tparams \u003d {\"ID\" : dt[\"ID\"],\"Design\" : dt[\"Design\"],\"Worm Speedo Ratio\" : dt[\"Worm Speedo Ratio\"],\"Punching Group\" : dt[\"Punching Group\"],\"Punching Code\" : dt[\"Punching Code\"],\n\t\t\t\t\"Model\" : dt[\"Model\"],\"TM Code\" : dt[\"TM Code\"], \"Action\":{\"value\":action}}\n\t\tresult.append(params)\n\treturn result",
                  "type": "script"
                }
              ],
              "type": "query"
            }
          }
