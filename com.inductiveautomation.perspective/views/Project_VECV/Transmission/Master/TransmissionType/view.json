            "onRowClick": {
              "config": {
                "script": "\t\"\"\"\n\t\tWritten By: Akhil Aerra\n\t\tWritten Date: 14/10/2024\n\t\tPurpose: Delete/Update data on row selection. \n\t\"\"\"\n\ttry:\n\t\tselectedRow \u003d self.props.selection.data\n\t\tfor data in\tselectedRow:\n\t\t\tID \u003d data[\"ID\"]\n\t\t\tTMCode \u003d data[\"TM Code\"]\n\t\t\tModel \u003d data[\"Model\"]\n\t\t\tPunchingCode \u003d data[\"Punching Code\"]\n\t\t\tPunchingGroup \u003d data[\"Punching Group\"]\n\t\t\tWormSpeedoRatio \u003d data[\"Worm Speedo Ratio\"]\n\t\t\tDesign \u003d data[\"Design\"]\t\n\t\tself.props.columns[6].viewParams.Id\u003dint(ID)\n\t\tself.props.columns[6].viewParams.Design\u003dstr(Design)\n\t\tself.props.columns[6].viewParams.Model\u003dstr(Model)\n\t\tself.props.columns[6].viewParams.PunchingCode\u003dstr(PunchingCode)\n\t\tself.props.columns[6].viewParams.PunchingGroup\u003dstr(PunchingGroup)\n\t\tself.props.columns[6].viewParams.TMCode\u003dstr(TMCode)\n\t\tself.props.columns[6].viewParams.WormSpeedoRatio\u003dstr(WormSpeedoRatio)\n\t\tpayload \u003d {\u0027ID\u0027:int(ID)}\n\t\tsystem.perspective.sendMessage(\u0027TransmissionDeletePanel\u0027, payload, scope \u003d \u0027page\u0027 )\t\n\texcept:\n\t\tscreenName \u003d\u0027TransmissionType Configuration\u0027   \n\t\tfilePath\u003dstr(\u0027Project_VECV/Transmission/Master/TransmissionType\u0027)  \n\t\terrorFunction \u003d str(\u0027Event:onRowClick -\u003e cntBody/table\u0027)  \n\t\terrorType\u003dstr(\u0027Application\u0027)  \n\t\terrorCode \u003d str(Project_VECV.Common.GenerateUUID.getUniqueUUID())   \n\t\tdescription\u003dstr(sys.exc_info()[1]) #error description \n\t\tlineNumber\u003dstr(sys.exc_info()[2].tb_lineno) #lineno on which error \n\t\tProject_VECV.Configuration.Common.AddLogDetails.AddErrorLogs(screenName,filePath,errorFunction,errorType,errorCode,description,lineNumber) "
              },
              "enabled": false,
              "scope": "G",
              "type": "script"
            }
