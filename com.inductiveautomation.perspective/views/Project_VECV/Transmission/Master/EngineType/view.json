            "type": "ia.input.dropdown"
          },
          {
            "children": [
              {
                "children": [
                  {
                    "events": {
                      "dom": {
                        "onClick": {
                          "config": {
                            "script": "\tType \u003d self.parent.parent.parent.getChild(\"Dropdown\").props.value\n\tETCode \u003d self.parent.parent.parent.getChild(\"ETCodetxt\").props.text\n\tTMCode \u003d self.parent.parent.parent.getChild(\"TMCodetxt\").props.text\n\tparams \u003d { \"Type\" :str(Type).upper(),\n\t\t\"ETCode\" :str(ETCode).upper(),\n\t\t\"TMCode\" :str(TMCode).upper(),\n\t\t\"CreatedBy\" :1}\n\tdata \u003d system.db.runNamedQuery(\"Project_VECV/Transmission/AddEngineTypeData\"\n\t\t\t\t\t\t\t\t,{ \"Type\" :str(Type).upper(),\n\t\t\t\t\t\t\t\t\"ETCode\" :str(ETCode).upper(),\n\t\t\t\t\t\t\t\t\"TMCode\" :str(TMCode).upper(),\n\t\t\t\t\t\t\t\t\"CreatedBy\" :1})\n\tResult \u003d 0\n\tfor dt in data:\n\t\tsystem.perspective.print(dt[\u0027Result\u0027])\n\t\tResult \u003d dt[\u0027Result\u0027]\n\tif Result \u003d\u003d 0:\n\t\tstate \u003d \u0027info\u0027\n\t\tmessage \u003d \u0027Engine Type Already Exists!\u0027\n\t\tProject_VECV.PopUp.Alerts.showAlert(str(state), str(state.capitalize()), str(message), \"true\", \"Okay\", \"\", \"\", \"\", \"\", \"closePopup\", \"closePopup\", \"closePopup\",\"\",\"\",\"\",\"\")\t\n\telse:\n\t\tstate \u003d \u0027success\u0027\n\t\tmessage \u003d \u0027Engine Type saved successfully !\u0027\n\t\tProject_VECV.PopUp.Alerts.showAlert(str(state), str(state.capitalize()), str(message), \"true\", \"Okay\", \"\", \"\", \"\", \"\", \"closePopup\", \"closePopup\", \"closePopup\",\"\",\"\",\"\",\"\")\t\n\tself.parent.parent.parent.getChild(\"Dropdown\").props.value \u003d None\n\tself.parent.parent.parent.getChild(\"ETCodetxt\").props.text \u003d \u0027\u0027\n\tself.parent.parent.parent.getChild(\"TMCodetxt\").props.text \u003d \u0027\u0027\n\tsystem.perspective.sendMessage(\"refreshTable\",scope\u003d\u0027page\u0027)\n\t\n\t"
                          },
                          "scope": "G",
                          "type": "script"
                        }
                      }
                    },
                    "meta": {
                      "name": "createbtn"
                    },
                    "position": {
                      "basis": "80px"
                    },
                    "propConfig": {
                      "props.enabled": {
                        "binding": {
                          "config": {
                            "expression": "if( {..../ETCodetxt.props.text} !\u003d \u0027\u0027 \u0026\r\n{..../TMCodetxt.props.text} !\u003d \u0027\u0027 \u0026\r\n{..../Dropdown.props.value} !\u003d \u0027\u0027\r\n,toBoolean(1),toBoolean(0))"
                          },
                          "type": "expr"
                        }
                      }
                    },
