{
  "custom": {},
  "params": {
    "Description": "value",
    "Status": false
  },
  "propConfig": {
    "params.Description": {
      "paramDirection": "inout",
      "persistent": true
    },
    "params.Status": {
      "paramDirection": "inout",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 50,
      "width": 370
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "Label"
        },
        "position": {
          "grow": 1
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.Description"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "color": "#283593",
            "fontWeight": "bolder",
            "margin": 5,
            "wordWrap": "break-word"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "Checkbox"
        },
        "position": {
          "basis": "60px"
        },
        "propConfig": {
          "props.selected": {
            "binding": {
              "config": {
                "path": "view.params.Status"
              },
              "type": "property"
            },
            "onChange": {
              "enabled": null,
              "script": "\tif self.props.selected:\n\t\tmessageType \u003d \u0027poka-yoke-selection\u0027\n\t\tsystem.perspective.sendMessage(messageType, payload \u003d {\"Description\":self.view.params.Description}, scope \u003d \"page\")\n\telif not self.props.selected:\n\t\tmessageType \u003d \u0027poka-yoke-deselection\u0027\n\t\tsystem.perspective.sendMessage(messageType, payload \u003d {\"Description\":self.view.params.Description}, scope \u003d \"page\")"
            }
          }
        },
        "props": {
          "checkedIcon": {
            "color": {
              "disabled": "#00D900",
              "enabled": "#00D900"
            }
          },
          "text": ""
        },
        "type": "ia.input.checkbox"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "style": {
        "borderBottomLeftRadius": 5,
        "borderBottomRightRadius": 5,
        "borderColor": "#FFFFFF",
        "borderStyle": "inset",
        "borderTopLeftRadius": 5,
        "borderTopRightRadius": 5,
        "borderWidth": 2,
        "margin": 2
      }
    },
    "type": "ia.container.flex"
  }
}