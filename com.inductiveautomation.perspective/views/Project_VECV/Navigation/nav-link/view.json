{
  "custom": {},
  "params": {
    "icon": "value",
    "subMenuName": "Link 1",
    "target": ""
  },
  "propConfig": {
    "params.icon": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.subMenuName": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.target": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 40,
      "width": 300
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "Icon"
        },
        "position": {
          "basis": "30px"
        },
        "propConfig": {
          "props.path": {
            "binding": {
              "config": {
                "path": "view.params.icon"
              },
              "type": "property"
            }
          }
        },
        "type": "ia.display.icon"
      },
      {
        "meta": {
          "name": "Label"
        },
        "position": {
          "grow": 1
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.subMenuName"
              },
              "type": "property"
            }
          }
        },
        "type": "ia.display.label"
      }
    ],
    "events": {
      "dom": {
        "onClick": {
          "config": {
            "script": "\t#update TopViewHeader session Params\n\tself.session.custom.TopViewHeader \u003d self.getChild(\"Label\").props.text\n#\tsystem.perspective.navigate(page \u003d self.view.params.target)\t\n\tsystem.perspective.navigate(page \u003d self.view.params.target)\t"
          },
          "scope": "G",
          "type": "script"
        }
      }
    },
    "meta": {
      "name": "root"
    },
    "props": {
      "style": {
        "classes": "Project_VECV/Login/Hover",
        "cursor": "pointer"
      }
    },
    "type": "ia.container.flex"
  }
}