{
  "custom": {},
  "params": {
    "DropIcon": "material/arrow_drop_down",
    "IconPath": "",
    "Instance": [
      {
        "instancePosition": {},
        "instanceStyle": {
          "classes": ""
        },
        "label": "Link 1",
        "target": ""
      },
      {
        "instancePosition": {},
        "instanceStyle": {
          "classes": ""
        },
        "label": "Link 2",
        "target": "/link"
      }
    ],
    "MenuDescription": "Label",
    "Selected": false,
    "itemHeight": 40
  },
  "propConfig": {
    "params.DropIcon": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.IconPath": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.Instance": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.MenuDescription": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.Selected": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.itemHeight": {
      "paramDirection": "input",
      "persistent": true
    },
    "props.defaultSize.height": {
      "binding": {
        "config": {
          "path": "view.params.Selected"
        },
        "transforms": [
          {
            "code": "\tif value:\n\t\treturn (len(self.params.Instance)+1)*self.params.itemHeight+3\n\telse:\n\t\treturn self.params.itemHeight",
            "type": "script"
          }
        ],
        "type": "property"
      }
    }
  },
  "props": {
    "defaultSize": {
      "width": 300
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "Icon"
            },
            "position": {
              "basis": "30px",
              "shrink": 0
            },
            "propConfig": {
              "props.path": {
                "binding": {
                  "config": {
                    "path": "view.params.IconPath"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "padding": "3px"
              }
            },
            "type": "ia.display.icon"
          },
          {
            "meta": {
              "name": "Label"
            },
            "position": {
              "basis": "50px",
              "grow": 1
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.MenuDescription"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "classes": "nav-link"
              }
            },
            "type": "ia.display.label"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "Icon"
                },
                "position": {
                  "grow": 1
                },
                "propConfig": {
                  "props.path": {
                    "binding": {
                      "config": {
                        "path": "view.params.DropIcon"
                      },
                      "type": "property"
                    }
                  }
                },
                "type": "ia.display.icon"
              }
            ],
            "meta": {
              "name": "FlexContainer"
            },
            "position": {
              "basis": "20px",
              "shrink": 0
            },
            "props": {
              "style": {
                "classes": "nav-section-arrow"
              }
            },
            "type": "ia.container.flex"
          }
        ],
        "events": {
          "dom": {
            "onClick": {
              "config": {
                "script": "\n\tif self.getChild(\"FlexContainer\").getChild(\"Icon\").props.path \u003d\u003d \u0027material/arrow_drop_down\u0027:\n\t\tself.view.params.DropIcon \u003d \u0027material/arrow_drop_up\u0027\n\t\tmessageType\u003d\u0027select_menu\u0027\n\t\tsystem.perspective.sendMessage(messageType,{\u0027MenuDescription\u0027:self.view.params.MenuDescription},scope\u003d\u0027page\u0027)\n\telse:\n\t\tself.view.params.DropIcon \u003d \u0027material/arrow_drop_down\u0027\n\t\tmessageType\u003d\u0027unselect_menu\u0027\n\t\tsystem.perspective.sendMessage(messageType,scope\u003d\u0027page\u0027)"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "FlexContainer"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "position.basis": {
            "binding": {
              "config": {
                "path": "view.params.itemHeight"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "classes": "Project_VECV/Login/Hover",
            "cursor": "pointer",
            "gap": "8px",
            "overflow": "hidden"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "FlexRepeater"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "path": "view.params.Selected"
              },
              "type": "property"
            }
          },
          "props.elementPosition.basis": {
            "binding": {
              "config": {
                "path": "view.params.itemHeight"
              },
              "type": "property"
            }
          },
          "props.instances": {
            "binding": {
              "config": {
                "path": "view.params.Instance"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "direction": "column",
          "elementPosition": {
            "grow": 0,
            "shrink": 0
          },
          "path": "Project_VECV/Navigation/nav-link",
          "style": {
            "background-color": "#EBEBEB",
            "border-radius": "7px",
            "gap": "8px",
            "overflow": "hidden",
            "padding": "8px 0"
          },
          "useDefaultViewHeight": false,
          "useDefaultViewWidth": false
        },
        "type": "ia.display.flex-repeater"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "classes": "nav-section",
        "gap": "8px",
        "overflow": "hidden"
      }
    },
    "type": "ia.container.flex"
  }
}