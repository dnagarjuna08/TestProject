                "script": "\t\"\"\"\n\t\tWritten By: Amitkumar Ravat\n\t\tWritten Date: 24/08/2024\n\t\tPurpose: print barcode\t\n\t\"\"\"\t\n\tres\u003dsystem.db.runNamedQuery(\"Project_VECV/Order/WashingMachine/GetPrinterDetails\",{\u0027WorkStation\u0027:self.getSibling(\"drpStation\").props.value})\n\tpyres\u003dsystem.dataset.toPyDataSet(res)\n\tfor row in pyres:\n\t\tIP \u003d row[\"IPAddress\"]\n\t\tport \u003d row[\"Port\"]\n\tserialNumber \u003d self.getSibling(\"txtSerialNumber\").props.text\n\tGearRatio \u003d self.getSibling(\"txtGearRatio\").props.text\n\tshift \u003d self.getSibling(\"txtShift\").props.text\n\tdate \u003d self.getSibling(\"DateTimeInput\").props.value\n\tif date \u003d\u003d None:\n\t\tsystem.perspective.print(\"in line 17\")\n\t\tProject_VECV.Printer.GetPrint.getPrint(serialNumber, GearRatio, shift, IP, port)\n\telse:\n\t\tdate\u003d system.date.format(date, \"dd/MM/yy\")\n\t\tsystem.perspective.print(\"in else\")\n\t\tsystem.perspective.print(date)\n\t\tProject_VECV.Printer.GetPrint.getPrintSupport(serialNumber, GearRatio, shift, IP, port, date)\n\tmessage \u003d \"Barcode Generated successfully.\"\n\tstate \u003d \"info\"\n\tProject_VECV.PopUp.Alerts.showAlert(str(state), str(state.capitalize()), str(message), \"true\", \"Okay\", \"\", \"\", \"\", \"\", \"closePopup\", \"closePopup\", \"closePopup\",\"\",\"\",\"\",\"\")\n\tself.getSibling(\"txtSerialNumber\").props.text \u003d \u0027\u0027\n\tself.getSibling(\"txtGearRatio\").props.text \u003d \u0027\u0027\n\tself.getSibling(\"txtShift\").props.text \u003d \u0027\u0027\n\tself.getSibling(\"drpStation\").props.value \u003d -1\n\tself.getSibling(\"DateTimeInput\").props.value \u003d None"
