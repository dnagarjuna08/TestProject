        "events": {
          "dom": {
            "onClick": {
              "config": {
                "script": "\t\"\"\"\n\t\tWritten By: Amitkumar Ravat\n\t\tWritten Date: 24/08/2024\n\t\tPurpose: print barcode\t\n\t\"\"\"\n\tserialNumber\u003dself.getSibling(\"txtSerialNumberQG\").props.text\n\tsystem.perspective.print(serialNumber)\n\tcount \u003d system.db.runNamedQuery(\"Project_VECV/ITSupport/checkSerialNumber\",{\"SerialNumber\":serialNumber})\t\n\tsystem.perspective.print(count)\n\tif int(count) \u003e 0:\n\t\ttry:\n\t\t\tQGID \u003d self.getSibling(\"drpStation_1\").props.value\n\t\t\tQGOptions \u003d self.getSibling(\"drpStation_1\").props.options\n\t\t\tQGOptions\u003d system.dataset.toPyDataSet(QGOptions)\n\t\t\tfor dt in QGOptions:\n\t\t\t\tif QGID\u003d\u003ddt[\u0027value\u0027]:\n\t\t\t\t\tWorkStation\u003ddt[\u0027label\u0027]\n\t\t\tBOMId\u003dsystem.db.runNamedQuery(\"Project_VECV/Rework/getBOMId\",{\u0027SerialNumber\u0027:serialNumber})\n\t\t\tBOMNumber\u003dsystem.db.runNamedQuery(\"Project_VECV/ITSupport/getBOM\",{\u0027SerialNumber\u0027:serialNumber})\n\t\t\tif str(WorkStation).upper() in  [\u0027LAQG04\u0027, \u0027LAQG05\u0027]:\n\t\t\t\tres\u003dsystem.db.runNamedQuery(\"Project_VECV/Order/WashingMachine/GetPrinterDetails\",{\u0027WorkStation\u0027:QGID})\n\t\t\t\tpyres\u003dsystem.dataset.toPyDataSet(res)\n\t\t\t\tfor row in pyres:\n\t\t\t\t\tIP \u003d row[\"IPAddress\"]\n\t\t\t\t\tport \u003d row[\"Port\"]\n\t\t\t\tdata \u003d system.db.runNamedQuery(\"Project_VECV/Order/getPartNumber\",{\"MST_WorkStation_Id\":QGID,\"M_BOM_Id\":BOMId})\n\t\t\t\tpartNumber \u003d \u0027\u0027\n\t\t\t\tfor dt in data:    \n\t\t\t\t\tpartNumber \u003d dt[\u0027M_MaterialNumber\u0027]\n\t\t\t\tif partNumber !\u003d \u0027\u0027:\n\t\t\t\t\tgearRatio \u003d system.db.runNamedQuery(\"Project_VECV/ITSupport/getGearRatio\",{\"SerialNumber\":serialNumber})\n\t\t\t\t\tProject_VECV.Printer.GetPrint.getDHPrint(serialNumber,IP,port,partNumber,gearRatio)\n\t\t\tif str(WorkStation).upper() \u003d\u003d \u0027LAQG03\u0027:\n\t\t\t\tres\u003dsystem.db.runNamedQuery(\"Project_VECV/Order/WashingMachine/GetPrinterDetails\",{\u0027WorkStation\u0027:QGID})\n\t\t\t\tpyres\u003dsystem.dataset.toPyDataSet(res)\n\t\t\t\tfor row in pyres:\n\t\t\t\t\tIP \u003d row[\"IPAddress\"]\n\t\t\t\t\tport \u003d row[\"Port\"]\n\t\t\t\tProject_VECV.Printer.GetPrint.getPrintHub(IP, port, serialNumber, BOMNumber)\n\t\t\tmessage \u003d \"Barcode Generated successfully.\"\n\t\t\tstate \u003d \"info\"\n\t\t\tProject_VECV.PopUp.Alerts.showAlert(str(state), str(state.capitalize()), str(message), \"true\", \"Okay\", \"\", \"\", \"\", \"\", \"closePopup\", \"closePopup\", \"closePopup\",\"\",\"\",\"\",\"\")\n\t\t\tself.getSibling(\"txtSerialNumberQG\").props.text \u003d \u0027\u0027\n\t\t\tself.getSibling(\"drpStation_1\").props.value \u003d -1\n\t\texcept:\n\t\t\tmessage \u003d \"Barcode Printing Failed.\"\n\t\t\tstate \u003d \"error\"\n\t\t\tProject_VECV.PopUp.Alerts.showAlert(str(state), str(state.capitalize()), str(message), \"true\", \"Okay\", \"\", \"\", \"\", \"\", \"closePopup\", \"closePopup\", \"closePopup\",\"\",\"\",\"\",\"\")\n\t\t\tscreenName \u003d\u0027Support IT\u0027   \n\t\t\tfilePath\u003dstr(\u0027Project_VECV/IT Support/BarCodePrinting\u0027)  \n\t\t\terrorFunction \u003d str(\u0027Event:onRowClick -\u003e Support IT\u0027)  \n\t\t\terrorType\u003dstr(\u0027Application\u0027)  \n\t\t\terrorCode \u003d str(Project_VECV.Common.GenerateUUID.getUniqueUUID())   \n\t\t\tdescription\u003dstr(sys.exc_info()[1]) #error description \n\t\t\tlineNumber\u003dstr(sys.exc_info()[2].tb_lineno) #lineno on which error \n\t\t\tProject_VECV.Configuration.Common.AddLogDetails.AddErrorLogs(screenName,filePath,errorFunction,errorType,errorCode,description,lineNumber) \n\telse:\n\t\tmessage \u003d \"Serial Number is Invalid.\"\n\t\tstate \u003d \"error\"\n\t\tProject_VECV.PopUp.Alerts.showAlert(str(state), str(state.capitalize()), str(message), \"true\", \"Okay\", \"\", \"\", \"\", \"\", \"closePopup\", \"closePopup\", \"closePopup\",\"\",\"\",\"\",\"\")\n\t\t\t\t\t"
              },
