              "config": {
                "script": "\t\"\"\"\n\t\tWritten By: Amitkumar Ravat\n\t\tWritten Date: 24/08/2024\n\t\tPurpose: print barcode\t\n\t\t\n\t\tUpdateDate: 20/01/2025\n\t\tAuthor: Aniket Sagar\n\t\tPurpose: Do reprint only if isPDI OK \n\t\"\"\"\n\t#WsName\u003d\u0027LAPDI\u0027\n\tcount \u003d system.db.runNamedQuery(\"Project_VECV/ITSupport/isPDIok\",{\"SerialNumber\":self.getSibling(\"txtSerialNumberPDI\").props.text})\t\n\tif int(count) \u003e 0:\n\t\tres\u003dsystem.db.runNamedQuery(\"Project_VECV/Order/WashingMachine/GetPrinterDetails\",{\u0027WorkStation\u0027:self.getSibling(\"drpStation_0\").props.value})\n\t\tpyres\u003dsystem.dataset.toPyDataSet(res)\n\t\tfor row in pyres:\n\t\t\tIP \u003d row[\"IPAddress\"]\n\t\t\tport \u003d row[\"Port\"]\n\t\ttry:\n\t\t\tserialNumber \u003d self.getSibling(\"txtSerialNumberPDI\").props.text\n\t\t\ttoday \u003d self.getSibling(\"DateTimeInput_0\").props.value\n\t\t\tif today \u003d\u003d None:\n\t\t\t\tProject_VECV.Printer.GetPrint.getPDIPrint(serialNumber, IP, port)\n\t\t\telse:\n\t\t\t\tline \u003d system.db.runNamedQuery(\"Project_VECV/ITSupport/getLine\",{\"MST_WorkStation_Id\":self.getSibling(\"drpStation_0\").props.value})\n\t\t\t\tProject_VECV.Printer.GetPrint.getPDIPrintSupport(serialNumber,IP,port,today, line)\n\t\t\tmessage \u003d \"Barcode Generated successfully.\"\n\t\t\tstate \u003d \"info\"\n\t\t\tProject_VECV.PopUp.Alerts.showAlert(str(state), str(state.capitalize()), str(message), \"true\", \"Okay\", \"\", \"\", \"\", \"\", \"closePopup\", \"closePopup\", \"closePopup\",\"\",\"\",\"\",\"\")\n\t\t\tself.getSibling(\"txtSerialNumberPDI\").props.text \u003d \u0027\u0027\n\t\t\tself.getSibling(\"DateTimeInput_0\").props.value \u003d None\n\t\t\tself.getSibling(\"drpStation_0\").props.value \u003d -1\n\t\texcept:\n\t\t\tmessage \u003d \"Barcode Printing Failed.\"\n\t\t\tstate \u003d \"error\"\n\t\t\tProject_VECV.PopUp.Alerts.showAlert(str(state), str(state.capitalize()), str(message), \"true\", \"Okay\", \"\", \"\", \"\", \"\", \"closePopup\", \"closePopup\", \"closePopup\",\"\",\"\",\"\",\"\")\n\t\t\tscreenName \u003d\u0027Support IT\u0027   \n\t\t\tfilePath\u003dstr(\u0027Project_VECV/IT Support/BarCodePrinting\u0027)  \n\t\t\terrorFunction \u003d str(\u0027Event:onRowClick -\u003e Support IT\u0027)  \n\t\t\terrorType\u003dstr(\u0027Application\u0027)  \n\t\t\terrorCode \u003d str(Project_VECV.Common.GenerateUUID.getUniqueUUID())   \n\t\t\tdescription\u003dstr(sys.exc_info()[1]) #error description \n\t\t\tlineNumber\u003dstr(sys.exc_info()[2].tb_lineno) #lineno on which error \n\t\t\tProject_VECV.Configuration.Common.AddLogDetails.AddErrorLogs(screenName,filePath,errorFunction,errorType,errorCode,description,lineNumber) \n\telse:\n\t\tmessage \u003d \"Given Serial Number PDI not done.\"\n\t\tstate \u003d \"error\"\n\t\tProject_VECV.PopUp.Alerts.showAlert(str(state), str(state.capitalize()), str(message), \"true\", \"Okay\", \"\", \"\", \"\", \"\", \"closePopup\", \"closePopup\", \"closePopup\",\"\",\"\",\"\",\"\")\n\t\t\t\t\t"
