        "propConfig": {
          "props.text": {
            "onChange": {
              "enabled": null,
              "script": "\tSerialNumber \u003d self.props.text\n\t#get GearRation and Fill the next Field\n\tdata \u003d system.db.runNamedQuery(\"Project_VECV/ITSupport/getGearRatio\",{\"SerialNumber\":SerialNumber})\n\tif str(data) \u003d\u003d \u00270\u0027:\n\t\tmessage \u003d \"Invalid Serial Number.\"\n\t\tstate \u003d \"warning\"\n\t\tProject_VECV.PopUp.Alerts.showAlert(str(state), str(state.capitalize()), str(message), \"true\", \"Okay\", \"\", \"\", \"\", \"\", \"closePopup\", \"closePopup\", \"closePopup\",\"\",\"\",\"\",\"\")\n\t\tself.getSibling(\"txtGearRatio\").props.text \u003d \u0027\u0027"
