      {
        "events": {
          "dom": {
            "onClick": {
              "config": {
                "script": "\t\"\"\"\n\t\tWritten By: Amitkumar Ravat\n\t\tWritten Date: 24/08/2024\n\t\tPurpose: Update Station Status\n\t\"\"\"\t\n\tWorkStationName \u003d self.getSibling(\"drpStation\").props.value\n\tSerialNumber \u003d self.getSibling(\"txtSerialNumber\").props.text\n\tBOMNumber \u003d SerialNumber.split(\u0027-\u0027)[1]\n\tStatus \u003d self.getSibling(\"drpStatus\").props.value\n\tparams\u003d{\"WorkStationName\":WorkStationName,\"SerialNumber\":SerialNumber,\"BOMNumber\":BOMNumber,\"CreatedBy\":self.session.custom.loggedInUserId,\"Status\":Status}\n\tmessage \u003d \"Station Status Stored successfully.\"\n\tstate \u003d \"info\"\n\tsystem.db.runNamedQuery(\"Project_VECV/ITSupport/StationStatus\",{\"WorkStationName\":int(WorkStationName),\"SerialNumber\":SerialNumber,\"BOMNumber\":BOMNumber,\"CreatedBy\":self.session.custom.loggedInUserId,\"Status\":int(Status)})\n\t\n\tProject_VECV.PopUp.Alerts.showAlert(str(state), str(state.capitalize()), str(message), \"true\", \"Okay\", \"\", \"\", \"\", \"\", \"closePopup\", \"closePopup\", \"closePopup\",\"\",\"\",\"\",\"\")\n\tself.getSibling(\"txtSerialNumber\").props.text \u003d \u0027\u0027\n\tself.getSibling(\"drpStatus\").props.value \u003d -1\n\tself.getSibling(\"drpStation\").props.value \u003d -1"
              },
              "scope": "G",
              "type": "script"
            }
          }
