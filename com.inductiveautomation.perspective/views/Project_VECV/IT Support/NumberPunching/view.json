            "onClick": {
              "config": {
                "script": "\n\t\"\"\"\n\t\tWritten By: Amitkumar Ravat\n\t\tWritten Date: 24/08/2024\n\t\tPurpose: Number Punching\n\t\"\"\"\t\n\tserialNumber \u003d self.getSibling(\"txtSerialNumber\").props.text\n\tSerialNumber \u003d serialNumber.split(\u0027-\u0027)[0]\n\tModel \u003d serialNumber.split(\u0027-\u0027)[1]\n\tGearRatio \u003d self.getSibling(\"txtGearRatio\").props.text\n\tshift \u003d self.getSibling(\"txtShift\").props.text\n\tWorkStationID \u003d self.getSibling(\"drpStation\").props.value\n\toptions \u003d self.getSibling(\"drpStation\").props.options\n\toptions \u003d system.dataset.toPyDataSet(options)\n\tWorkStation \u003d \u0027\u0027\n\tfor i in options:\n\t\tif i[\u0027value\u0027] \u003d\u003d WorkStationID:\n\t\t\tWorkStation \u003d i[\u0027label\u0027]\n\t\t\tbreak\n\tif str(WorkStation) \u003d\u003d \u0027LAML20\u0027:\n\t\tsystem.tag.writeBlocking(\"[default]Dewas/Legacy Axle/LEGACY AXLE MAIN LINE/LAML20/Number_Punching/MODEL\", Model)\n\t\tsystem.tag.writeBlocking(\"[default]Dewas/Legacy Axle/LEGACY AXLE MAIN LINE/LAML20/Number_Punching/SERIAL_NUMBER\", SerialNumber)\n\t\tsystem.tag.writeBlocking(\"[default]Dewas/Legacy Axle/LEGACY AXLE MAIN LINE/LAML20/Number_Punching/Shift\", shift)\n\t\tsystem.tag.writeBlocking(\"[default]Dewas/Legacy Axle/LEGACY AXLE MAIN LINE/LAML20/Number_Punching/Gear_Ratio\", GearRatio)\n\t\tmessage \u003d \"Serial Number sent for Punching successfully.\"\n\t\tstate \u003d \"info\"\n\t\tsystem.db.runNamedQuery(\"Project_VECV/ITSupport/InsertNumberPunchingStatus\",{\"WorkStationName\":WorkStation,\"SerialNumber\":serialNumber,\"BOMNumber\":Model,\"CreatedBy\":self.session.custom.loggedInUserId})\n\t\tProject_VECV.PopUp.Alerts.showAlert(str(state), str(state.capitalize()), str(message), \"true\", \"Okay\", \"\", \"\", \"\", \"\", \"closePopup\", \"closePopup\", \"closePopup\",\"\",\"\",\"\",\"\")\n\t\tself.getSibling(\"txtSerialNumber\").props.text \u003d \u0027\u0027\n\t\tself.getSibling(\"txtGearRatio\").props.text \u003d \u0027\u0027\n\t\tself.getSibling(\"txtShift\").props.text \u003d \u0027\u0027\n\t\tself.getSibling(\"drpStation\").props.value \u003d -1"
              },
